@namespace ProjectBlazor.Components

<button disabled="@(CurrentPage == 1)" @onclick="@(() => OnSetPage(1))"
        class="px-2 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
    <span style="font-family:serif;">«</span>
</button>

<button disabled="@(CurrentPage == 1)" @onclick="@(() => OnSetPage(CurrentPage - 1))"
        class="px-2 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
    <span style="font-family:serif;">‹</span>
</button>

@foreach (var p in Pages)
{
    if (p == null)
    {
        <span class="px-1 text-xs text-gray-400">…</span>
    }
    else
    {
        var pg = p.Value;
        <button @onclick="@(() => OnSetPage(pg))"
                class="@($"px-2 py-0.5 text-xs border rounded {(pg == CurrentPage ? "text-white border-transparent" : "border-gray-300 hover:bg-gray-100")}")"
                style="@(pg == CurrentPage ? "background:#C9A84C;" : "")">
            @pg
        </button>
    }
}

<button disabled="@(CurrentPage == TotalPages)" @onclick="@(() => OnSetPage(CurrentPage + 1))"
        class="px-2 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
    <span style="font-family:serif;">›</span>
</button>

<button disabled="@(CurrentPage == TotalPages)" @onclick="@(() => OnSetPage(TotalPages))"
        class="px-2 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
    <span style="font-family:serif;">»</span>
</button>

@code {
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    [Parameter]
    public int TotalPages { get; set; } = 1;

    [Parameter]
    public Action<int>? SetPageAction { get; set; }

    private List<int?> Pages { get; set; } = new();

    protected override void OnParametersSet()
    {
        Pages.Clear();
        for (int i = 1; i <= TotalPages; i++)
        {
            if (i == 1 || i == TotalPages || (i >= CurrentPage - 1 && i <= CurrentPage + 1))
            {
                Pages.Add(i);
            }
            else if (Pages.Count > 0 && Pages[^1] != null)
            {
                Pages.Add(null);
            }
        }
    }

    private void OnSetPage(int page)
    {
        SetPageAction?.Invoke(page);
    }
}
