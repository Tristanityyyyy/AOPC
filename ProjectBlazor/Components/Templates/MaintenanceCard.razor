@namespace ProjectBlazor.Components
@using ProjectBlazor.Components

<div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" 
     style="@(string.IsNullOrEmpty(Height) ? "" : $"height:{Height};"))">
    
    @* Dark header *@
    <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
         style="@ThemeConfig.Styles.HeaderGradient">
        <h4 class="text-sm font-medium text-white">@Title</h4>
    </div>

    @* Row 1: entries per page | toolbar right *@
    <div class="flex items-center justify-between mb-4 px-1">
        @ToolbarLeft
        @ToolbarRight
    </div>

    @* Body *@
    <div class="overflow-auto flex-1">
        @Body
    </div>

    @* Footer *@
    @if (Footer != null)
    {
        <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
            @Footer
        </div>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string? Height { get; set; }

    [Parameter]
    public RenderFragment? ToolbarLeft { get; set; }

    [Parameter]
    public RenderFragment? ToolbarRight { get; set; }

    [Parameter]
    public RenderFragment? Body { get; set; }

    [Parameter]
    public RenderFragment? Footer { get; set; }
}
