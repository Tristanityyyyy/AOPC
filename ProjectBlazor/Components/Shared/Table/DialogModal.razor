@* Components/Shared/DialogModal.razor *@
@using MudBlazor

@if (IsVisible)
{
    <div class="fixed inset-0 flex @PositionClass"
         style="z-index: 9999; background: rgba(0,0,0,0.4); @PaddingStyle">
        <div class="bg-white rounded-xl shadow-2xl w-full @MaxWidthClass flex flex-col"
             style="max-height: 90vh;">

            @* ── Header ── *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl flex-shrink-0"
                 style="@HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icon" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@Title</span>
                </div>
                <button @onclick="OnClose"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* ── Body ── *@
            <div class="overflow-y-auto px-6 py-5 flex-1">
                @ChildContent
            </div>

            @* ── Footer ── *@
            @if (FooterContent != null)
            {
                <div class="flex items-center justify-end gap-2 px-6 py-4 border-t border-gray-100 flex-shrink-0">
                    @FooterContent
                </div>
            }

        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public string HeaderGradient { get; set; } = "";
    [Parameter] public string MaxWidth { get; set; } = "md";  // sm | md | lg | 2xl
    [Parameter] public bool CenterVertically { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string MaxWidthClass => MaxWidth switch
    {
        "sm" => "max-w-sm",
        "lg" => "max-w-lg",
        "2xl" => "max-w-2xl",
        "3xl" => "max-w-3xl",  
        "4xl" => "max-w-4xl", 
        _ => "max-w-md"
    };

    private string PositionClass => CenterVertically
        ? "items-center justify-center"
        : "items-start justify-center";

    private string PaddingStyle => CenterVertically
        ? ""
        : "padding: 70px 20px 20px 20px;";
}