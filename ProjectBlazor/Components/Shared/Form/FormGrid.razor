@namespace ProjectBlazor.Components.Shared.Form

<div class="grid @GridClass gap-4">
    @ChildContent
</div>

@code {
    [Parameter] public int Columns { get; set; } = 2;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string GridClass => Columns switch
    {
        1 => "grid-cols-1",
        2 => "grid-cols-2",
        3 => "grid-cols-3",
        4 => "grid-cols-4",
        _ => "grid-cols-2"
    };
}
