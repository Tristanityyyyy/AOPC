@namespace ProjectBlazor.Components.Shared.Form

<div class="flex items-center gap-4 pb-2">
    <div class="@ImageClass overflow-hidden border-2 border-gray-200 bg-gray-100 flex items-center justify-center">
        @if (!string.IsNullOrEmpty(ImageUrl))
        {
            <img src="@ImageUrl" class="w-full h-full object-cover" alt="Preview" />
        }
        else
        {
            <MudIcon Icon="@PlaceholderIcon" Style="@($"font-size:28px; color:{ThemeConfig.Colors.Text.Muted};")" />
        }
    </div>
    <div>
        <label class="flex items-center gap-2 px-4 py-2 rounded-lg text-white text-xs font-medium cursor-pointer"
               style="background:@ButtonColor;">
            <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:14px;" Color="Color.Inherit" />
            @ButtonText
            <InputFile OnChange="HandleFileSelected" accept="image/*" class="hidden" />
        </label>
        <p class="text-xs text-gray-400 mt-1">JPG, PNG up to 5MB</p>
    </div>
</div>

@code {
    [Parameter] public string ImageUrl { get; set; } = "";
    [Parameter] public EventCallback<string> ImageUrlChanged { get; set; }
    [Parameter] public string ButtonText { get; set; } = "Upload Image";
    [Parameter] public string ButtonColor { get; set; } = "#C9A84C";
    [Parameter] public string ImageClass { get; set; } = "w-20 h-20 rounded";
    [Parameter] public string PlaceholderIcon { get; set; } = Icons.Material.Filled.Image;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            var dataUrl = $"data:{file.ContentType};base64,{base64}";
            await ImageUrlChanged.InvokeAsync(dataUrl);
        }
    }
}
