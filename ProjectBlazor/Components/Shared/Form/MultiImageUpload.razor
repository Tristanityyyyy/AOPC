@namespace ProjectBlazor.Components.Shared.Form

<div class="flex flex-col gap-2">
    <div class="flex flex-wrap gap-2">
        @foreach (var imageUrl in ImageUrls)
        {
            <div class="relative group">
                <img src="@imageUrl" class="w-16 h-16 rounded-lg object-cover border border-gray-200" alt="Hotel" />
                <button type="button" @onclick="() => RemoveImage(imageUrl)"
                        class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer border-none">
                    ×
                </button>
            </div>
        }
        
        @if (ImageUrls.Count < MaxImages)
        {
            <label class="w-16 h-16 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-gray-400 transition-colors">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 24px; color: #9CA3AF;" />
                <InputFile OnChange="HandleFileSelected" accept="image/*" class="hidden" />
            </label>
        }
    </div>
    
    @if (ImageUrls.Count > 0)
    {
        <span class="text-xs text-gray-500">@ImageUrls.Count / @MaxImages images</span>
    }
</div>

@code {
    [Parameter] public List<string> ImageUrls { get; set; } = new();
    [Parameter] public EventCallback<List<string>> ImageUrlsChanged { get; set; }
    [Parameter] public int MaxImages { get; set; } = 5;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && ImageUrls.Count < MaxImages)
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 10485760).ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            var imageUrl = $"data:{file.ContentType};base64,{base64}";
            
            ImageUrls.Add(imageUrl);
            await ImageUrlsChanged.InvokeAsync(ImageUrls);
        }
    }

    private async Task RemoveImage(string imageUrl)
    {
        ImageUrls.Remove(imageUrl);
        await ImageUrlsChanged.InvokeAsync(ImageUrls);
    }
}
