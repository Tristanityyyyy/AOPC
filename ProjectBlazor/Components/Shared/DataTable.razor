@namespace ProjectBlazor.Components.Shared
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared
@typeparam T

<div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="@ContainerStyle">
    <!-- Header -->
    <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-3"
         style="@(HeaderGradient ?? "")">
        <h4 class="text-sm font-medium text-white">@Title</h4>
        @if (ToolbarButtons != null)
        {
            <div class="flex items-center gap-2">
                @ToolbarButtons
            </div>
        }
    </div>

    <!-- Controls -->
    <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2 text-xs text-gray-600">
            <select value="@PageSize"
                    @onchange="OnPageSizeChanged"
                    class="border border-gray-300 rounded px-2 py-1 text-xs">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            entries per page
        </div>

        <div class="flex items-center gap-2 text-xs text-gray-600">
            @if (ShowImportExport)
            {
                <InputFile id="@($"importFile-{_randomId}")" OnChange="OnImportFileSelected" accept=".xlsx,.xls" class="hidden" />
                <label for="@($"importFile-{_randomId}")"
                       class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-300 bg-white text-xs text-gray-600 cursor-pointer hover:bg-gray-50 transition">
                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Style="font-size:13px;" />
                    @(ImportedFileName ?? "Choose File")
                </label>
                <button @onclick="OnImportClick"
                        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium transition"
                        style="background:@ButtonColor;">
                    <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" />
                    Upload
                </button>
                <button @onclick="OnExportTemplateClick"
                        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-600 hover:bg-gray-50 transition">
                    <MudIcon Icon="@Icons.Material.Filled.Download" Style="font-size:13px;" />
                    Download Template
                </button>
                <div class="w-px h-4 bg-gray-300 mx-1"></div>
            }
            <span class="text-xs text-gray-600 font-medium">Search:</span>
            <input type="text" @bind="SearchText" @bind:event="oninput"
                   class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                   placeholder="Type to search..." />
        </div>
    </div>

    <!-- Add Button -->
    @if (ShowAddButton)
    {
        <div class="mb-3 px-1">
            <button type="button" @onclick="OnAddButtonClick"
                    class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                    style="background: @ButtonColor;">
                + Add New
            </button>
        </div>
    }

    <!-- Table -->
    <div class="overflow-y-auto" style="max-height: @TableHeight; @TableWrapperStyle">
        <table class="text-xs" style="@TableStyle">
            <thead style="position:sticky; top:0; background:white; z-index:1;">
                <tr class="border-b-2 border-gray-200">
                    @foreach (var col in Columns)
                    {
                        var sortField = col.SortField ?? "";
                        <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                            style="width: @col.Width;"
                            @onclick="() => Sort(sortField)">
                            @col.Header
                            <span class="text-gray-400">@GetSortIcon(col.SortField)</span>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var (item, index) in PagedItems.Select((x, i) => (x, i)))
                {
                    <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                        @foreach (var col in Columns)
                        {
                            <td class="px-2" style="height: 72px; overflow: hidden; vertical-align: middle;">
                                @if (col.RenderCell != null)
                                {
                                    @col.RenderCell(item)
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100">
        <span class="text-xs text-gray-500">@ShowingText</span>
        <div class="flex items-center gap-1">

            <button type="button" @onclick="() => GoToPage(1)" disabled="@(CurrentPage == 1)"
                    class="w-6 h-6 text-xs rounded flex items-center justify-center cursor-pointer border"
                    style="@(CurrentPage == 1 ? "background:white; color:#ccc; border-color:#eee;" : "background:white; color:gray; border-color:#ddd;")">
                «
            </button>
            <button type="button" @onclick="() => GoToPage(CurrentPage - 1)" disabled="@(CurrentPage == 1)"
                    class="w-6 h-6 text-xs rounded flex items-center justify-center cursor-pointer border"
                    style="@(CurrentPage == 1 ? "background:white; color:#ccc; border-color:#eee;" : "background:white; color:gray; border-color:#ddd;")">
                ‹
            </button>

            @foreach (var pg in VisiblePages)
            {
                <button type="button" @onclick="() => GoToPage(pg)"
                        class="w-6 h-6 text-xs rounded flex items-center justify-center cursor-pointer border-none"
                        style="@(pg == CurrentPage ? $"background:{ButtonColor}; color:white;" : "background:white; color:gray; border:1px solid #ddd;")">
                    @pg
                </button>
            }

            <button type="button" @onclick="() => GoToPage(CurrentPage + 1)" disabled="@(CurrentPage == TotalPages)"
                    class="w-6 h-6 text-xs rounded flex items-center justify-center cursor-pointer border"
                    style="@(CurrentPage == TotalPages ? "background:white; color:#ccc; border-color:#eee;" : "background:white; color:gray; border-color:#ddd;")">
                ›
            </button>
            <button type="button" @onclick="() => GoToPage(TotalPages)" disabled="@(CurrentPage == TotalPages)"
                    class="w-6 h-6 text-xs rounded flex items-center justify-center cursor-pointer border"
                    style="@(CurrentPage == TotalPages ? "background:white; color:#ccc; border-color:#eee;" : "background:white; color:gray; border-color:#ddd;")">
                »
            </button>

        </div>
    </div>
</div>

@code {
    private readonly string _randomId = Guid.NewGuid().ToString("N")[..8];
    // change from private to internal or just remove the private keyword
    public int TotalPages => (int)Math.Ceiling(FilteredItems.Count / (double)PageSize);
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<T> Items { get; set; } = new();
    [Parameter] public List<TableColumn<T>> Columns { get; set; } = new();
    [Parameter] public Func<T, bool>? ExternalFilter { get; set; }
    [Parameter] public bool ShowAddButton { get; set; } = true;
    [Parameter] public string ButtonColor { get; set; } = "#3b82f6";
    [Parameter] public string TableHeight { get; set; } = "560px";
    [Parameter] public string ContainerStyle { get; set; } = "height:750px;";
    [Parameter] public EventCallback OnAddClick { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChange { get; set; }
    [Parameter] public string? HeaderGradient { get; set; }
    [Parameter] public string PrimaryColor { get; set; } = "#C9A84C";
    
    //TABLE STYLE
    [Parameter] public string TableWrapperStyle { get; set; } = "";
    [Parameter] public string TableStyle { get; set; } = "width: 100%;";

    [Parameter] public bool ShowImportExport { get; set; } = false;
    [Parameter] public string? ImportedFileName { get; set; }
    [Parameter] public EventCallback<string> OnImport { get; set; }
    [Parameter] public EventCallback OnImportButtonClick { get; set; }
    [Parameter] public EventCallback OnExportTemplateClick { get; set; }
    [Parameter] public RenderFragment? ToolbarButtons { get; set; }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        PageSize = int.Parse(e.Value?.ToString() ?? "10");
        CurrentPage = 1;
        await OnPageSizeChange.InvokeAsync(PageSize);
    }

    private async Task OnAddButtonClick()
    {
        await OnAddClick.InvokeAsync();
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        ImportedFileName = e.File.Name;
        await OnImport.InvokeAsync(e.File.Name);
    }

    private async Task OnImportClick()
    {
        await OnImportButtonClick.InvokeAsync();
    }

    private async Task HandleExportTemplateClick()
    {
        await OnExportTemplateClick.InvokeAsync();
    }

    private int _pageSize = 10;
    public int PageSize
    {
        get => _pageSize;
        set => _pageSize = value;
    }

    private int _currentPage = 1;
    public int CurrentPage
    {
        get => _currentPage;
        set => _currentPage = value;
    }

    private string _searchText = "";
    public string SearchText
    {
        get => _searchText;
        set => _searchText = value;
    }

    private string _sortField = "";
    private bool _sortAsc = true;

    private List<T> FilteredItems => Items.Where(item =>
        (ExternalFilter == null || ExternalFilter(item)) &&
        (string.IsNullOrWhiteSpace(SearchText) || ApplyFilter(item))
    ).ToList();

    private List<T> PagedItems => FilteredItems
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int From => FilteredItems.Count == 0 ? 0 : (CurrentPage - 1) * PageSize + 1;
    private int To => Math.Min(CurrentPage * PageSize, FilteredItems.Count);

    private string ShowingText => $"Showing {From} to {To} of {FilteredItems.Count} entries";

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var pages = new List<int>();
            for (int i = 1; i <= TotalPages; i++)
            {
                if (i == 1 || i == TotalPages || (i >= CurrentPage - 1 && i <= CurrentPage + 1))
                    pages.Add(i);
                else if (pages.LastOrDefault() != -1)
                    pages.Add(-1);
            }
            return pages.Where(p => p != -1);
        }
    }

    private bool ApplyFilter(T item) => true;

    private void Sort(string field)
    {
        if (string.IsNullOrEmpty(field)) return;
        if (_sortField == field)
            _sortAsc = !_sortAsc;
        else
        {
            _sortField = field;
            _sortAsc = true;
        }
        CurrentPage = 1;
    }

    private string GetSortIcon(string? field) => field == _sortField ? (_sortAsc ? "▲" : "▼") : "";

    private void GoToPage(int page) => CurrentPage = page;
}