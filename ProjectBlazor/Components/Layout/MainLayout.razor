@inherits LayoutComponentBase
@using MudBlazor
@using ProjectBlazor.Components

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="@($"background: linear-gradient(135deg, {ThemeConfig.Colors.Header.Start}, {ThemeConfig.Colors.Header.DarkVariant});")">
        <img src="/images/AOPCWHITEPNG.png"
             alt="Alfardan Oyster Logo"
             style="max-height: 50px; width: auto;" />
        <MudSpacer />
        <AuthorizeView>
            <NotAuthorized>
                <MudButton Href="/login"
                           Variant="Variant.Outlined"
                           Style="color: white; border-color: white;">
                    Login
                </MudButton>
            </NotAuthorized>
            <Authorized>
                <div style="display: flex; flex-direction: column; align-items: flex-end; margin-right: 12px;">
                    <MudText Style="color: white; font-size: 14px; font-weight: 500; line-height: 1.2;">
                        @context.User.Identity?.Name
                    </MudText>
                    <MudText Style="@($"color: {ThemeConfig.Colors.Primary}; font-size: 11px; line-height: 1.2;")">
                        @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                    </MudText>
                </div>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="2"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Style="@($"background: linear-gradient(180deg, {ThemeConfig.Colors.Header.Start}, {ThemeConfig.Colors.Header.DarkVariant});")">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
<AntiforgeryToken />

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = ThemeConfig.Colors.Primary,
            PrimaryDarken = ThemeConfig.Colors.Header.Start,
            AppbarBackground = ThemeConfig.Colors.Header.Start,
        }
    };
}