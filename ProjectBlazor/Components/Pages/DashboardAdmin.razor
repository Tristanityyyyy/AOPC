@page "/dashboardadmin"
@rendermode InteractiveServer

<style>
    .mud-carousel-indicators {
        display: none !important;
    }
</style>

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Dashboard Admin</h3>

<div class="grid grid-cols-12 gap-4">

    @* ── Top Bar ── *@
    <div class="col-span-12">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md h-16 flex items-center justify-end gap-2 p-4">
            <button class="flex items-center gap-2 px-4 py-2 rounded-full text-white text-sm cursor-pointer border-none"
                    style="background: #C9A84C;">
                <MudIcon Icon="@Icons.Material.Filled.DateRange" Style="font-size: 16px; color: white;" />
                Select Date
            </button>
            <div class="relative inline-block">
                <button @onclick="ToggleDropdown"
                        class="flex items-center justify-between gap-2 px-4 py-2 rounded-full text-white text-sm cursor-pointer border-none w-36"
                        style="background: #C9A84C;">
                    @_selectedDays
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="white">
                        <path d="M7 10l5 5 5-5z" />
                    </svg>
                </button>
                @if (_dropdownOpen)
                {
                    <div class="absolute right-0 mt-1 w-40 bg-white border border-gray-200 shadow-md rounded-lg z-50">
                        <div @onclick='@(() => SelectDay("Last 7 Days"))' class="px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-t-lg">Last 7 Days</div>
                        <div @onclick='@(() => SelectDay("Last 14 Days"))' class="px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 14 Days</div>
                        <div @onclick='@(() => SelectDay("Last 30 Days"))' class="px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 30 Days</div>
                        <div @onclick='@(() => SelectDay("Last 90 Days"))' class="px-4 py-2 text-sm text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-b-lg">Last 90 Days</div>
                    </div>
                }
            </div>
            <button class="flex items-center gap-2 px-4 py-2 rounded-full text-white text-sm cursor-pointer border-none"
                    style="background: #C9A84C;">
                <MudIcon Icon="@Icons.Material.Filled.FileDownload" Style="font-size: 16px; color: white;" />
                Export
            </button>
        </div>
    </div>

    @* ── Total User Chart (left) ── *@
    <div class="col-span-7">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4"
             style="height: 396px; overflow: hidden;">
            <p class="text-base font-medium mb-2" style="color: #C9A84C;">Total User</p>
            <div class="w-full" style="height: 320px;">
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_series"
                          ChartLabels="@_xAxisLabels"
                          ChartOptions="@_options"
                          Width="100%"
                          Height="320px"
                          ShowLegend="false" />
            </div>
        </div>
    </div>

    @* ── New User Registration + Support Center (right) ── *@
    <div class="col-span-5 flex flex-col gap-4">

        @* New User Registration *@
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4"
             style="height: 190px;">
            <div class="relative">
                <CardHeader Title="New User Registration"
                            ShowClearFilter="true"
                            ShowSelectDate="true"
                            ShowFilterDays="true"
                            ShowSelectCategory="false"
                            SelectedDays="@_selectedDays2"
                            OnClearFilter="ClearFilter2"
                            OnSelectDate="OpenDatePicker2"
                            OnToggleDropdown="ToggleDropdown2" />
                @if (_dropdownOpen2)
                {
                    <div class="absolute right-0 mt-1 w-28 bg-white border border-gray-200 shadow-md rounded-lg z-50">
                        <div @onclick='@(() => SelectDay2("Last 7 Days"))' class="px-2 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-t-lg">Last 7 Days</div>
                        <div @onclick='@(() => SelectDay2("Last 14 Days"))' class="px-2 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 14 Days</div>
                        <div @onclick='@(() => SelectDay2("Last 30 Days"))' class="px-2 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 30 Days</div>
                        <div @onclick='@(() => SelectDay2("Last 90 Days"))' class="px-2 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-b-lg">Last 90 Days</div>
                    </div>
                }
                <div class="flex flex-col mt-2 flex-1 justify-between items-center w-full">
                    <div class="flex items-center gap-3">
                        <div class="flex flex-col items-center">
                            <span class="text-8xl font-bold" style="color: #C9A84C;">@_newUsers</span>
                            <span class="text-xs text-gray-500 text-center">New User(s)</span>
                        </div>
                        <svg class="w-6 h-6 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
                            <path d="M3 12h18M15 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex flex-col items-center">
                            <span class="text-8xl font-bold" style="color: #C9A84C;">@_totalActiveUsers</span>
                            <span class="text-xs text-gray-500 text-center">Total Active User(s)</span>
                        </div>
                    </div>
                    <p class="text-xs m-0" style="color: #C9A84C;">
                        @_registrationPercent.ToString("F2")% of expected user(s) are registered.
                    </p>
                </div>
            </div>
        </div>

        @* Support Center *@
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4"
             style="height: 190px;">
            <p class="text-base font-medium mb-4" style="color: #C9A84C;">Support Center</p>
            <div class="flex flex-col items-center justify-center flex-1 w-full">
                <span class="text-8xl font-bold" style="color: #C9A84C;">@_concerns</span>
                <span class="text-xs text-gray-500 text-center">Total concern that need to attends</span>
            </div>
        </div>
    </div>

    @* ── Donut Carousel ── *@
    <div class="col-span-12 flex">
        <MudCarousel TData="string"
                     Class="w-full rounded-xl"
                     Style="height: 250px;"
                     ShowArrows="true"
                     ShowBullets="false"
                     AutoCycle="false">
            <MudCarouselItem>
                <div class="flex gap-4 w-full h-full">
                    @DonutCard("Top 3 Restaurant", _restaurantData, _restaurantLabels)
                    @DonutCard("Top 3 Hotels", _hotelData, _hotelLabels)
                    @DonutCard("Top 3 Store", _storeData, _storeLabels)
                </div>
            </MudCarouselItem>
            <MudCarouselItem>
                <div class="flex gap-4 w-full h-full">
                    @DonutCard("Top 3 Hotels", _hotelData, _hotelLabels)
                    @DonutCard("Top 3 Store", _storeData, _storeLabels)
                    @DonutCard("Top 3 Wellness", _wellnessData, _wellnessLabels)
                </div>
            </MudCarouselItem>
            <MudCarouselItem>
                <div class="flex gap-4 w-full h-full">
                    @DonutCard("Top 3 Store", _storeData, _storeLabels)
                    @DonutCard("Top 3 Wellness", _wellnessData, _wellnessLabels)
                    @DonutCard("Top 3 Offers", _offersData, _offersLabels)
                </div>
            </MudCarouselItem>
        </MudCarousel>
    </div>

    @* ── Call to Actions (left) ── *@
    <div class="col-span-8">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height: 550px;">
            <div class="relative">
                <CardHeader Title="Call to Actions"
                            ShowClearFilter="true"
                            ShowSelectDate="true"
                            ShowFilterDays="true"
                            ShowSelectCategory="true"
                            SelectedDays="@_ctaSelectedDays"
                            SelectedCategory="@_ctaSelectedCategory"
                            CategoryDropdownOpen="@_ctaCategoryDropdownOpen"
                            Categories="@_categories"
                            OnClearFilter="ClearCtaFilter"
                            OnSelectDate="OpenCtaDatePicker"
                            OnToggleDropdown="ToggleCtaDropdown"
                            OnToggleCategoryDropdown="ToggleCtaCategoryDropdown"
                            OnCategorySelected="SelectCtaCategory" />
                @if (_ctaDropdownOpen)
                {
                    <div class="absolute right-0 mt-1 w-36 bg-white border border-gray-200 rounded-lg shadow-lg z-50">
                        <div @onclick='@(() => SelectCtaDay("Last 7 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-t-lg">Last 7 Days</div>
                        <div @onclick='@(() => SelectCtaDay("Last 14 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 14 Days</div>
                        <div @onclick='@(() => SelectCtaDay("Last 30 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 30 Days</div>
                        <div @onclick='@(() => SelectCtaDay("Last 90 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-b-lg">Last 90 Days</div>
                    </div>
                }
            </div>

            <div class="flex items-center justify-between mt-3 mb-2">
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select class="border border-gray-300 rounded px-2 py-1 text-xs" @bind="_ctaPageSize">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    entries per page
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    Search:
                    <input type="text" @bind="_ctaSearch" @bind:event="oninput"
                           class="border border-gray-300 rounded px-2 py-1 text-xs w-40" />
                </div>
            </div>

            <div class="flex-1 overflow-y-auto" style="min-height: 0;">
                <table class="w-full text-xs">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortCta("Name")'>
                                Name <span class="text-gray-400">@SortIcon(_ctaSortCol, _ctaSortAsc, "Name")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortCta("Category")'>
                                Categories <span class="text-gray-400">@SortIcon(_ctaSortCol, _ctaSortAsc, "Category")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortCta("Call")'>
                                Call <span class="text-gray-400">@SortIcon(_ctaSortCol, _ctaSortAsc, "Call")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortCta("Email")'>
                                Email <span class="text-gray-400">@SortIcon(_ctaSortCol, _ctaSortAsc, "Email")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortCta("Book")'>
                                Book <span class="text-gray-400">@SortIcon(_ctaSortCol, _ctaSortAsc, "Book")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredCtaItems)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2 text-gray-700">@item.Name</td>
                                <td class="py-2 px-2 text-gray-600">@item.Category</td>
                                <td class="py-2 px-2 text-gray-600">@item.Call</td>
                                <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                <td class="py-2 px-2 text-gray-600">@item.Book</td>
                            </tr>
                        }
                        @for (int i = FilteredCtaItems.Count(); i < _ctaPageSize; i++)
                        {
                            <tr class="border-b border-gray-100">
                                <td class="py-2 px-2">&nbsp;</td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2"></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-3">
                <span class="text-xs text-gray-500">Showing @CtaFrom to @CtaTo of @_ctaItems.Count entries</span>
                <div class="flex items-center gap-1">
                    @RenderPagination(_ctaPage, CtaTotalPages, (p) => _ctaPage = p)
                </div>
            </div>
            <div class="flex justify-end mt-2">
                <button class="px-3 py-1.5 text-xs text-white rounded" style="background: #0D1B3A;">
                    Export Excel File
                </button>
            </div>
        </div>
    </div>

    @* ── Module Click Count (right) ── *@
    <div class="col-span-4">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height: 550px;">
            <div class="relative">
                <CardHeader Title="Module Click Count"
                            ShowClearFilter="true"
                            ShowSelectDate="true"
                            ShowFilterDays="true"
                            ShowSelectCategory="false"
                            SelectedDays="@_moduleSelectedDays"
                            OnClearFilter="ClearModuleFilter"
                            OnSelectDate="OpenModuleDatePicker"
                            OnToggleDropdown="ToggleModuleDropdown" />
                @if (_moduleDropdownOpen)
                {
                    <div class="absolute right-0 mt-1 w-36 bg-white border border-gray-200 rounded-lg shadow-lg z-50">
                        <div @onclick='@(() => SelectModuleDay("Last 7 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-t-lg">Last 7 Days</div>
                        <div @onclick='@(() => SelectModuleDay("Last 14 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 14 Days</div>
                        <div @onclick='@(() => SelectModuleDay("Last 30 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 30 Days</div>
                        <div @onclick='@(() => SelectModuleDay("Last 90 Days"))' class="px-3 py-2 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-b-lg">Last 90 Days</div>
                    </div>
                }
            </div>

            <div class="flex items-center justify-between mt-3 mb-2">
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select class="border border-gray-300 rounded px-2 py-1 text-xs" @bind="_modulePageSize">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    entries per page
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    Search:
                    <input type="text" @bind="_moduleSearch" @bind:event="oninput"
                           class="border border-gray-300 rounded px-2 py-1 text-xs w-28" />
                </div>
            </div>

            <div class="flex-1 overflow-y-auto" style="min-height: 0;">
                <table class="w-full text-xs">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortModule("Module")'>
                                Module <span class="text-gray-400">@SortIcon(_moduleSortCol, _moduleSortAsc, "Module")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortModule("Count")'>
                                Count <span class="text-gray-400">@SortIcon(_moduleSortCol, _moduleSortAsc, "Count")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredModuleItems)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2 text-gray-700">@item.Module</td>
                                <td class="py-2 px-2 text-gray-600">@item.Count</td>
                            </tr>
                        }
                        @for (int i = FilteredModuleItems.Count(); i < _modulePageSize; i++)
                        {
                            <tr class="border-b border-gray-100">
                                <td class="py-2 px-2">&nbsp;</td>
                                <td class="py-2 px-2"></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-3">
                <span class="text-xs text-gray-500">Showing @ModuleFrom to @ModuleTo of @_moduleItems.Count entries</span>
                <div class="flex items-center gap-1">
                    @RenderPagination(_modulePage, ModuleTotalPages, (p) => _modulePage = p)
                </div>
            </div>
            <div class="flex justify-end mt-2">
                <button class="px-3 py-1.5 text-xs text-white rounded" style="background: #0D1B2A;">
                    Export Excel File
                </button>
            </div>
        </div>
    </div>

    @if (_datePickerOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center"
             style="background: rgba(0,0,0,0.3);"
             @onclick="CloseDatePicker">
            <div class="bg-white rounded-2xl shadow-2xl p-6 w-96"
                 @onclick:stopPropagation="true">

                @* Header *@
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-semibold" style="color: #0D1B2A;">Select Date Range</h2>
                    <button @onclick="CloseDatePicker"
                            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-400 hover:text-gray-600 cursor-pointer border-none bg-transparent text-lg">
                        ✕
                    </button>
                </div>

                @* Date Inputs *@
                <div class="flex gap-4 mb-6">
                    <div class="flex-1">
                        <label class="block text-xs font-medium text-gray-500 mb-1">From Date</label>
                        <div class="flex items-center border-b-2 pb-2"
                             style="border-color: #C9A84C;">
                            <input type="date"
                                   @bind="_dateFrom"
                                   class="flex-1 text-sm text-gray-700 border-none outline-none bg-transparent cursor-pointer"
                                   style="color-scheme: light;" />
                        </div>
                    </div>
                    <div class="flex-1">
                        <label class="block text-xs font-medium text-gray-500 mb-1">To Date</label>
                        <div class="flex items-center border-b-2 pb-2"
                             style="border-color: #C9A84C;">
                            <input type="date"
                                   @bind="_dateTo"
                                   class="flex-1 text-sm text-gray-700 border-none outline-none bg-transparent cursor-pointer"
                                   style="color-scheme: light;" />
                        </div>
                    </div>
                </div>

                @* Error message *@
                @if (_dateError)
                {
                    <p class="text-xs text-red-500 mb-3">"From Date" must be before "To Date".</p>
                }

                @* Actions *@
                <div class="flex justify-end gap-2">
                    <button @onclick="CloseDatePicker"
                            class="px-4 py-2 text-xs rounded-full cursor-pointer border"
                            style="color: #C9A84C; border-color: #C9A84C; background: transparent;">
                        Cancel
                    </button>
                    <button @onclick="ApplyDateRange"
                            class="px-4 py-2 text-xs rounded-full text-white cursor-pointer border-none"
                            style="background: #C9A84C;">
                        Apply
                    </button>
                </div>
            </div>
        </div>
    }

    @* ── Company Information Table ── *@
    <div class="col-span-12">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">

            @* Header Bar *@
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-medium" style="color: #C9A84C;">Company Information</h3>
                <button class="flex items-center gap-2 px-4 py-2 rounded-full text-white text-sm cursor-pointer border-none"
                        style="background: #C9A84C;">
                    <MudIcon Icon="@Icons.Material.Filled.FileDownload" Style="font-size: 16px; color: white;" />
                    Export
                </button>
            </div>

            @* Controls: entries per page + search *@
            <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select class="border border-gray-300 rounded px-2 py-1 text-xs" @bind="_companyPageSize">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    entries per page
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    Search:
                    <input type="text" @bind="_companySearch" @bind:event="oninput"
                           class="border border-gray-300 rounded px-2 py-1 text-xs w-48" />
                </div>
            </div>

            @* Table *@
            <div class="overflow-x-auto">
                <table class="w-full text-xs">
                    <thead>
                        <tr class="border-b-2 border-gray-200">
                            <th class="text-left py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("CompanyName")'>
                                Company Name
                                <span class="text-gray-400">@CompanySortIcon("CompanyName")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("RegisteredUsers")'>
                                Registered Users
                                <span class="text-gray-400">@CompanySortIcon("RegisteredUsers")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("UnregisteredUsers")'>
                                Unregistered Users
                                <span class="text-gray-400">@CompanySortIcon("UnregisteredUsers")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("VipRegistered")'>
                                VIP Registered
                                <span class="text-gray-400">@CompanySortIcon("VipRegistered")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("VipUserCount")'>
                                VIP User Count
                                <span class="text-gray-400">@CompanySortIcon("VipUserCount")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("UserCount")'>
                                User Count
                                <span class="text-gray-400">@CompanySortIcon("UserCount")</span>
                            </th>
                            <th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCompany("TotalUsers")'>
                                Total Users
                                <span class="text-gray-400">@CompanySortIcon("TotalUsers")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredCompanyItems)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-3 text-gray-700">@item.CompanyName</td>
                                <td class="py-3 px-3 text-center text-gray-600">@item.RegisteredUsers</td>
                                <td class="py-3 px-3 text-center text-gray-600">
                                    <div>@item.UnregisteredUsers</div>
                                    <div class="text-gray-400" style="font-size: 10px;">Unregistered VIP count: @item.UnregisteredVipCount</div>
                                </td>
                                <td class="py-3 px-3 text-center text-gray-600">
                                    <div>@item.VipRegistered</div>
                                    <div class="text-gray-400" style="font-size: 10px;">Remaining VIP count: @item.RemainingVipCount</div>
                                </td>
