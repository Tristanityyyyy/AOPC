@* Reusable donut chart card component *@

<div class="flex-1 bg-white rounded-lg border border-gray-200 shadow-md p-4 flex flex-col">
    <p class="text-base font-medium" style="color: @ThemeConfig.Colors.Primary;">@Title</p>
    <div class="flex items-center justify-center gap-8 flex-1">
        <svg width="160" height="160" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="70" fill="none" stroke="@ThemeConfig.Colors.Border.Default" stroke-width="30" />
            <circle cx="100" cy="100" r="70" fill="none" stroke="@ThemeConfig.Colors.Header.Middle" stroke-width="30"
                    stroke-dasharray="@(Data[0] / 100 * 440) @(Data[1] / 100 * 440)"
                    stroke-dashoffset="0" transform="rotate(-90 100 100)" />
            <circle cx="100" cy="100" r="70" fill="none" stroke="@ThemeConfig.Colors.Primary" stroke-width="30"
                    stroke-dasharray="@(Data[1] / 100 * 440) @(Data[0] / 100 * 440)"
                    stroke-dashoffset="-@(Data[0] / 100 * 440)" transform="rotate(-90 100 100)" />
            <text x="100" y="105" text-anchor="middle" font-size="16" fill="@ThemeConfig.Colors.Text.Primary" font-weight="500">@Data[0]%</text>
        </svg>
        <div class="flex flex-col gap-2">
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-sm" style="background:@ThemeConfig.Colors.Header.Middle"></div>
                <span class="text-xs text-gray-600">@Labels[0] @Data[0]%</span>
            </div>
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-sm" style="background:@ThemeConfig.Colors.Primary"></div>
                <span class="text-xs text-gray-600">@Labels[1] @Data[1]%</span>
            </div>
        </div>
    </div>

    <div class="relative">
        <CardHeader ShowClearFilter="false"
                    ShowSelectDate="true"
                    ShowFilterDays="true"
                    ShowViewDetails="true"
                    ShowSelectCategory="false"
                    SelectedDays="@SelectedDays"
                    OnSelectDate="OnSelectDate"
                    OnToggleDropdown="OnToggleDropdown"
                    OnViewDetails="OnViewDetails" />
        @if (DropdownOpen)
        {
            <div class="absolute right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-50"
                 style="min-width: 120px;">
                <div @onclick='@(() => OnDaySelected.InvokeAsync("Last 7 Days"))' class="px-3 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-t-lg">Last 7 Days</div>
                <div @onclick='@(() => OnDaySelected.InvokeAsync("Last 14 Days"))' class="px-3 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 14 Days</div>
                <div @onclick='@(() => OnDaySelected.InvokeAsync("Last 30 Days"))' class="px-3 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer">Last 30 Days</div>
                <div @onclick='@(() => OnDaySelected.InvokeAsync("Last 90 Days"))' class="px-3 py-1.5 text-xs text-gray-700 hover:bg-amber-50 hover:text-amber-700 cursor-pointer rounded-b-lg">Last 90 Days</div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public double[] Data { get; set; } = Array.Empty<double>();
    [Parameter] public string[] Labels { get; set; } = Array.Empty<string>();
    [Parameter] public string SelectedDays { get; set; } = "Filter Days";
    [Parameter] public bool DropdownOpen { get; set; }
    [Parameter] public EventCallback OnSelectDate { get; set; }
    [Parameter] public EventCallback OnToggleDropdown { get; set; }
    [Parameter] public EventCallback OnViewDetails { get; set; }
    [Parameter] public EventCallback<string> OnDaySelected { get; set; }
}
