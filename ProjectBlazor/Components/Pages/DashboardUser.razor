@page "/dashboarduser"
@rendermode InteractiveServer
<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Dashboard User</h3>

<div class="grid grid-cols-12 gap-4">

    @* xs=12 top bar *@
    <div class="col-span-12">
        <div class="bg-white rounded-lg border border-gray-200 p-4 h-16 flex items-center justify-center">
            Top Bar
        </div>
    </div>

    @* xs=8 left card *@
    <div class="col-span-8">
        <div class="bg-white rounded-lg border border-gray-200 flex items-center justify-center"
             style="height: 376px;">
            xs=8
        </div>
    </div>

    @* xs=4 right cards *@
    <div class="col-span-4 flex flex-col gap-4">
        <div class="bg-white rounded-lg border border-gray-200 flex items-center justify-center"
             style="height: 180px;">
            xs=4 top
        </div>
        <div class="bg-white rounded-lg border border-gray-200 flex items-center justify-center"
             style="height: 180px;">
            xs=4 bottom
        </div>
    </div>

    <div class="col-span-12 flex">
    
<MudCarousel TData="string"
                   Class="w-full rounded-xl"
                   Style="height: 420px;"
                   ShowArrows="true","
                   ShowBullets="false"
                   AutoCycle="false">
                   
    <MudCarouselItem>
        <div class="flex gap-4 p-4 w-full h-full">
            <div class="flex-1 bg-white rounded-xl border border-gray-200 p-4 flex flex-col">
                <p class="text-base font-medium mb-4" style="color: #C9A84C;">Top 3 Restaurant</p>
                <div class="flex items-center justify-center gap-8 flex-1">
                    <svg width="200" height="200" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#e5e7eb" stroke-width="30" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#134E4A" stroke-width="30"
                                stroke-dasharray="293 146" stroke-dashoffset="0" transform="rotate(-90 100 100)" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#C9A84C" stroke-width="30"
                                stroke-dasharray="146 293" stroke-dashoffset="-293" transform="rotate(-90 100 100)" />
                        <text x="100" y="105" text-anchor="middle" font-size="16" fill="#0D1B2A" font-weight="500">66.67%</text>
                    </svg>
                    <div class="flex flex-col gap-2">
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#134E4A"></div><span class="text-sm text-gray-600">Bebabel 66.67%</span></div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#C9A84C"></div><span class="text-sm text-gray-600">Scalini 33.33%</span></div>
                    </div>
                </div>
            </div>

            <div class="flex-1 bg-white rounded-xl border border-gray-200 p-4 flex flex-col">
                <p class="text-base font-medium mb-4" style="color: #C9A84C;">Top 3 Hotels</p>
                <div class="flex items-center justify-center gap-8 flex-1">
                    <svg width="200" height="200" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#e5e7eb" stroke-width="30" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#134E4A" stroke-width="30"
                                stroke-dasharray="220 220" stroke-dashoffset="0" transform="rotate(-90 100 100)" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#C9A84C" stroke-width="30"
                                stroke-dasharray="220 220" stroke-dashoffset="-220" transform="rotate(-90 100 100)" />
                        <text x="100" y="105" text-anchor="middle" font-size="16" fill="#0D1B2A" font-weight="500">50%</text>
                    </svg>
                    <div class="flex flex-col gap-2">
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#134E4A"></div><span class="text-sm text-gray-600">St. Regis 50%</span></div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#C9A84C"></div><span class="text-sm text-gray-600">Four Seasons 50%</span></div>
                    </div>
                </div>
            </div>
        </div>
    </MudCarouselItem>

    <MudCarouselItem>
        <div class="flex gap-4 p-4 w-full h-full">
            <div class="flex-1 bg-white rounded-xl border border-gray-200 p-4 flex flex-col">
                <p class="text-base font-medium mb-4" style="color: #C9A84C;">Top 3 Store</p>
                <div class="flex items-center justify-center gap-8 flex-1">
                    <svg width="200" height="200" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#e5e7eb" stroke-width="30" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#134E4A" stroke-width="30"
                                stroke-dasharray="264 176" stroke-dashoffset="0" transform="rotate(-90 100 100)" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#C9A84C" stroke-width="30"
                                stroke-dasharray="176 264" stroke-dashoffset="-264" transform="rotate(-90 100 100)" />
                        <text x="100" y="105" text-anchor="middle" font-size="16" fill="#0D1B2A" font-weight="500">60%</text>
                    </svg>
                    <div class="flex flex-col gap-2">
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#134E4A"></div><span class="text-sm text-gray-600">Store A 60%</span></div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#C9A84C"></div><span class="text-sm text-gray-600">Store B 40%</span></div>
                    </div>
                </div>
            </div>

            <div class="flex-1 bg-white rounded-xl border border-gray-200 p-4 flex flex-col">
                <p class="text-base font-medium mb-4" style="color: #C9A84C;">Top 3 Spa</p>
                <div class="flex items-center justify-center gap-8 flex-1">
                    <svg width="200" height="200" viewBox="0 0 200 200">
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#e5e7eb" stroke-width="30" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#134E4A" stroke-width="30"
                                stroke-dasharray="308 132" stroke-dashoffset="0" transform="rotate(-90 100 100)" />
                        <circle cx="100" cy="100" r="70" fill="none" stroke="#C9A84C" stroke-width="30"
                                stroke-dasharray="132 308" stroke-dashoffset="-308" transform="rotate(-90 100 100)" />
                        <text x="100" y="105" text-anchor="middle" font-size="16" fill="#0D1B2A" font-weight="500">70%</text>
                    </svg>
                    <div class="flex flex-col gap-2">
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#134E4A"></div><span class="text-sm text-gray-600">Spa A 70%</span></div>
                        <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-sm" style="background:#C9A84C"></div><span class="text-sm text-gray-600">Spa B 30%</span></div>
                    </div>
                </div>
            </div>
        </div>
    </MudCarouselItem>

</MudCarousel>
</div>
@* xs=8 left card *@
    <div class="col-span-8">
        <div class="bg-white rounded-lg border border-gray-200 flex items-center justify-center"
                style="height: auto;">
            bottom 8
        </div>
    </div>

    @* xs=4 right cards *@
    <div class="col-span-4 flex flex-col gap-4">
        <div class="bg-white rounded-lg border border-gray-200 flex items-center justify-center"
                style="height: auto;">
            bottom 4
        </div>
    </div>
</div>
@code {
    private double[] _restaurantData = new double[] { 66.67, 33.33 };
    private string[] _restaurantLabels = new string[] { "Bebabel", "Scalini" };

    private double[] _hotelData = new double[] { 50, 50 };
    private string[] _hotelLabels = new string[] { "St. Regis", "Four Seasons" };

    private double[] _storeData = new double[] { 60, 40 };
    private string[] _storeLabels = new string[] { "Store A", "Store B" };

    private double[] _spaData = new double[] { 70, 30 };
    private string[] _spaLabels = new string[] { "Spa A", "Spa B" };

}