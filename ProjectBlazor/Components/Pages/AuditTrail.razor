@page "/audittrail"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Audit Trail</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <DataTable T="AuditTrailItem"
                   Title="Audit Trail"
                   Items="_auditItems"
                   Columns="_auditColumns"
                   ShowAddButton="false"
                   ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient" />
    </div>
</div>

@code {
    private List<TableColumn<AuditTrailItem>> _auditColumns = new();

    protected override void OnInitialized()
    {
        _auditColumns = new List<TableColumn<AuditTrailItem>>
        {
            new() {
                Header = "Employee ID", Width = "12%", SortField = "EmployeeID",
                RenderCell = item => __builder => {
<span class="text-gray-600">@item.EmployeeID</span>
; }
            },
            new() {
                Header = "Full Name", Width = "15%", SortField = "FullName",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.FullName</span>
; }
            },
            new() {
                Header = "Actions", Width = "20%", SortField = "Action",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.Actions</span>
; }
            },
            new() {
                Header = "Module", Width = "8%", SortField = "Module",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.Module</span>
; }
            },
            new() {
                Header = "Position Name", Width = "12%", SortField = "PositionName",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.PositionName</span>
; }
            },
            new() {
                Header = "Corporate Name", Width = "10%", SortField = "CorporateName",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.CorporateName</span>
; }
            },
            new() {
                Header = "User Type", Width = "10%", SortField = "UserType",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.UserType</span>
; }
            },
            new() {
                Header = "Date Created", Width = "13%", SortField = "DateCreated",
                RenderCell = item => __builder => {

<span class="text-gray-600">@item.DateCreated.ToString("g")</span>
; }
            }
        };
    }

