@page "/maintenance/position"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Position Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">

            @* Dark header *@
            <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <h4 class="text-sm font-medium text-white">Position Maintenance</h4>
            </div>

            @* Controls Row *@
            <div class="flex items-center justify-between mb-4 px-1">
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select value="@_pageSize" @onchange="e => { _pageSize = int.Parse(e.Value.ToString()); _page = 1; }"
                            class="border border-gray-300 rounded px-2 py-1 text-xs">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span>entries per page</span>
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <span class="font-medium">Search:</span>
                    <input type="text" @bind="_search" @bind:event="oninput"
                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                           placeholder="Type to search..." />
                </div>
            </div>

            @* Add New *@
            <div class="mb-3 px-1">
                <button class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                        style="background: #C9A84C;">
                    + Add New
                </button>
            </div>

            @* Table *@
            <div class="overflow-y-auto" style="max-height:600px;">
                <table class="w-full text-xs">
                    <thead style="position:sticky; top:0; background:white; z-index:1;">
                        <tr class="border-b-2 border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 30%;"
                                @onclick='() => Sort("Name")'>
                                Name <span class="text-gray-400">@SortIcon("Name")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 50%;"
                                @onclick='() => Sort("Description")'>
                                Description <span class="text-gray-400">@SortIcon("Description")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 20%;"
                                @onclick='() => Sort("DateCreated")'>
                                Date Created <span class="text-gray-400">@SortIcon("DateCreated")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, index) in FilteredItems.Select((x, i) => (x, i)))
                        {
                            <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                <td class="py-2 px-2" style="height: 64px; width: 30%;">
                                    <div class="relative w-full" style="height: 64px;">
                                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 8px;">
                                            @item.Code
                                        </div>
                                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 16px;">
                                            @item.Name
                                        </div>
                                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 36px;">
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: #C9A84C;">
                                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Edit
                                            </button>
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-gray-600" style="width: 50%;">@item.Description</td>
                                <td class="py-2 px-2 text-gray-600 whitespace-nowrap" style="width: 20%;">@item.DateCreated.ToString("M/d/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Footer *@
            <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                <span class="text-xs text-gray-500">
                    Showing @From to @To of @_totalCount entries
                </span>
                <div class="flex items-center gap-1">
                    <Pagination CurrentPage="_page" TotalPages="TotalPages" SetPageAction="p => _page = p" />
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private string _search = "";
    private int _pageSize = 10;
    private int _page = 1;
    private string _sortCol = "DateCreated";
    private bool _sortAsc = false;
    private int _totalCount = 0;

    private void Sort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = true; }
        _page = 1;
    }
    private string SortIcon(string col) => _sortCol == col ? (_sortAsc ? "↑" : "↓") : "⇅";

    private List<PositionItem> _items = new()
    {
        new("POS-001","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-002", "GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-003","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-004","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-005","President",            "President",             new DateTime(2024, 2, 25)),
        new("POS-006","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-007","GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-008","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-009","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-010","President",            "President",             new DateTime(2024, 2, 25)),
        new("POS-011","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-012","GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-013","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-014","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-015","President",            "President",             new DateTime(2024, 2, 25))
    };

    private IEnumerable<PositionItem> FilteredItems
    {
        get
        {
            var filtered = _items.Where(x =>
                string.IsNullOrEmpty(_search) ||
                x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                x.Description.Contains(_search, StringComparison.OrdinalIgnoreCase));

            var sorted = SortItems(filtered);
            _totalCount = sorted.Count();
            return sorted.Skip((_page - 1) * _pageSize).Take(_pageSize);
        }
    }

    private IEnumerable<PositionItem> SortItems(IEnumerable<PositionItem> items) =>
        (_sortCol, _sortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Description", true) => items.OrderBy(x => x.Description),
            ("Description", false) => items.OrderByDescending(x => x.Description),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int TotalPages => (int)Math.Ceiling(_totalCount / (double)_pageSize);
    private int From => _totalCount == 0 ? 0 : (_page - 1) * _pageSize + 1;
    private int To => Math.Min(_page * _pageSize, _totalCount);

    public record PositionItem(string Code, string Name, string Description, DateTime DateCreated);
}