@page "/maintenance/position"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Position Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <DataTable T="PositionItem"
                   Title="Position Maintenance"
                   Items="_items"
                   Columns="_posColumns"
                   ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                   OnAddClick="OpenAddPosition" />
    </div>
</div>
@* ── Add/Edit Position Dialog ── *@
@if (_showAddPositionDialog || _showEditPositionDialog)
{
    var isEdit = _showEditPositionDialog;
    <DialogModal IsVisible="_showAddPositionDialog || _showEditPositionDialog"
                 Title="@(isEdit ? "Edit Position" : "Add Position")"
                 Icon="@Icons.Material.Filled.Work"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="ClosePositionDialog">
        <ChildContent>
            <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-700">
                    Position Name <span class="text-red-500">*</span>
                </label>
                <input type="text" @bind="_positionName"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none @ThemeConfig.Styles.BorderFocus" />
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-700">Position Description</label>
                <input type="text" @bind="_positionDescription"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none @ThemeConfig.Styles.BorderFocus" />
            </div>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Submit"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="ClosePositionDialog"
                          OnConfirm="SavePositionDialog" />
        </FooterContent>
    </DialogModal>
}
@code {
    private List<TableColumn<PositionItem>> _posColumns = new();

    protected override void OnInitialized()
    {
        _posColumns = new List<TableColumn<PositionItem>>
        {
            new() {
                Header = "Name", Width = "30%", SortField = "Name",
                RenderCell = item => __builder => {
                    <div class="relative w-full" style="height:64px;">
                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:8px;">@item.Code</div>
                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 group-hover:translate-y-2" style="top:16px;">@item.Name</div>
                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 group-hover:translate-y-2" style="top:36px;">
                            <button @onclick="() => OpenEditPosition(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:14px;" Color="Color.Inherit" /> Edit
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:14px;" Color="Color.Inherit" /> Delete
                            </button>
                        </div>
                    </div>
                    ;
                }
            },
            new() {
                Header = "Description", Width = "50%", SortField = "Description",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Description</span>; }
            },
            new() {
                Header = "Date Created", Width = "20%", SortField = "DateCreated",
                RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateCreated.ToString("M/d/yyyy")</span>; }
            }
        };
    }

    private string _search = "";
    private int _pageSize = 10;
    private int _page = 1;
    private string _sortCol = "DateCreated";
    private bool _sortAsc = false;
    private int _totalCount = 0;

    private void Sort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = true; }
        _page = 1;
    }
    private string SortIcon(string col) => _sortCol == col ? (_sortAsc ? "↑" : "↓") : "⇅";

    private List<PositionItem> _items = new()
    {
        new("POS-001","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-002", "GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-003","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-004","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-005","President",            "President",             new DateTime(2024, 2, 25)),
        new("POS-006","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-007","GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-008","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-009","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-010","President",            "President",             new DateTime(2024, 2, 25)),
        new("POS-011","System Administrator", "System Administrator",  new DateTime(2023, 5, 26)),
        new("POS-012","GM",                   "General Manager",       new DateTime(2023, 5, 26)),
        new("POS-013","Customer Service",     "Contact Center",        new DateTime(2023, 5, 31)),
        new("POS-014","Account Manager",      "Account manager",       new DateTime(2024, 2, 25)),
        new("POS-015","President",            "President",             new DateTime(2024, 2, 25))
    };

    private IEnumerable<PositionItem> FilteredItems
    {
        get
        {
            var filtered = _items.Where(x =>
                string.IsNullOrEmpty(_search) ||
                x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                x.Description.Contains(_search, StringComparison.OrdinalIgnoreCase));

            var sorted = SortItems(filtered);
            _totalCount = sorted.Count();
            return sorted.Skip((_page - 1) * _pageSize).Take(_pageSize);
        }
    }

    private IEnumerable<PositionItem> SortItems(IEnumerable<PositionItem> items) =>
        (_sortCol, _sortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Description", true) => items.OrderBy(x => x.Description),
            ("Description", false) => items.OrderByDescending(x => x.Description),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int TotalPages => (int)Math.Ceiling(_totalCount / (double)_pageSize);
    private int From => _totalCount == 0 ? 0 : (_page - 1) * _pageSize + 1;
    private int To => Math.Min(_page * _pageSize, _totalCount);

    public record PositionItem(string Code, string Name, string Description, DateTime DateCreated);

    // ── POSITION DIALOG STATE ──
    private bool _showAddPositionDialog = false;
    private bool _showEditPositionDialog = false;
    private PositionItem? _editingPosition;

    private string _positionName = "";
    private string _positionDescription = "";

    private void OpenAddPosition()
    {
        _positionName = "";
        _positionDescription = "";
        _editingPosition = null;
        _showAddPositionDialog = true;
    }

    private void OpenEditPosition(PositionItem item)
    {
        _editingPosition = item;
        _positionName = item.Name;
        _positionDescription = item.Description;
        _showEditPositionDialog = true;
    }

    private void ClosePositionDialog()
    {
        _showAddPositionDialog = false;
        _showEditPositionDialog = false;
        _editingPosition = null;
    }

    private void SavePositionDialog()
    {
        if (_showEditPositionDialog && _editingPosition != null)
        {
            var index = _items.IndexOf(_editingPosition);
            if (index >= 0)
            {
                _items[index] = _editingPosition with
                {
                    Name = _positionName,
                    Description = _positionDescription
                };
            }
        }
        else
        {
            _items.Insert(0, new PositionItem(
                $"POS-{(_items.Count + 1):D3}",
                _positionName,
                _positionDescription,
                DateTime.Now
            ));
        }
        ClosePositionDialog();
    }
}