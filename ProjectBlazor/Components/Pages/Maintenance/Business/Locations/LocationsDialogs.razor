@namespace ProjectBlazor.Components.Pages.Maintenance.Business.Locations
@using ProjectBlazor.Components.Shared
@using ProjectBlazor.Components.Shared.Form
@using ProjectBlazor.Components.Shared.Table
@using MudBlazor

@if (ShowAddDialog)
{
    <DialogModal IsVisible="@ShowAddDialog"
               Title="Add Business Location"
               Icon="@Icons.Material.Filled.AddLocation"
               HeaderGradient="@LocationsBodyRef.LocationsHeader.HeaderGradient"
               CenterVertically="true"
               OnClose="() => ShowAddDialog = false">
        <ChildContent>
            <FormField Label="Name" Required>
                <TextInput @bind-Value="AddName" Placeholder="Enter location name" />
            </FormField>
            <FormField Label="Postal Code">
                <TextInput @bind-Value="AddPostalCode" Placeholder="Enter postal code" />
            </FormField>
            <FormField Label="Country" Required>
                <TextInput @bind-Value="AddCountry" Placeholder="Enter country" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Add Location"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => ShowAddDialog = false"
                          OnConfirm="Add" />
        </FooterContent>
    </DialogModal>
}

@if (ShowEditDialog)
{
    <DialogModal IsVisible="ShowEditDialog"
               Title="Edit Business Location"
               Icon="@Icons.Material.Filled.LocationOn"
               HeaderGradient="@LocationsBodyRef.LocationsHeader.HeaderGradient"
               CenterVertically="true"
               OnClose="CancelEdit">
        <ChildContent>
            <FormField Label="Name" Required>
                <TextInput @bind-Value="EditName" />
            </FormField>
            <FormField Label="Postal Code">
                <TextInput @bind-Value="EditPostalCode" />
            </FormField>
            <FormField Label="Country" Required>
                <TextInput @bind-Value="EditCountry" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Save Changes"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CancelEdit"
                          OnConfirm="SaveEdit" />
        </FooterContent>
    </DialogModal>
}

@code {
    [Parameter] public LocationsBody? LocationsBodyRef { get; set; }
    [Inject] private LocationsService? LocationsService { get; set; }
    [Inject] private ISnackbar? Snackbar { get; set; }
    
    private LocationsBody? LocationsBody => LocationsBodyRef;

    public bool ShowEditDialog { get; set; }
    public bool ShowAddDialog { get; set; }
    private LocationItem? EditingItem;
    private string EditName = "", EditPostalCode = "", EditCountry = "";
    private string AddName = "", AddPostalCode = "", AddCountry = "";
    private bool IsProcessing = false;

    public void OpenAdd() { AddName = ""; AddPostalCode = ""; AddCountry = ""; ShowAddDialog = true; StateHasChanged(); }

    private async Task Add()
    {
        if (IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var success = await LocationsService!.UpdateLocationAsync(
                0,
                AddName,
                AddPostalCode,
                AddCountry,
                $"LOC-{DateTime.Now.Ticks}",
                DateTime.Now
            );

            if (success)
            {
                LocationsBody?.Items.Insert(0, new LocationItem(0, $"LOC-{LocationsBody.Items.Count + 1:D3}", AddName, AddPostalCode, AddCountry, DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")));
                Snackbar?.Add("Location added successfully", Severity.Success);
                ShowAddDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to add location", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void OpenEdit(LocationItem item) { EditingItem = item; EditName = item.Name; EditPostalCode = item.PostalCode; EditCountry = item.Country; ShowEditDialog = true; StateHasChanged(); }

    private async Task SaveEdit()
    {
        if (EditingItem == null || IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var beforeData = new LocationDto
            {
                Id = EditingItem.Id,
                BusinessLocID = EditingItem.Code,
                City = EditingItem.Name,
                PostalCode = EditingItem.PostalCode,
                Country = EditingItem.Country,
                DateCreated = EditingItem.DateCreated
            };
            
            var success = await LocationsService!.UpdateLocationAsync(
                EditingItem.Id,
                EditName,
                EditPostalCode,
                EditCountry,
                EditingItem.Code,
                DateTime.Parse(EditingItem.DateCreated),
                beforeData
            );

            if (success)
            {
                if (LocationsBody != null)
                {
                    var i = LocationsBody.Items.FindIndex(x => x.Id == EditingItem.Id);
                    if (i >= 0) LocationsBody.Items[i] = new LocationItem(EditingItem.Id, EditingItem.Code, EditName, EditPostalCode, EditCountry, EditingItem.DateCreated);
                }
                Snackbar?.Add("Location updated successfully", Severity.Success);
                ShowEditDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to update location", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void CancelEdit() => ShowEditDialog = false;
}