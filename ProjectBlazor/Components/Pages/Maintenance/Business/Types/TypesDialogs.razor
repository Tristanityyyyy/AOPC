@namespace ProjectBlazor.Components.Pages.Maintenance.Business.Types
@using ProjectBlazor.Components.Shared
@using ProjectBlazor.Components.Shared.Form
@using ProjectBlazor.Components.Shared.Table
@using MudBlazor

@if (ShowEditDialog)
{
    <DialogModal IsVisible="ShowEditDialog"
               Title="Edit Business Type"
               Icon="@Icons.Material.Filled.Category"
               HeaderGradient="@TypesBodyRef.TypesHeader.HeaderGradient"
               OnClose="CancelEdit">
        <ChildContent>
            <FormField Label="Profile Picture">
                <ImageUpload @bind-ImageUrl="EditImageUrl" ImageClass="w-16 h-16 rounded-lg" PlaceholderIcon="@Icons.Material.Filled.Business" />
            </FormField>

            <FormField Label="Business Type Name" Required>
                <TextInput @bind-Value="EditTypeName" />
            </FormField>

            <FormField Label="Description">
                <TextAreaInput @bind-Value="EditTypeDescription" Rows="3" />
            </FormField>

            <FormField Label="Promo">
                <TextInput @bind-Value="EditTypePromo" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Save Changes"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CancelEdit"
                          OnConfirm="SaveEdit" />
        </FooterContent>
    </DialogModal>
}

@if (ShowAddDialog)
{
    <DialogModal IsVisible="ShowAddDialog"
               Title="Add Business Type"
               Icon="@Icons.Material.Filled.AddBusiness"
               HeaderGradient="@TypesBodyRef.TypesHeader.HeaderGradient"
               OnClose="() => ShowAddDialog = false">
        <ChildContent>
            <FormField Label="Profile Picture">
                <ImageUpload @bind-ImageUrl="AddImageUrl" ImageClass="w-16 h-16 rounded-lg" PlaceholderIcon="@Icons.Material.Filled.Business" />
            </FormField>

            <FormField Label="Business Type Name" Required>
                <TextInput @bind-Value="AddTypeName" Placeholder="Enter business type name" />
            </FormField>

            <FormField Label="Description">
                <TextAreaInput @bind-Value="AddTypeDescription" Rows="3" Placeholder="Enter description" />
            </FormField>

            <FormField Label="Promo">
                <TextInput @bind-Value="AddTypePromo" Placeholder="e.g. Up to 20% preferred rates" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Add Type"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => ShowAddDialog = false"
                          OnConfirm="Add" />
        </FooterContent>
    </DialogModal>
}

@code {
    [Parameter] public TypesBody? TypesBodyRef { get; set; }
    [Inject] private TypesService? TypesService { get; set; }
    [Inject] private ISnackbar? Snackbar { get; set; }
    
    private TypesBody? TypesBody => TypesBodyRef;

    public bool ShowEditDialog { get; set; }
    public bool ShowAddDialog { get; set; }
    private BusinessTypeItem? EditingItem;
    private string EditImageUrl = "", EditTypeName = "", EditTypeDescription = "", EditTypePromo = "";
    private string AddImageUrl = "", AddTypeName = "", AddTypeDescription = "", AddTypePromo = "";
    private bool IsProcessing = false;

    public void OpenAdd()
    {
        AddImageUrl = ""; AddTypeName = ""; AddTypeDescription = ""; AddTypePromo = "";
        ShowAddDialog = true;
        StateHasChanged();
    }

    private async Task Add()
    {
        if (IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var success = await TypesService!.UpdateBusinessTypeAsync(
                0,
                AddTypeName,
                AddTypeDescription,
                AddImageUrl,
                AddTypePromo,
                $"BT-{TypesBody?.Items.Count + 1:D3}",
                DateTime.Now
            );

            if (success)
            {
                TypesBody?.Items.Insert(0, new BusinessTypeItem(
                    0,
                    $"BT-{TypesBody.Items.Count + 1:D3}",
                    AddTypeName,
                    AddImageUrl,
                    AddTypePromo,
                    AddTypeDescription,
                    DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")
                ));
                Snackbar?.Add("Business type added successfully", Severity.Success);
                ShowAddDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to add business type", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void OpenEdit(BusinessTypeItem item)
    {
        EditingItem = item;
        EditImageUrl = item.ImageUrl;
        EditTypeName = item.Name;
        EditTypeDescription = item.Description;
        EditTypePromo = item.Promo;
        ShowEditDialog = true;
        StateHasChanged();
    }

    private async Task SaveEdit()
    {
        if (EditingItem == null || IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var beforeData = new BusinessTypeDto
            {
                Id = EditingItem.Id,
                BusinessTypeID = EditingItem.Code,
                BusinessTypeName = EditingItem.Name,
                ImgURL = EditingItem.ImageUrl,
                PromoText = EditingItem.Promo,
                Description = EditingItem.Description,
                DateCreated = EditingItem.DateCreated
            };
            
            var success = await TypesService!.UpdateBusinessTypeAsync(
                EditingItem.Id,
                EditTypeName,
                EditTypeDescription,
                EditImageUrl,
                EditTypePromo,
                EditingItem.Code,
                DateTime.Parse(EditingItem.DateCreated),
                beforeData
            );

            if (success)
            {
                if (TypesBody != null)
                {
                    var i = TypesBody.Items.FindIndex(x => x.Id == EditingItem.Id);
                    if (i >= 0)
                    {
                        TypesBody.Items[i] = new BusinessTypeItem(
                            EditingItem.Id,
                            EditingItem.Code,
                            EditTypeName,
                            EditImageUrl,
                            EditTypePromo,
                            EditTypeDescription,
                            EditingItem.DateCreated
                        );
                    }
                }
                Snackbar?.Add("Business type updated successfully", Severity.Success);
                ShowEditDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to update business type", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void CancelEdit() => ShowEditDialog = false;
}