@namespace ProjectBlazor.Components.Pages.Maintenance.Business.Hotels
@using ProjectBlazor.Components.Shared
@using ProjectBlazor.Components.Shared.Form
@using ProjectBlazor.Components.Shared.Table
@using ProjectBlazor.Components.Pages.Maintenance.Business.Locations
@using ProjectBlazor.Components.Pages.Maintenance.Business.Types
@rendermode InteractiveServer

@if (ShowEditDialog)
{
    <DialogModal IsVisible="ShowEditDialog"
               Title="Edit Hotel"
               Icon="@Icons.Material.Filled.Hotel"
               HeaderGradient="@HotelsBodyRef.HotelsHeader.HeaderGradient"
               MaxWidth="2xl"
               OnClose="CancelEdit">
        <ChildContent>
            <FormGrid Columns="2">
                <FormField Label="Profile Picture">
                    <ImageUpload @bind-ImageUrl="EditHotelImageUrl" ImageClass="w-16 h-16 rounded-lg" PlaceholderIcon="@Icons.Material.Filled.Hotel" />
                </FormField>
                <FormField Label="Hotel Pictures">
                    <MultiImageUpload @bind-ImageUrls="EditHotelImages" MaxImages="10" />
                </FormField>
            </FormGrid>

            <FormGrid Columns="2">
                <FormField Label="Hotel Name" Required>
                    <TextInput @bind-Value="EditHotelName" />
                </FormField>
                <FormField Label="Business Location">
                    <SelectInput @bind-Value="EditHotelLocation">
                        <option value="">Select Location</option>
                        @foreach (var loc in Locations)
                        {
                            <option value="@loc.City">@loc.City</option>
                        }
                    </SelectInput>
                </FormField>
                <FormField Label="Contact Number">
                    <TextInput @bind-Value="EditHotelContactNo" />
                </FormField>
                <FormField Label="Email">
                    <TextInput Type="email" @bind-Value="EditHotelEmail" />
                </FormField>
                <FormField Label="Website URL">
                    <TextInput @bind-Value="EditHotelUrl" />
                </FormField>
                <FormField Label="Services">
                    <TextInput @bind-Value="EditHotelServices" Placeholder="e.g. WiFi, Pool, Spa" />
                </FormField>
            </FormGrid>

            <FormField Label="Address">
                <TextAreaInput @bind-Value="EditHotelAddress" Rows="2" />
            </FormField>

            <FormField Label="Description">
                <TextAreaInput @bind-Value="EditHotelDescription" Rows="3" />
            </FormField>

            <FormField Label="Map (Embed URL or Address)">
                <TextInput @bind-Value="EditHotelMap" Placeholder="Google Maps embed URL or address" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Save Changes"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CancelEdit"
                          OnConfirm="SaveEdit" />
        </FooterContent>
    </DialogModal>
}

@if (ShowAddDialog)
{
    <DialogModal IsVisible="ShowAddDialog"
               Title="Add Hotel"
               Icon="@Icons.Material.Filled.AddHome"
               HeaderGradient="@HotelsBodyRef.HotelsHeader.HeaderGradient"
               MaxWidth="2xl"
               OnClose="() => ShowAddDialog = false">
        <ChildContent>
            <FormGrid Columns="2">
                <FormField Label="Profile Picture">
                    <ImageUpload @bind-ImageUrl="AddHotelImageUrl" ImageClass="w-16 h-16 rounded-lg" PlaceholderIcon="@Icons.Material.Filled.Hotel" />
                </FormField>
                <FormField Label="Hotel Pictures">
                    <MultiImageUpload @bind-ImageUrls="AddHotelImages" MaxImages="10" />
                </FormField>
            </FormGrid>

            <FormGrid Columns="2">
                <FormField Label="Hotel Name" Required>
                    <TextInput @bind-Value="AddHotelName" Placeholder="Enter hotel name" />
                </FormField>
                <FormField Label="Business Location">
                    <SelectInput @bind-Value="AddHotelLocation">
                        <option value="">Select Location</option>
                        @foreach (var loc in Locations)
                        {
                            <option value="@loc.City">@loc.City</option>
                        }
                    </SelectInput>
                </FormField>
                <FormField Label="Contact Number">
                    <TextInput @bind-Value="AddHotelContactNo" Placeholder="e.g. +974 4446 0000" />
                </FormField>
                <FormField Label="Email">
                    <TextInput Type="email" @bind-Value="AddHotelEmail" Placeholder="e.g. info@hotel.com" />
                </FormField>
                <FormField Label="Website URL">
                    <TextInput @bind-Value="AddHotelUrl" Placeholder="https://..." />
                </FormField>
                <FormField Label="Services">
                    <TextInput @bind-Value="AddHotelServices" Placeholder="e.g. WiFi, Pool, Spa" />
                </FormField>
            </FormGrid>

            <FormField Label="Address">
                <TextAreaInput @bind-Value="AddHotelAddress" Rows="2" Placeholder="Enter full address" />
            </FormField>

            <FormField Label="Description">
                <TextAreaInput @bind-Value="AddHotelDescription" Rows="3" Placeholder="Enter hotel description" />
            </FormField>

            <FormField Label="Map (Embed URL or Address)">
                <TextInput @bind-Value="AddHotelMap" Placeholder="Google Maps embed URL or address" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Add Hotel"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => ShowAddDialog = false"
                          OnConfirm="Add" />
        </FooterContent>
    </DialogModal>
}

@code {
    [Parameter] public HotelsBody? HotelsBodyRef { get; set; }
    [Inject] private LocationsService? LocationsService { get; set; }
    [Inject] private TypesService? TypesService { get; set; }
    [Inject] private HotelsService? HotelsService { get; set; }
    [Inject] private ISnackbar? Snackbar { get; set; }
    
    private HotelsBody? HotelsBody => HotelsBodyRef;
    private List<LocationDto> Locations = new();
    private List<BusinessTypeDto> BusinessTypes = new();
    private bool IsProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        Locations = await LocationsService!.GetLocationsAsync();
        BusinessTypes = await TypesService!.GetBusinessTypesAsync();
    }

    public bool ShowEditDialog { get; set; }
    public bool ShowAddDialog { get; set; }
    private HotelItem? EditingItem;
    private string EditHotelImageUrl = "", EditHotelName = "", EditHotelLocation = "";
    private string EditHotelAddress = "", EditHotelContactNo = "", EditHotelEmail = "";
    private string EditHotelUrl = "", EditHotelDescription = "", EditHotelServices = "", EditHotelMap = "";
    private int EditHotelTypeId = 0, EditHotelLocationId = 0;
    private List<string> EditHotelImages = new();
    private string AddHotelImageUrl = "", AddHotelName = "", AddHotelLocation = "";
    private string AddHotelAddress = "", AddHotelContactNo = "", AddHotelEmail = "";
    private string AddHotelUrl = "", AddHotelDescription = "", AddHotelServices = "", AddHotelMap = "";
    private int AddHotelTypeId = 0, AddHotelLocationId = 0;
    private List<string> AddHotelImages = new();

    public void OpenAdd()
    {
        AddHotelImageUrl = ""; AddHotelImages = new(); AddHotelName = ""; AddHotelLocation = "";
        AddHotelAddress = ""; AddHotelContactNo = ""; AddHotelEmail = ""; AddHotelUrl = "";
        AddHotelDescription = ""; AddHotelServices = ""; AddHotelMap = "";
        AddHotelTypeId = 0; AddHotelLocationId = 0;
        ShowAddDialog = true;
        StateHasChanged();
    }

    private async Task Add()
    {
        if (IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var gallery = string.Join(",", AddHotelImages);
            var success = await HotelsService!.SaveBusinessAsync(
                0,
                AddHotelName,
                AddHotelTypeId,
                AddHotelLocationId,
                AddHotelDescription,
                AddHotelAddress,
                AddHotelContactNo,
                AddHotelEmail,
                AddHotelUrl,
                AddHotelServices,
                AddHotelImageUrl,
                gallery,
                AddHotelMap,
                $"HTL-{DateTime.Now.Ticks}",
                DateTime.Now
            );

            if (success)
            {
                Snackbar?.Add("Hotel added successfully. Please refresh to see changes.", Severity.Success);
                ShowAddDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to add hotel", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void OpenEdit(HotelItem item)
    {
        EditingItem = item;
        EditHotelImageUrl = item.ImageUrl;
        EditHotelImages = string.IsNullOrEmpty(item.Gallery) ? new List<string>() : item.Gallery.Split(',').ToList();
        EditHotelName = item.Name;
        EditHotelLocation = item.Location;
        EditHotelAddress = item.Address;
        EditHotelContactNo = item.ContactNo;
        EditHotelEmail = item.Email;
        EditHotelUrl = item.Url;
        EditHotelDescription = item.Description;
        EditHotelServices = item.Services;
        EditHotelMap = item.Map;
        EditHotelTypeId = item.TypeId;
        EditHotelLocationId = item.LocationId;
        ShowEditDialog = true;
        StateHasChanged();
    }

    private async Task SaveEdit()
    {
        if (EditingItem == null || IsProcessing) return;
        
        IsProcessing = true;
        try
        {
            var gallery = string.Join(",", EditHotelImages);
            var success = await HotelsService!.SaveBusinessAsync(
                EditingItem.Id,
                EditHotelName,
                EditHotelTypeId,
                EditHotelLocationId,
                EditHotelDescription,
                EditHotelAddress,
                EditHotelContactNo,
                EditHotelEmail,
                EditHotelUrl,
                EditHotelServices,
                EditHotelImageUrl,
                gallery,
                EditHotelMap,
                EditingItem.Code,
                DateTime.Parse(EditingItem.DateCreated)
            );

            if (success)
            {
                if (HotelsBody != null)
                {
                    var i = HotelsBody.Items.FindIndex(x => x.Id == EditingItem.Id);
                    if (i >= 0)
                    {
                        HotelsBody.Items[i] = new HotelItem(
                            EditingItem.Id,
                            EditingItem.Code,
                            EditHotelName,
                            EditHotelImageUrl,
                            EditHotelLocation,
                            EditHotelAddress,
                            EditHotelContactNo,
                            EditHotelEmail,
                            EditHotelUrl,
                            EditHotelDescription,
                            EditingItem.DateCreated,
                            EditHotelTypeId,
                            EditHotelLocationId,
                            EditHotelServices,
                            gallery,
                            EditHotelMap
                        );
                    }
                }
                Snackbar?.Add("Hotel updated successfully", Severity.Success);
                ShowEditDialog = false;
            }
            else
            {
                Snackbar?.Add("Failed to update hotel", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
        }
    }

    public void CancelEdit() => ShowEditDialog = false;
}