@page "/maintenance/offering"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Offering Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <DataTable T="OfferingItem"
                   Title="Offering Maintenance"
                   Items="_offerItems"
                   Columns="_offerColumns"
                   ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                   ShowImportExport="true"
                   ImportedFileName="@_uploadedFileName"
                   OnAddClick="OpenAddOffer"
                   OnImport="HandleFileUpload"
                   OnImportButtonClick="HandleImportClick"
                   OnExportTemplateClick="HandleExportTemplate" />
    </div>
</div>
@* ── Add/Edit Offering Dialog ── *@
@if (_showAddOfferDialog || _showEditOfferDialog)
{
    var isEdit = _showEditOfferDialog;
    <div class="fixed inset-0 flex items-start justify-center z-[100]" style="background: rgba(0,0,0,0.4); padding: 70px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-3xl flex flex-col" style="max-height: calc(100vh - 90px);">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="@ThemeConfig.Styles.HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@(isEdit ? "Edit Offering" : "Add Offering")</span>
                </div>
                <button @onclick="CloseOfferDialog"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-5">

                @* Image Upload Row *@
                <div class="flex items-center gap-6">
                    <div class="relative flex-shrink-0">
                        @if (!string.IsNullOrEmpty(_offerImageUrl))
                        {
                            <img src="@_offerImageUrl"
                                 class="w-24 h-24 rounded-full object-cover border-2 border-gray-200" />
                        }
                        else
                        {
                            <div class="w-24 h-24 rounded-full border-2 border-gray-200 bg-gray-100 flex items-center justify-center">
                                <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Style="@($"font-size:32px; color:{ThemeConfig.Colors.Text.LightGray};")" />
                            </div>
                        }
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="flex items-center gap-2 px-5 py-2 rounded-lg text-white text-xs font-medium cursor-pointer w-fit"
                               style="background:@ThemeConfig.Colors.Primary;">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="white" stroke-width="2" fill="none" />
                                <polyline points="21,15 16,10 5,21" stroke="white" stroke-width="2" fill="none" />
                                <circle cx="8.5" cy="8.5" r="1.5" fill="white" />
                            </svg>
                            Upload Image
                            <InputFile OnChange="OnOfferImageSelected" accept="image/jpeg,image/png,image/webp" class="hidden" />
                        </label>
                        <span class="text-xs text-gray-400">Valid image type are JPEG, PNG, WEBP.</span>
                    </div>
                </div>

                @* Offering Name + Promo Description *@
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Offering Name</label>
                        <input type="text" @bind="_offerName"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Promo Description</label>
                        <textarea @bind="_offerPromoDescription" rows="3"
                                  class="w-full border border-gray-300 rounded px-3 py-2 text-xs resize-y focus:outline-none"></textarea>
                    </div>
                </div>

                @* Vendor Name + Business Type *@
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Vendor Name</label>
                        <select @bind="_offerVendorName"
                                class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                            <option value="">-Select Vendor-</option>
                            <option value="Vine Terrace">Vine Terrace</option>
                            <option value="Sky Lounge">Sky Lounge</option>
                            <option value="The Lounge">The Lounge</option>
                            <option value="Club Social">Club Social</option>
                            <option value="Alfardan Club">Alfardan Club</option>
                            <option value="Rift Bar">Rift Bar</option>
                            <option value="Executive Dining">Executive Dining</option>
                            <option value="FAUCHON">FAUCHON</option>
                            <option value="Serenity Spa">Serenity Spa</option>
                            <option value="Royal Golf Club">Royal Golf Club</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Business Type</label>
                        <select @bind="_offerBusinessType"
                                class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                            <option value="">-Select Business Type-</option>
                            <option value="Food & Beverages">Food & Beverages</option>
                            <option value="Health">Health</option>
                            <option value="Rooms & Suites">Rooms & Suites</option>
                            <option value="Wellness">Wellness</option>
                            <option value="Sports & Leisure">Sports & Leisure</option>
                            <option value="Access to co-working spaces">Access to co-working spaces</option>
                        </select>
                    </div>
                </div>

                @* Membership Tier + Offering URL *@
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Membership Tier</label>
                        <select @bind="_offerMembershipTier"
                                class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                            <option value="">-ALL TIERS-</option>
                            <option value="EXCLUSIVE - VIP">EXCLUSIVE - VIP</option>
                            <option value="PLATINUM">PLATINUM</option>
                            <option value="EXCLUSIVE">EXCLUSIVE</option>
                            <option value="EXCLUSIVE OMAN">EXCLUSIVE OMAN</option>
                            <option value="BRONZE">BRONZE</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Offering URL</label>
                        <input type="text" @bind="_offerUrl"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none"
                               placeholder="https://" />
                    </div>
                </div>

                @* Start Date + End Date *@
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Start Date</label>
                        <input type="date" @bind="_offerStartDate"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">End Date</label>
                        <input type="date" @bind="_offerEndDate"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                    </div>
                </div>

                @* From Time + To Time + Offer Days *@
                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">From Time</label>
                        <input type="time" @bind="_offerFromTime"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">To Time</label>
                        <input type="time" @bind="_offerToTime"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Offer Days</label>
                        <input type="text" @bind="_offerDays"
                               class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none"
                               placeholder="e.g. Sunday to Wednesday" />
                    </div>
                </div>

            </div>

            @* Footer *@
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-100">
                <button @onclick="CloseOfferDialog"
                        class="text-xs cursor-pointer bg-transparent border-none hover:text-gray-700 underline"
                        style="color:@ThemeConfig.Colors.Primary;">
                    Cancel
                </button>
                <button @onclick="SaveOfferDialog"
                        class="px-6 py-2 text-xs rounded-lg text-white font-medium border-none cursor-pointer"
                        style="@ThemeConfig.Styles.ButtonPrimary">
                    Submit
                </button>
            </div>

        </div>
    </div>
}
@code {
    private List<TableColumn<OfferingItem>> _offerColumns = new();

    protected override void OnInitialized()
    {
        _offerColumns = new List<TableColumn<OfferingItem>>
        {
            new() {
                Header = "", Width = "5%",
                RenderCell = item => __builder => {
                    <div class="w-10 h-10 rounded overflow-hidden flex-shrink-0 flex items-center justify-center pointer-events-none"
                         style="background:@ThemeConfig.Colors.Header.DarkerVariant;">
                        @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                        {
                            <img src="@item.ThumbnailUrl" alt="@item.PromoName" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Style="@($"font-size:16px; color:{ThemeConfig.Colors.Primary};")" />
                        }
                    </div>
                    ;
                }
            },
            new() {
                Header = "Promo Name", Width = "15%", SortField = "PromoName",
                RenderCell = item => __builder => {
                    <div class="relative w-full" style="height:64px;">
                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:8px;">@item.Code</div>
                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 group-hover:translate-y-2" style="top:16px;">@item.PromoName</div>
                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 group-hover:translate-y-2" style="top:36px;">
                            <button @onclick="() => OpenEditOffer(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:14px;" Color="Color.Inherit" /> Edit
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:14px;" Color="Color.Inherit" /> Delete
                            </button>
                        </div>
                    </div>
                    ;
                }
            },
            new() {
                Header = "Promo Description", Width = "20%", SortField = "PromoDescription",
                RenderCell = item => __builder => { <span class="text-gray-600 line-clamp-3">@item.PromoDescription</span>; }
            },
            new() {
                Header = "Vendor Name", Width = "12%", SortField = "VendorName",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.VendorName</span>; }
            },
            new() {
                Header = "Business Type Name", Width = "13%", SortField = "BusinessTypeName",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.BusinessTypeName</span>; }
            },
            new() {
                Header = "Membership Tier", Width = "10%", SortField = "MembershipTier",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.MembershipTier</span>; }
            },
            new() {
                Header = "DateCreated", Width = "10%", SortField = "DateCreated",
                RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateCreated.ToString("M/d/yyyy")</span>; }
            },
            new() {
                Header = "Status", Width = "8%", SortField = "Status",
                RenderCell = item => __builder => {
                    <span class="@(item.Status == "Active" ? "text-green-600 font-medium" : "text-red-500")">@item.Status</span>;
                }
            }
        };
    }

    private string? _uploadedFileName;

    private async Task HandleFileUpload(string fileName)
    {
        _uploadedFileName = fileName;
        await Task.CompletedTask;
    }

    private Task HandleImportClick()
    {
        return Task.CompletedTask;
    }

    private Task HandleExportTemplate()
    {
        return Task.CompletedTask;
    }

    private string _offerSearch = "";
    private int _offerPageSize = 10;
    private int _offerPage = 1;
    private string _offerSortCol = "DateCreated";
    private bool _offerSortAsc = false;
    private int _totalFilteredCount = 0;

    private void SortOffer(string col)
    {
        if (_offerSortCol == col) _offerSortAsc = !_offerSortAsc;
        else { _offerSortCol = col; _offerSortAsc = true; }
        _offerPage = 1;
    }
    private string OfferSortIcon(string col) => _offerSortCol == col ? (_offerSortAsc ? "↑" : "↓") : "⇅";

    private List<OfferingItem> _offerItems = new()
    {
        new("Offering-001", null, "Fisherman's Night",        "Savor the finest treasures of the sea at Vine Terrace. Every Wednesday | 6 PM – 10.30 PM QAR 295 per person including soft beverages QAR 145 per child (6-12 years)", "Vine Terrace",       "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-002",null, "Mediterranean BBQ Night",  "Join us for an evening of exquisite aromas and grilled delights at Vine Terrace. Every Thursday | 6 PM – 10.30 PM QAR 295 per person including soft beverages QAR 145 per child (6-12 years)", "Vine Terrace", "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-003",null, "Gentlemen Night",          "For the discerning gentleman. Taste, class, and bold aromas. * 1 selected cigar + 2 crafted cocktails * Price: 225 QAR", "Sky Lounge",         "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-004",null, "Melody Night",             "Midweek melodies, vintage charm. • Live music performance • Happy Hour menu available", "The Lounge",          "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-005",null, "Strictly Old School",      "Ladies Package 3 sips for QAR 125", "Club Social",                                                                   "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-006",null, "Turkish Delight Tuesdays", "DJ EBRU setting the stage with 80's & 90's Turkish Hits. Turkish locals, we've got you! Enjoy a 20% discount, and ladies get two complimentary beverage. IT'S A NIGHT MADE FOR YOU!", "Alfardan Club", "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-007",null, "Sounds of Africa",         "2 complimentary sips for the Ladies 9:30pm to 2:00am Every Wednesday", "Rift Bar",           "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-008",null, "Business Lunch",           "Reimagining business lunch as a refined affair that strikes the perfect balance between work and leisure, featuring exquisite cuisine in an ambiance conducive for success. 100 QAR 2 courses 120 QAR 3 courses", "Executive Dining", "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-009",null, "FAUCHON Afternoon Tea",    "Afternoon Tea QAR 290 for two persons", "FAUCHON",                                                                   "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-010",null, "Pizza & Vino",             "175 QAR per person for two hours of unlimited pizzas, grapes, and hops. Available every Sunday from 6pm to 10pm.", "Vino Corner",        "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-012",null, "Agora Night",              "A gathering of sips & bites. Every Wednesday from 7pm till 9:30pm, QAR 170 per person including unlimited sips & bites", "Agora Terrace",  "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-013",null, "Botana Bloom",             "Special Spritz Selection (QAR 45 per drink) & Signature Chicken Nachos (QAR 70)", "Botana",              "Food & Beverages", "EXCLUSIVE", new DateTime(2025,6,11), "Expired"),
        new("Offering-014",null, "Spa Sunday Retreat",       "Full-body rejuvenation package every Sunday. 60-min massage + access to thermal suite. QAR 350 per person.", "Serenity Spa",      "Wellness",         "BRONZE",    new DateTime(2025,7,1),  "Active"),
        new("Offering-015",null, "Golf Morning Classic",     "Tee off with complimentary green fee + breakfast. Weekdays 7 AM – 11 AM.", "Royal Golf Club",   "Sports & Leisure", "EXCLUSIVE - VIP", new DateTime(2025,7,15), "Active"),
    };

    private IEnumerable<OfferingItem> FilteredOfferItems
    {
        get
        {
            var filtered = _offerItems.Where(x =>
                string.IsNullOrEmpty(_offerSearch) ||
                x.PromoName.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase) ||
                x.PromoDescription.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase) ||
                x.VendorName.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase) ||
                x.BusinessTypeName.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase) ||
                x.MembershipTier.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase) ||
                x.Status.Contains(_offerSearch, StringComparison.OrdinalIgnoreCase));

            var sorted = SortOfferItems(filtered);
            _totalFilteredCount = sorted.Count();
            return sorted.Skip((_offerPage - 1) * _offerPageSize).Take(_offerPageSize);
        }
    }

    private IEnumerable<OfferingItem> SortOfferItems(IEnumerable<OfferingItem> items) =>
        (_offerSortCol, _offerSortAsc) switch
        {
            ("PromoName", true) => items.OrderBy(x => x.PromoName),
            ("PromoName", false) => items.OrderByDescending(x => x.PromoName),
            ("PromoDescription", true) => items.OrderBy(x => x.PromoDescription),
            ("PromoDescription", false) => items.OrderByDescending(x => x.PromoDescription),
            ("VendorName", true) => items.OrderBy(x => x.VendorName),
            ("VendorName", false) => items.OrderByDescending(x => x.VendorName),
            ("BusinessTypeName", true) => items.OrderBy(x => x.BusinessTypeName),
            ("BusinessTypeName", false) => items.OrderByDescending(x => x.BusinessTypeName),
            ("MembershipTier", true) => items.OrderBy(x => x.MembershipTier),
            ("MembershipTier", false) => items.OrderByDescending(x => x.MembershipTier),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            ("Status", true) => items.OrderBy(x => x.Status),
            ("Status", false) => items.OrderByDescending(x => x.Status),
            _ => items
        };

    private int OfferTotalPages => (int)Math.Ceiling(_totalFilteredCount / (double)_offerPageSize);
    private int OfferFrom => _totalFilteredCount == 0 ? 0 : (_offerPage - 1) * _offerPageSize + 1;
    private int OfferTo => Math.Min(_offerPage * _offerPageSize, _totalFilteredCount);

    public record OfferingItem(
        string Code,
        string? ThumbnailUrl,
        string PromoName,
        string PromoDescription,
        string VendorName,
        string BusinessTypeName,
        string MembershipTier,
        DateTime DateCreated,
        string Status);

    // ── OFFERING DIALOG STATE ──
    private bool _showAddOfferDialog = false;
    private bool _showEditOfferDialog = false;
    private OfferingItem? _editingOffer;

    // Offer form fields
    private string _offerImageUrl = "";
    private string _offerName = "";
    private string _offerPromoDescription = "";
    private string _offerVendorName = "";
    private string _offerBusinessType = "";
    private string _offerMembershipTier = "";
    private string _offerUrl = "";
    private DateTime _offerStartDate = DateTime.Today;
    private DateTime _offerEndDate = DateTime.Today; 
    private TimeOnly _offerFromTime = new TimeOnly(18, 0);
    private TimeOnly _offerToTime = new TimeOnly(21, 0);
    private string _offerDays = "";

    private void OpenAddOffer()
    {
        _offerImageUrl = ""; _offerName = ""; _offerPromoDescription = "";
        _offerVendorName = ""; _offerBusinessType = ""; _offerMembershipTier = "";
        _offerUrl = ""; _offerStartDate = DateTime.Today; _offerEndDate = DateTime.Today;
        _offerFromTime = new TimeOnly(18, 0);
        _offerToTime = new TimeOnly(21, 0);
        _offerDays = "";
        _showAddOfferDialog = true;
    }

    private void OpenEditOffer(OfferingItem item)
    {
        _editingOffer = item;
        _offerImageUrl = item.ThumbnailUrl ?? "";
        _offerName = item.PromoName;
        _offerPromoDescription = item.PromoDescription;
        _offerVendorName = item.VendorName;
        _offerBusinessType = item.BusinessTypeName;
        _offerMembershipTier = item.MembershipTier;
        _offerUrl = "";
        _offerStartDate = item.DateCreated;
        _offerEndDate = item.DateCreated;
        _offerFromTime = new TimeOnly(18, 0);
        _offerToTime = new TimeOnly(21, 0);
        _offerDays = "";
        _showEditOfferDialog = true;
    }

    private void CloseOfferDialog()
    {
        _showAddOfferDialog = false;
        _showEditOfferDialog = false;
        _editingOffer = null;
    }

    private void SaveOfferDialog()
    {
        if (_showEditOfferDialog && _editingOffer != null)
        {
            var index = _offerItems.IndexOf(_editingOffer);
            if (index >= 0)
            {
                _offerItems[index] = _editingOffer with
                {
                    ThumbnailUrl = _offerImageUrl,
                    PromoName = _offerName,
                    PromoDescription = _offerPromoDescription,
                    VendorName = _offerVendorName,
                    BusinessTypeName = _offerBusinessType,
                    MembershipTier = _offerMembershipTier
                };
            }
        }
        else
        {
            _offerItems.Insert(0, new OfferingItem(
                $"Offering-{(_offerItems.Count + 1):D3}",
                string.IsNullOrEmpty(_offerImageUrl) ? null : _offerImageUrl,
                _offerName,
                _offerPromoDescription,
                _offerVendorName,
                _offerBusinessType,
                _offerMembershipTier,
                _offerStartDate,
                "Active"
            ));
        }
        CloseOfferDialog();
    }

    private async Task OnOfferImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        _offerImageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }
}
