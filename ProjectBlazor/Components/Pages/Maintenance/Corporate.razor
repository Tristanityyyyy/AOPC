@page "/maintenance/corporate"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Corporate Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <MaintenanceCard Title="Corporate Maintenance" Height="920px">
            <ToolbarLeft>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select value="@_corpPageSize" @onchange="e => { _corpPageSize = int.Parse(e.Value.ToString()); _corpPage = 1; }"
                            class="border border-gray-300 rounded px-2 py-1 text-xs">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span>entries per page</span>
                </div>
            </ToolbarLeft>
            <ToolbarRight>
                <div class="flex items-center gap-2">

                    @* Buttons group *@
                    <InputFile id="excelFileInput" OnChange="HandleFileUpload" accept=".xlsx,.xls" class="hidden" />
                    <label for="excelFileInput"
                           class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-300 bg-white text-xs text-gray-600 cursor-pointer hover:bg-gray-50 transition">
                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" Style="font-size:13px;" />
                        @(_uploadedFileName ?? "Choose File")
                    </label>
                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium transition"
                            style="background:#C9A84C;">
                        <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" />
                        Upload
                    </button>
                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-600 hover:bg-gray-50 transition">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Style="font-size:13px;" />
                        Download Template
                    </button>

                    @* Divider *@
                    <div class="w-px h-4 bg-gray-300 mx-1"></div>

                    @* Search *@
                    <span class="text-xs text-gray-600 font-medium">Search:</span>
                    <input type="text" @bind="_corpSearch" @bind:event="oninput"
                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                           placeholder="Type to search..." />

                </div>
            </ToolbarRight>
            <Body>
                <div class="mb-4 px-1">
                    <button @onclick="OpenAddCorporate" class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: #C9A84C;">
                        + Add New
                    </button>
                </div>
                <table class="w-full text-xs">
                    <thead style="position:sticky; top:0; background:white; z-index:1;">
                        <tr class="border-b-2 border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 20%;"
                                @onclick='() => SortCorp("Name")'>
                                Name <span class="text-gray-400">@CorpSortIcon("Name")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 20%;"
                                @onclick='() => SortCorp("Address")'>
                                Address <span class="text-gray-400">@CorpSortIcon("Address")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 10%;"
                                @onclick='() => SortCorp("ContactNumber")'>
                                Contact Number <span class="text-gray-400">@CorpSortIcon("ContactNumber")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 12%;"
                                @onclick='() => SortCorp("EmailAddress")'>
                                Email Address <span class="text-gray-400">@CorpSortIcon("EmailAddress")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 8%;"
                                @onclick='() => SortCorp("MembershipTier")'>
                                Membership Tier <span class="text-gray-400">@CorpSortIcon("MembershipTier")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 8%;"
                                @onclick='() => SortCorp("UserCount")'>
                                User Count <span class="text-gray-400">@CorpSortIcon("UserCount")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 7%;"
                                @onclick='() => SortCorp("VipCount")'>
                                VIP Count <span class="text-gray-400">@CorpSortIcon("VipCount")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 15%;"
                                @onclick='() => SortCorp("MembershipDescription")'>
                                Membership Description <span class="text-gray-400">@CorpSortIcon("MembershipDescription")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 10%;"
                                @onclick='() => SortCorp("DateCreated")'>
                                Date Created <span class="text-gray-400">@CorpSortIcon("DateCreated")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (item, index) in FilteredCorpItems.Select((x, i) => (x, i)))
                        {
                            <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                <td class="py-2 px-2" style="height: 64px;">
                                    <div class="relative w-full" style="height: 64px;">
                                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 8px;">
                                            @item.Code
                                        </div>
                                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 16px;">
                                            @item.Name
                                        </div>
                                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 36px;">
                                            <button @onclick="() => OpenEditCorporate(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: #C9A84C;">
                                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Edit
                                            </button>
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Delete
                                            </button>
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 14px;" Color="Color.Inherit" />
                                                View
                                            </button>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-gray-600" style="width: 20%;">@item.Address</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 10%;">@item.ContactNumber</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 12%;">@item.EmailAddress</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 8%;">@item.MembershipTier</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 8%;">@item.UserCount</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 7%;">@item.VipCount</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 15%;">@item.MembershipDescription</td>
                                <td class="py-2 px-2 text-gray-600" style="width: 10%;">@item.DateCreated</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </Body>
            <Footer>
                <span class="text-xs text-gray-500">
                    Showing @CorpFrom to @CorpTo of @_corpItems.Count entries
                </span>
                <div class="flex items-center gap-1">
                    <Pagination CurrentPage="_corpPage" TotalPages="CorpTotalPages" SetPageAction="p => _corpPage = p" />
                </div>
            </Footer>
        </MaintenanceCard>
    </div>
</div>

@* Add Corporate Dialog *@
@if (_showAddCorporateDialog)
{
    <div class="fixed inset-0 flex items-start justify-center z-[100]" style="background: rgba(0,0,0,0.4); padding: 70px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl flex flex-col" style="max-height: 90vh;">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">Add Corporate</span>
                </div>
                <button @onclick="() => _showAddCorporateDialog = false"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Scrollable Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Corporate Name</label>
                        <input type="text" @bind="_addCorpName"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1"
                               style="focus:ring-color:#C9A84C;" placeholder="Enter corporate name" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Contact Number</label>
                        <input type="text" @bind="_addCorpContactNumber"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="e.g. +974 4446 0000" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Email Address</label>
                        <input type="email" @bind="_addCorpEmailAddress"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="e.g. info@company.com" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Membership Tier</label>
                        <select @bind="_addCorpMembershipTier" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs">
                            <option value="">Select Tier</option>
                            <option value="EXCLUSIVE">EXCLUSIVE</option>
                            <option value="EXCLUSIVE OMAN">EXCLUSIVE OMAN</option>
                            <option value="EXCLUSIVE - VIP">EXCLUSIVE - VIP</option>
                            <option value="BRONZE">BRONZE</option>
                            <option value="SILVER">SILVER</option>
                            <option value="GOLD">GOLD</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">VIP Count</label>
                        <input type="number" @bind="_addCorpVipCount"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="0" />
                    </div>
                    <div></div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Date Start</label>
                        <input type="date" @bind="_addCorpDateStart"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 mb-1">Date End</label>
                        <input type="date" @bind="_addCorpDateEnd"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Address</label>
                    <textarea @bind="_addCorpAddress" rows="2"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs resize-none" placeholder="Enter full address"></textarea>
                </div>

                <div class="flex justify-end gap-2 pt-2">
                    <button @onclick="() => _showAddCorporateDialog = false" class="px-4 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 font-medium">Cancel</button>
                    <button @onclick="AddCorporate" class="px-5 py-2 text-xs rounded-lg text-white font-medium border-none cursor-pointer" style="background:#C9A84C;">Add Corporate</button>
                </div>

            </div>
        </div>
    </div>
}

