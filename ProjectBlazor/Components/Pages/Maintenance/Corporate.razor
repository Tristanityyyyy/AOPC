@page "/maintenance/corporate"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Corporate Maintenance</h3>

<div class="grid grid-cols-12 gap-4">

    <div class="col-span-12">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="max-height:920px;">
            @* Dark header *@
            <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <h4 class="text-sm font-medium text-white">Corporate Maintenance</h4>
            </div>

            @* Row 1: entries per page | toolbar right *@
            <div class="flex items-center justify-between mb-4 px-1">

                @* Left: entries per page *@
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select value="@_corpPageSize" @onchange="e => { _corpPageSize = int.Parse(e.Value.ToString()); _corpPage = 1; }"
                            class="border border-gray-300 rounded px-2 py-1 text-xs">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span>entries per page</span>
                </div>

                @* Right: toolbar *@
                <div class="flex items-center gap-2">

                    @* Hidden real file input *@
                    <InputFile id="excelFileInput" OnChange="HandleFileUpload" accept=".xlsx,.xls" class="hidden" />

                    @* Styled label that triggers it *@
                    <label for="excelFileInput"
                           class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-300 bg-white text-xs text-gray-600 cursor-pointer hover:bg-gray-50 transition">
                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" Style="font-size:13px;" />
                        @(_uploadedFileName ?? "Choose File")
                    </label>

                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium transition"
                            style="background:#C9A84C;">
                        <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" />
                        Upload
                    </button>

                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-600 hover:bg-gray-50 transition">
                        <MudIcon Icon="@Icons.Material.Filled.Download" Style="font-size:13px;" />
                        Download Template
                    </button>

                    @* Divider *@
                    <div class="w-px h-4 bg-gray-300 mx-1"></div>

                    @* Search *@
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <span class="font-medium">Search:</span>
                        <input type="text" @bind="_corpSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                               placeholder="Type to search..." />
                    </div>

                </div>
            </div>

            @* Row 2: Add New — stands alone, left aligned *@
            <div class="mb-4 px-1">
                <button class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                        style="background: #C9A84C;">
                    + Add New
                </button>
            </div>

            @* Table *@
            <div class="overflow-auto">
                <table class="w-full text-xs">
                    <thead style="position:sticky; top:0; background:white; z-index:1;">
                        <tr class="border-b-2 border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("Name")'>
                                Name <span class="text-gray-400">@CorpSortIcon("Name")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("Address")'>
                                Address <span class="text-gray-400">@CorpSortIcon("Address")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("ContactNumber")'>
                                Contact Number <span class="text-gray-400">@CorpSortIcon("ContactNumber")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("EmailAddress")'>
                                Email Address <span class="text-gray-400">@CorpSortIcon("EmailAddress")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("MembershipTier")'>
                                Membership Tier <span class="text-gray-400">@CorpSortIcon("MembershipTier")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("UserCount")'>
                                User Count <span class="text-gray-400">@CorpSortIcon("UserCount")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("VipCount")'>
                                VIP Count <span class="text-gray-400">@CorpSortIcon("VipCount")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortCorp("MembershipDescription")'>
                                Membership Description <span class="text-gray-400">@CorpSortIcon("MembershipDescription")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredCorpItems)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2">
                                    <div class="font-medium text-gray-800">@item.Name</div>
                                    <div class="flex gap-2 mt-1">
                                        <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent"
                                                style="color: #C9A84C;">
                                            ✎ Edit
                                        </button>
                                        <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                            🗑 Delete
                                        </button>
                                        <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                                            👁 View
                                        </button>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-gray-600">@item.Address</td>
                                <td class="py-2 px-2 text-gray-600">@item.ContactNumber</td>
                                <td class="py-2 px-2 text-gray-600">@item.EmailAddress</td>
                                <td class="py-2 px-2 text-gray-600">@item.MembershipTier</td>
                                <td class="py-2 px-2 text-gray-600">@item.UserCount</td>
                                <td class="py-2 px-2 text-gray-600">@item.VipCount</td>
                                <td class="py-2 px-2 text-gray-600">@item.MembershipDescription</td>
                            </tr>
                        }
                      
                    </tbody>
                </table>
            </div>

            @* Footer *@
            <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                <span class="text-xs text-gray-500">
                    Showing @CorpFrom to @CorpTo of @_corpItems.Count entries
                </span>
                <div class="flex items-center gap-1">
                    @RenderPagination(_corpPage, CorpTotalPages, (p) => _corpPage = p)
                </div>
            </div>

        </div>
    </div>

</div>

@code {

    private string? _uploadedFileName;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _uploadedFileName = e.File.Name;
        await Task.CompletedTask;
    }

    private RenderFragment RenderPagination(int currentPage, int totalPages, Action<int> setPage) => __builder =>
    {
        var pages = new List<int?>();
        for (int i = 1; i <= totalPages; i++)
        {
            if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                pages.Add(i);
            else if (pages.Last() != null)
                pages.Add(null);
        }

        <button disabled="@(currentPage == 1)" @onclick="@(() => setPage(1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            «
        </button>
        <button disabled="@(currentPage == 1)" @onclick="@(() => setPage(currentPage - 1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            ‹
        </button>

        @foreach (var p in pages.Distinct())
        {
            if (p == null)
            {
                <span class="px-1 text-xs text-gray-400">…</span>
            }
            else
            {
                var pg = p.Value;
                <button @onclick="@(() => setPage(pg))"
                        class="@($"px-2 py-0.5 text-xs border rounded {(pg == currentPage ? "text-white border-transparent" : "border-gray-300 hover:bg-gray-100")}")"
                        style="@(pg == currentPage ? "background:#C9A84C;" : "")">
                    @pg
                </button>
            }
        }

        <button disabled="@(currentPage == totalPages)" @onclick="@(() => setPage(currentPage + 1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            ›
        </button>
        <button disabled="@(currentPage == totalPages)" @onclick="@(() => setPage(totalPages))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            »
        </button>
    };

    private string _corpSearch = "";
    private int _corpPageSize = 10;
    private int _corpPage = 1;
    private string _corpSortCol = "Name";
    private bool _corpSortAsc = true;

    private void SortCorp(string col)
    {
        if (_corpSortCol == col) _corpSortAsc = !_corpSortAsc;
        else { _corpSortCol = col; _corpSortAsc = true; }
        _corpPage = 1;
    }
    private string CorpSortIcon(string col) => _corpSortCol == col ? (_corpSortAsc ? "↑" : "↓") : "⇅";

    private List<CorporateItem> _corpItems = new()
    {
        new("Corp Oman",           "Oman",                                                                          "44408591",      "ccaspc@alfardan.com.qa",    "EXCLUSIVE OMAN",  10000, 5,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("ABC Corp",            "Doha",                                                                          "12345678",      "test@testing.com",          "EXCLUSIVE",       1000,  1,   "EXCLUSIVE MEMBERSHIP"),
        new("OMAN TECH IN...",     "Al Fardan Heights Building, Muscat, Al Maardh St, 6th Floor",                  "+968 91738184", "hto-pod@htoman.com",        "EXCLUSIVE OMAN",  10000, 0,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("Al Massila Techn...", "AL Fardan Hights Ghala, 2nd Floor, office 225",                                "79066600",      "malek.haj@metco.net",       "EXCLUSIVE OMAN",  10000, 0,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("Ibrahim Jaidah ...",  "Finaa Alfardan Building, First Floor, Office # 5-18, Muscat, Sultanate of Oman","+968 2411 7030","tenders@ibrahimjaidah.com", "EXCLUSIVE OMAN",  10000, 0,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("Korea Trade Con...",  "Final Al Fardhan, Azaiba",                                                     "24117011/12",   "muscat@kotra.or.kr",        "EXCLUSIVE OMAN",  10000, 0,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("Alfardan Proper...",  "Doha, Qatar",                                                                   "33297781",      "app@alfardan.com.qa",       "EXCLUSIVE",       100,   100, "EXCLUSIVE MEMBERSHIP"),
        new("Odecci",              "0004 Miranda street, Manatal, Pandi, Bulacan 3014",                            "+639163626853", "info@odecci.com",           "EXCLUSIVE - VIP", 10,    10,  "TOP LEVEL EXECUTIVES"),
        new("Workinton Qatar",     "Grand Hamad Street",                                                            "44408572",      "kmcrgcn@workinton.com.qa",  "BRONZE",          100,   100, "BRONZE MEMBERSHIP"),
        new("Fadaat Media",        "P.O.Box 11591, Doha, Qatar",                                                   "40310500",      "info@fadaatmedia.com",      "EXCLUSIVE",       1000,  24,  "EXCLUSIVE MEMBERSHIP"),
        new("Gulf Corp",           "West Bay, Doha",                                                                "44501234",      "info@gulfcorp.qa",          "EXCLUSIVE OMAN",  500,   5,   "EXCLUSIVE MEMBERSHIP OMAN"),
        new("Pearl Ventures",      "The Pearl, Doha, Qatar",                                                        "40312000",      "contact@pearlventures.qa",  "EXCLUSIVE",       200,   20,  "EXCLUSIVE MEMBERSHIP"),
    };

    private IEnumerable<CorporateItem> FilteredCorpItems =>
        SortCorpItems(_corpItems.Where(x => string.IsNullOrEmpty(_corpSearch) ||
            x.Name.Contains(_corpSearch, StringComparison.OrdinalIgnoreCase) ||
            x.Address.Contains(_corpSearch, StringComparison.OrdinalIgnoreCase) ||
            x.EmailAddress.Contains(_corpSearch, StringComparison.OrdinalIgnoreCase) ||
            x.MembershipTier.Contains(_corpSearch, StringComparison.OrdinalIgnoreCase)))
        .Skip((_corpPage - 1) * _corpPageSize).Take(_corpPageSize);

    private IEnumerable<CorporateItem> SortCorpItems(IEnumerable<CorporateItem> items) =>
        (_corpSortCol, _corpSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Address", true) => items.OrderBy(x => x.Address),
            ("Address", false) => items.OrderByDescending(x => x.Address),
            ("ContactNumber", true) => items.OrderBy(x => x.ContactNumber),
            ("ContactNumber", false) => items.OrderByDescending(x => x.ContactNumber),
            ("EmailAddress", true) => items.OrderBy(x => x.EmailAddress),
            ("EmailAddress", false) => items.OrderByDescending(x => x.EmailAddress),
            ("MembershipTier", true) => items.OrderBy(x => x.MembershipTier),
            ("MembershipTier", false) => items.OrderByDescending(x => x.MembershipTier),
            ("UserCount", true) => items.OrderBy(x => x.UserCount),
            ("UserCount", false) => items.OrderByDescending(x => x.UserCount),
            ("VipCount", true) => items.OrderBy(x => x.VipCount),
            ("VipCount", false) => items.OrderByDescending(x => x.VipCount),
            ("MembershipDescription", true) => items.OrderBy(x => x.MembershipDescription),
            ("MembershipDescription", false) => items.OrderByDescending(x => x.MembershipDescription),
            _ => items
        };

    private int CorpTotalPages => (int)Math.Ceiling(_corpItems.Count / (double)_corpPageSize);
    private int CorpFrom => (_corpPage - 1) * _corpPageSize + 1;
    private int CorpTo => Math.Min(_corpPage * _corpPageSize, _corpItems.Count);

    public record CorporateItem(
        string Name, string Address, string ContactNumber, string EmailAddress,
        string MembershipTier, int UserCount, int VipCount, string MembershipDescription);
}