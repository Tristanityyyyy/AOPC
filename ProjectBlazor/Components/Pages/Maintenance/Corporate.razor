@code {
    private List<TableColumn<CorporateItem>> _corpColumns = new();

    protected override void OnInitialized()
    {
        _corpColumns = new List<TableColumn<CorporateItem>>
        {
            new() {
                Header = "Name", Width = "20%", SortField = "Name",
                RenderCell = item => __builder => {
                    <div class="relative w-full" style="height:64px;">
                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:8px;">@item.Code</div>
                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 group-hover:translate-y-2" style="top:16px;">@item.Name</div>
                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 group-hover:translate-y-2" style="top:36px;">
                            <button @onclick="() => OpenEditCorporate(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:14px;" Color="Color.Inherit" /> Edit
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:14px;" Color="Color.Inherit" /> Delete
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size:14px;" Color="Color.Inherit" /> View
                            </button>
                        </div>
                    </div>
                    ;
                }
            },
            new() {
                Header = "Address", Width = "20%", SortField = "Address",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Address</span>; }
            },
            new() {
                Header = "Contact Number", Width = "10%", SortField = "ContactNumber",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.ContactNumber</span>; }
            },
            new() {
                Header = "Email Address", Width = "12%", SortField = "EmailAddress",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.EmailAddress</span>; }
            },
            new() {
                Header = "Membership Tier", Width = "8%", SortField = "MembershipTier",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.MembershipTier</span>; }
            },
            new() {
                Header = "User Count", Width = "8%", SortField = "UserCount",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.UserCount</span>; }
            },
            new() {
                Header = "VIP Count", Width = "7%", SortField = "VipCount",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.VipCount</span>; }
            },
            new() {
                Header = "Membership Description", Width = "15%", SortField = "MembershipDescription",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.MembershipDescription</span>; }
            },
            new() {
                Header = "Date Created", Width = "10%", SortField = "DateCreated",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.DateCreated</span>; }
            }
        };
    }

    private string? _uploadedFileName;

    private async Task HandleFileUpload(string fileName)
    {
        _uploadedFileName = fileName;
        await Task.CompletedTask;
    }

    private Task HandleImportClick()
    {
        return Task.CompletedTask;
    }

    private Task HandleExportTemplate()
    {
        return Task.CompletedTask;
    }

    // ── Add Corporate State ──
    private bool _showAddCorporateDialog = false;
    private string _addCorpName = "";
    private string _addCorpAddress = "";
    private string _addCorpContactNumber = "";
    private string _addCorpEmailAddress = "";
    private string _addCorpMembershipTier = "";
    private int _addCorpVipCount = 0;
    private DateTime _addCorpDateStart = DateTime.Today;
    private DateTime _addCorpDateEnd = DateTime.Today.AddYears(1);

    // ── Edit Corporate State ──
    private bool _showEditCorporateDialog = false;
    private CorporateItem? _editingCorporate;
    private string _editCorpCode = "";
    private string _editCorpName = "";
    private string _editCorpAddress = "";
    private string _editCorpContactNumber = "";
    private string _editCorpEmailAddress = "";
    private string _editCorpMembershipTier = "";
    private int _editCorpUserCount = 0;
    private int _editCorpVipCount = 0;
    private string _editCorpMembershipDescription = "";
    private string _editCorpDateCreated = "";
    private DateTime _editCorpDateStart = DateTime.Today;
    private DateTime _editCorpDateEnd = DateTime.Today.AddYears(1);

    private void OpenEditCorporate(CorporateItem item)
    {
        _editingCorporate = item;
        _editCorpCode = item.Code;
        _editCorpName = item.Name;
        _editCorpAddress = item.Address;
        _editCorpContactNumber = item.ContactNumber;
        _editCorpEmailAddress = item.EmailAddress;
        _editCorpMembershipTier = item.MembershipTier;
        _editCorpUserCount = item.UserCount;
        _editCorpVipCount = item.VipCount;
        _editCorpMembershipDescription = item.MembershipDescription;
        _editCorpDateCreated = item.DateCreated;
        DateTime.TryParse(item.DateStart, out var ds);
        DateTime.TryParse(item.DateEnd, out var de);
        _editCorpDateStart = ds == default ? DateTime.Today : ds;
        _editCorpDateEnd = de == default ? DateTime.Today.AddYears(1) : de;
        _showEditCorporateDialog = true;
    }

    private void CancelEditCorporate()
    {
        _showEditCorporateDialog = false;
        _editingCorporate = null;
    }

    private void SaveEditCorporate()
    {
        if (_editingCorporate == null) return;

        var index = _corpItems.IndexOf(_editingCorporate);
        if (index >= 0)
        {
            _corpItems[index] = new CorporateItem(
                _editCorpCode,
                _editCorpName,
                _editCorpAddress,
                _editCorpContactNumber,
                _editCorpEmailAddress,
                _editCorpMembershipTier,
                _editCorpUserCount,
                _editCorpVipCount,
                _editCorpMembershipDescription,
                _editCorpDateCreated,
                _editCorpDateStart.ToString("yyyy-MM-dd"),
                _editCorpDateEnd.ToString("yyyy-MM-dd")
            );
        }
        _showEditCorporateDialog = false;
        _editingCorporate = null;
    }

    private void OpenAddCorporate()
    {
        _addCorpName = "";
        _addCorpAddress = "";
        _addCorpContactNumber = "";
        _addCorpEmailAddress = "";
        _addCorpMembershipTier = "";
        _addCorpVipCount = 0;
        _addCorpDateStart = DateTime.Today;
        _addCorpDateEnd = DateTime.Today.AddYears(1);
        _showAddCorporateDialog = true;
    }

    private void AddCorporate()
    {
        var newCorp = new CorporateItem(
            $"CM-{(_corpItems.Count + 1):D3}",
            _addCorpName,
            _addCorpAddress,
            _addCorpContactNumber,
            _addCorpEmailAddress,
            _addCorpMembershipTier,
            0,
            _addCorpVipCount,
            $"{_addCorpMembershipTier} MEMBERSHIP",
            DateTime.Now.ToString("MM/dd/yyyy"),
            _addCorpDateStart.ToString("yyyy-MM-dd"),
            _addCorpDateEnd.ToString("yyyy-MM-dd")
        );
        _corpItems.Insert(0, newCorp);
        _showAddCorporateDialog = false;
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _uploadedFileName = e.File.Name;
        await Task.CompletedTask;
    }

