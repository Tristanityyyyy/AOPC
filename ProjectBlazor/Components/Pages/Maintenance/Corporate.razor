@page "/maintenance/corporate"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Corporate Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <DataTable T="CorporateItem"
                   Title="Corporate Maintenance"
                   Items="_corpItems"
                   Columns="_corpColumns"
                   ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                   ShowImportExport="true"
                   ImportedFileName="@_uploadedFileName"
                   OnAddClick="OpenAddCorporate"
                   OnImport="HandleFileUpload"
                   OnImportButtonClick="HandleImportClick"
                   OnExportTemplateClick="HandleExportTemplate" />
    </div>
</div>

@* Add Corporate Dialog *@
@if (_showAddCorporateDialog)
{
    <DialogModal IsVisible="_showAddCorporateDialog"
                 Title="Add Corporate"
                 Icon="@Icons.Material.Filled.Business"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="() => _showAddCorporateDialog = false">
        <ChildContent>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Corporate Name</label>
                    <input type="text" @bind="_addCorpName"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1"
                           style="focus:ring-color:@ThemeConfig.Colors.Primary;" placeholder="Enter corporate name" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Contact Number</label>
                    <input type="text" @bind="_addCorpContactNumber"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="e.g. +974 4446 0000" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Email Address</label>
                    <input type="email" @bind="_addCorpEmailAddress"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="e.g. info@company.com" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Membership Tier</label>
                    <select @bind="_addCorpMembershipTier" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs">
                        <option value="">Select Tier</option>
                        <option value="EXCLUSIVE">EXCLUSIVE</option>
                        <option value="EXCLUSIVE OMAN">EXCLUSIVE OMAN</option>
                        <option value="EXCLUSIVE - VIP">EXCLUSIVE - VIP</option>
                        <option value="BRONZE">BRONZE</option>
                        <option value="SILVER">SILVER</option>
                        <option value="GOLD">GOLD</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">VIP Count</label>
                    <input type="number" @bind="_addCorpVipCount"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="0" />
                </div>
                <div></div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Date Start</label>
                    <input type="date" @bind="_addCorpDateStart"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Date End</label>
                    <input type="date" @bind="_addCorpDateEnd"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Address</label>
                <textarea @bind="_addCorpAddress" rows="2"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs resize-none" placeholder="Enter full address"></textarea>
            </div>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Add Corporate"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => _showAddCorporateDialog = false"
                          OnConfirm="AddCorporate" />
        </FooterContent>
    </DialogModal>
}

