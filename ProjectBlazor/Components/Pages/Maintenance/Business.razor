    private async Task HandleTypeImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var buffer = new byte[file.Size];
        using var stream = file.OpenReadStream();
        await stream.ReadAsync(buffer);
        _editImageUrl = $"data:image/*;base64,{Convert.ToBase64String(buffer)}";
    }
    private async Task HandleAddTypeImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
