@page "/maintenance/business"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Business</h3>

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "locations"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "locations" ? $"border-color:{ThemeConfig.Colors.Primary}; color:{ThemeConfig.Colors.Primary};" : $"border-color:transparent; color:{ThemeConfig.Colors.Text.Secondary};")">
        Business Locations
    </button>
    <button @onclick='() => _activeTab = "types"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "types" ? $"border-color:{ThemeConfig.Colors.Primary}; color:{ThemeConfig.Colors.Primary};" : $"border-color:transparent; color:{ThemeConfig.Colors.Text.Secondary};")">
        Business Types
    </button>
    <button @onclick='() => _activeTab = "hotels"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "hotels" ? $"border-color:{ThemeConfig.Colors.Primary}; color:{ThemeConfig.Colors.Primary};" : $"border-color:transparent; color:{ThemeConfig.Colors.Text.Secondary};")">
        Hotels
    </button>
</div>

<div class="grid grid-cols-12 gap-4">

    @* ── Business Locations ── *@
    @if (_activeTab == "locations")
    {
        <div class="col-span-12">
            <DataTable T="LocationItem"
                       Title="Business Locations"
                       Items="_locItems"
                       Columns="_locColumns"
                       ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                       HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                       OnAddClick="OpenAddLocation" />
        </div>
    }

    @* ── Business Types ── *@
    @if (_activeTab == "types")
    {
        <div class="col-span-12">
            <DataTable T="BusinessTypeItem"
                       Title="Business Types"
                       Items="_typeItems"
                       Columns="_typeColumns"
                       ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                       HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                       OnAddClick="OpenAddType" />
        </div>
    }

    @* ── Hotels ── *@
    @if (_activeTab == "hotels")
    {
        <div class="col-span-12">
            <DataTable T="HotelItem"
                       Title="Hotels"
                       Items="_hotelItems"
                       Columns="_hotelColumns"
                       ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                       OnAddClick="OpenAddHotel" />
        </div>
    }

</div>

@* ── Edit Location Dialog ── *@
@if (_showEditLocationDialog)
{
    @* ── Edit Location Dialog ── *@
    <DialogModal IsVisible="_showEditLocationDialog"
                 Title="Edit Business Location"
                 Icon="@Icons.Material.Filled.LocationOn"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 CenterVertically="true"
                 OnClose="CancelEditLocation">
        <ChildContent>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Name</label>
                <input type="text" @bind="_editName"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Postal Code</label>
                <input type="text" @bind="_editPostalCode"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Country</label>
                <input type="text" @bind="_editCountry"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none" />
            </div>
        </ChildContent>
        <FooterContent>
            <button @onclick="CancelEditLocation"
                    class="px-4 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 font-medium">
                Cancel
            </button>
            <button @onclick="SaveEditLocation"
                    class="px-4 py-2 text-xs rounded-lg text-white font-medium"
                    style="@ThemeConfig.Styles.ButtonPrimary">
                Save Changes
            </button>
        </FooterContent>
    </DialogModal>
}

@* ── Add Location Dialog ── *@
@if (_showAddLocationDialog)
{
    <DialogModal IsVisible="_showAddLocationDialog"
                 Title="Add Business Location"
                 Icon="@Icons.Material.Filled.AddLocation"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 CenterVertically="true"
                 OnClose="() => _showAddLocationDialog = false">

        <ChildContent>
            <div class="flex flex-col gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Name</label>
                    <input type="text" @bind="_addName"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs"
                           placeholder="Enter location name" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Postal Code</label>
                    <input type="text" @bind="_addPostalCode"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs"
                           placeholder="Enter postal code" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Country</label>
                    <input type="text" @bind="_addCountry"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs"
                           placeholder="Enter country" />
                </div>
            </div>
        </ChildContent>

        <FooterContent>
            <DialogFooter ConfirmText="Add Location"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => _showAddLocationDialog = false"
                          OnConfirm="AddLocation" />
        </FooterContent>

    </DialogModal>
}

@* ── Edit Business Type Dialog ── *@
@if (_showEditTypeDialog)
{
    <DialogModal IsVisible="_showEditTypeDialog"
                 Title="Edit Business Type"
                 Icon="@Icons.Material.Filled.Category"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="CancelEditType">

        <ChildContent>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Profile Picture</label>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-lg overflow-hidden border border-gray-200 bg-gray-100 flex items-center justify-center">
                        @if (!string.IsNullOrEmpty(_editImageUrl) && !_editImageUrl.StartsWith("/images"))
                        {
                            <img src="@_editImageUrl" class="w-full h-full object-cover" alt="Profile" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Business"
                                     Style="@($"font-size:28px; color:{ThemeConfig.Colors.Text.Muted};")" />
                        }
                    </div>
                    <div>
                        <InputFile id="typeImageInput" OnChange="HandleTypeImageUpload" accept="image/*" class="hidden" />
                        <label for="typeImageInput" class="flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-lg border border-gray-300 cursor-pointer hover:bg-gray-50 transition text-gray-600">
                            <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" /> Upload New Photo
                        </label>
                        <p class="text-xs text-gray-400 mt-1">JPG, PNG up to 5MB</p>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Business Type Name</label>
                <input type="text" @bind="_editTypeName"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none" />
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Description</label>
                <textarea @bind="_editTypeDescription"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none"
                          rows="3"></textarea>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-2">Promo</label>
                <input type="text" @bind="_editTypePromo"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none" />
            </div>
        </ChildContent>

        <FooterContent>
            <button @onclick="CancelEditType"
                    class="px-4 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 font-medium">
                Cancel
            </button>
            <button @onclick="SaveEditType"
                    class="px-4 py-2 text-xs rounded-lg text-white font-medium"
                    style="@ThemeConfig.Styles.ButtonPrimary">
                Save Changes
            </button>
        </FooterContent>

    </DialogModal>
}

