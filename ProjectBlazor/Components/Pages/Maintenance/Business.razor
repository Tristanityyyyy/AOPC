    public record HotelItem(string Code, string Name, string ImageUrl, string Location, string Address, string ContactNo, string Email, string Url, string Description, string DateCreated);

    private void OpenAddHotel() { _addHotelImageUrl = ""; _addHotelImages = new(); _addHotelName = ""; _addHotelLocation = ""; _addHotelAddress = ""; _addHotelContactNo = ""; _addHotelEmail = ""; _addHotelUrl = ""; _addHotelDescription = ""; _addHotelServices = ""; _addHotelMap = ""; _showAddHotelDialog = true; }
    private void AddHotel()
    {
        _hotelItems.Insert(0, new HotelItem($"HTL-{_hotelItems.Count + 1:D3}", _addHotelName, _addHotelImageUrl, _addHotelLocation, _addHotelAddress, _addHotelContactNo, _addHotelEmail, _addHotelUrl, _addHotelDescription, DateTime.Now.ToString("MM/dd/yyyy")));
        _showAddHotelDialog = false;
    }
    private void OpenEditHotel(HotelItem item) { _editingHotel = item; _editHotelImageUrl = item.ImageUrl; _editHotelImages = new List<string> { item.ImageUrl }; _editHotelName = item.Name; _editHotelLocation = item.Location; _editHotelAddress = item.Address; _editHotelContactNo = item.ContactNo; _editHotelEmail = item.Email; _editHotelUrl = item.Url; _editHotelDescription = item.Description; _editHotelServices = ""; _editHotelMap = ""; _showEditHotelDialog = true; }
    private void SaveEditHotel()
    {
        if (_editingHotel != null)
        {
            var i = _hotelItems.FindIndex(x => x.Code == _editingHotel.Code);
            if (i >= 0) _hotelItems[i] = new HotelItem(_editingHotel.Code, _editHotelName, _editHotelImageUrl, _editHotelLocation, _editHotelAddress, _editHotelContactNo, _editHotelEmail, _editHotelUrl, _editHotelDescription, _editingHotel.DateCreated);
        }
        _showEditHotelDialog = false;
    }
    private void CancelEditHotel() => _showEditHotelDialog = false;

    private async Task HandleHotelImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var buffer = new byte[file.Size];
        using var stream = file.OpenReadStream();
        await stream.ReadAsync(buffer);
        _editHotelImageUrl = $"data:image/*;base64,{Convert.ToBase64String(buffer)}";
    }
    private async Task HandleHotelImagesUpload(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var buffer = new byte[file.Size];
            using var stream = file.OpenReadStream();
            await stream.ReadAsync(buffer);
            _editHotelImages.Add($"data:image/*;base64,{Convert.ToBase64String(buffer)}");
        }
    }
    private async Task HandleAddHotelImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var buffer = new byte[file.Size];
        using var stream = file.OpenReadStream();
        await stream.ReadAsync(buffer);
        _addHotelImageUrl = $"data:image/*;base64,{Convert.ToBase64String(buffer)}";
    }
    private async Task HandleAddHotelImagesUpload(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var buffer = new byte[file.Size];
            using var stream = file.OpenReadStream();
            await stream.ReadAsync(buffer);
            _addHotelImages.Add($"data:image/*;base64,{Convert.ToBase64String(buffer)}");
        }
    }
