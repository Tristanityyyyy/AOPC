<DialogModal IsVisible="_showEditHotelDialog"
             Title="Edit Hotel"
             Icon="@Icons.Material.Filled.Hotel"
             HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
             MaxWidth="2xl"
             OnClose="CancelEditHotel">
    <ChildContent>
        <div>
            <label class="block text-xs font-semibold text-gray-700 mb-2">Profile Picture</label>
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-lg overflow-hidden border border-gray-200 bg-gray-100 flex items-center justify-center">
                    @if (!string.IsNullOrEmpty(_editHotelImageUrl) && !_editHotelImageUrl.StartsWith("/images"))
                    {
                        <img src="@_editHotelImageUrl" class="w-full h-full object-cover" alt="Profile" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Hotel"
                                 Style="@($"font-size:28px; color:{ThemeConfig.Colors.Text.Muted};")" />
                    }
                </div>
                <div>
                    <InputFile id="hotelImageInput" OnChange="HandleHotelImageUpload" accept="image/*" class="hidden" />
                    <label for="hotelImageInput" class="flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-lg border border-gray-300 cursor-pointer hover:bg-gray-50 transition text-gray-600">
                        <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" /> Upload New Photo
                    </label>
                    <p class="text-xs text-gray-400 mt-1">JPG, PNG up to 5MB</p>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-700 mb-2">Hotel Images (Multiple)</label>
            <div class="flex flex-wrap gap-2">
                @foreach (var img in _editHotelImages)
                {
                    var imgCopy = img;
                    <div class="relative w-16 h-16">
                        <div class="w-16 h-16 rounded-lg overflow-hidden border border-gray-200 bg-gray-100">
                            @if (!img.StartsWith("/images"))
                            {
                                <img src="@img" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Image"
                                             Style="@($"font-size:24px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                </div>
                            }
                        </div>
                        <button @onclick="() => _editHotelImages.Remove(imgCopy)"
                                class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-red-500 text-white text-xs flex items-center justify-center border-none cursor-pointer">
                            ×
                        </button>
                    </div>
                }
                <InputFile id="hotelImagesInput" OnChange="HandleHotelImagesUpload" accept="image/*" multiple class="hidden" />
                <label for="hotelImagesInput" class="w-16 h-16 rounded-lg border-2 border-dashed border-gray-300 flex flex-col items-center justify-center text-gray-400 cursor-pointer hover:bg-gray-50 transition">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size:20px;" />
                </label>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Hotel Name</label>
                <input type="text" @bind="_editHotelName" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Business Location</label>
                <select @bind="_editHotelLocation" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs">
                    <option value="">Select Location</option>
                    @foreach (var loc in _locItems)
                    {
                        <option value="@loc.Name">@loc.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Contact Number</label>
                <input type="text" @bind="_editHotelContactNo" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Email</label>
                <input type="email" @bind="_editHotelEmail" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Website URL</label>
                <input type="text" @bind="_editHotelUrl" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Services</label>
                <input type="text" @bind="_editHotelServices" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="e.g. WiFi, Pool, Spa" />
            </div>
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Address</label>
            <textarea @bind="_editHotelAddress" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs resize-none"></textarea>
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Description</label>
            <textarea @bind="_editHotelDescription" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs resize-none"></textarea>
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Map (Embed URL or Address)</label>
            <input type="text" @bind="_editHotelMap" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs" placeholder="Google Maps embed URL or address" />
        </div>
    </ChildContent>
    <FooterContent>
        <button @onclick="CancelEditHotel"
                class="px-5 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 transition">
            Cancel
        </button>
        <button @onclick="SaveEditHotel"
                class="px-5 py-2 text-xs rounded-lg text-white font-medium"
                style="@ThemeConfig.Styles.ButtonPrimary">
            Save Changes
        </button>
    </FooterContent>
</DialogModal>

