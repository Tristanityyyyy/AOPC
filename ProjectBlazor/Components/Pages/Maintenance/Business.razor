@code {

    // ── PAGINATION RENDERER (shared) ──
    private RenderFragment RenderPagination(int currentPage, int totalPages, Action<int> setPage) => __builder =>
    {
        var pages = new List<int?>();
        for (int i = 1; i <= totalPages; i++)
        {
            if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                pages.Add(i);
            else if (pages.Last() != null)
                pages.Add(null);
        }

        <button disabled="@(currentPage == 1)" @onclick="@(() => setPage(1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            «
        </button>
        <button disabled="@(currentPage == 1)" @onclick="@(() => setPage(currentPage - 1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            ‹
        </button>

        @foreach (var p in pages.Distinct())
        {
            if (p == null)
            {
                <span class="px-1 text-xs text-gray-400">…</span>
            }
            else
            {
                var pg = p.Value;
                <button @onclick="@(() => setPage(pg))"
                        class="@($"px-2 py-0.5 text-xs border rounded {(pg == currentPage ? "text-white border-transparent" : "border-gray-300 hover:bg-gray-100")}")"
                        style="@(pg == currentPage ? "background:#C9A84C;" : "")">
                    @pg
                </button>
            }
        }

        <button disabled="@(currentPage == totalPages)" @onclick="@(() => setPage(currentPage + 1))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            ›
        </button>
        <button disabled="@(currentPage == totalPages)" @onclick="@(() => setPage(totalPages))"
                class="px-1.5 py-0.5 text-xs border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-40">
            »
        </button>
    };

    // ── BUSINESS LOCATIONS ──
    private string _locSearch = "";
    private int _locPageSize = 10;
    private int _locPage = 1;
    private string _locSortCol = "Name";
    private bool _locSortAsc = true;

    private void SortLoc(string col) { if (_locSortCol == col) _locSortAsc = !_locSortAsc; else { _locSortCol = col; _locSortAsc = true; } _locPage = 1; }
    private string LocSortIcon(string col) => _locSortCol == col ? (_locSortAsc ? "↑" : "↓") : "⇅";

    private List<LocationItem> _locItems = new()
    {
        new("Istanbul",         "0000",  "Turkey", "2025-09-29T15:57:32.45"),
        new("Lusail",           "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("Grand Hamad Seda Hotel", "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("The Pearl Island Oriental Philippines etc etc","26660","Qatar",  "2025-09-29T15:57:32.45"),
         new("Istanbul",         "0000",  "Turkey", "2025-09-29T15:57:32.45"),
        new("Lusail",           "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("Grand Hamad Seda Hotel", "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("The Pearl Island Oriental Philippines etc etc","26660","Qatar",  "2025-09-29T15:57:32.45"),
         new("Istanbul",         "0000",  "Turkey", "2025-09-29T15:57:32.45"),
        new("Lusail",           "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("Grand Hamad Seda Hotel", "26660", "Qatar",  "2025-09-29T15:57:32.45"),
        new("The Pearl Island Oriental Philippines etc etc","26660","Qatar",  "2025-09-29T15:57:32.45")
    };

    private IEnumerable<LocationItem> FilteredLocItems =>
        SortLocItems(_locItems.Where(x => string.IsNullOrEmpty(_locSearch) ||
            x.Name.Contains(_locSearch, StringComparison.OrdinalIgnoreCase)))
        .Skip((_locPage - 1) * _locPageSize).Take(_locPageSize);

    private IEnumerable<LocationItem> SortLocItems(IEnumerable<LocationItem> items) =>
        (_locSortCol, _locSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("PostalCode", true) => items.OrderBy(x => x.PostalCode),
            ("PostalCode", false) => items.OrderByDescending(x => x.PostalCode),
            ("Country", true) => items.OrderBy(x => x.Country),
            ("Country", false) => items.OrderByDescending(x => x.Country),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int LocTotalPages => (int)Math.Ceiling(_locItems.Count / (double)_locPageSize);
    private int LocFrom => (_locPage - 1) * _locPageSize + 1;
    private int LocTo => Math.Min(_locPage * _locPageSize, _locItems.Count);

    public record LocationItem(string Name, string PostalCode, string Country, string DateCreated);

    // ── BUSINESS TYPES ──
    private string _typeSearch = "";
    private int _typePageSize = 10;
    private int _typePage = 1;
    private string _typeSortCol = "Name";
    private bool _typeSortAsc = true;

    private void SortType(string col) { if (_typeSortCol == col) _typeSortAsc = !_typeSortAsc; else { _typeSortCol = col; _typeSortAsc = true; } _typePage = 1; }
    private string TypeSortIcon(string col) => _typeSortCol == col ? (_typeSortAsc ? "↑" : "↓") : "⇅";

    private List<BusinessTypeItem> _typeItems = new()
    {
        new("Health",           "/images/health.jpg",   "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
        new("Food & Beverages", "/images/food.jpg",    "Up to 30% preferred rates", "2025-07-08T17:17:46.02"),
        new("Access to co-workers","/images/cowork.jpg",  "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
         new("Health",           "/images/health.jpg",   "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
        new("Food & Beverages", "/images/food.jpg",    "Up to 30% preferred rates", "2025-07-08T17:17:46.02"),
        new("Access to co-workers","/images/cowork.jpg",  "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
         new("Health",           "/images/health.jpg",   "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
        new("Food & Beverages", "/images/food.jpg",    "Up to 30% preferred rates", "2025-07-08T17:17:46.02"),
        new("Access to co-workers","/images/cowork.jpg",  "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
         new("Health",           "/images/health.jpg",   "Up to 20% preferred rates", "2025-07-08T17:17:46.02"),
        new("Food & Beverages", "/images/food.jpg",    "Up to 30% preferred rates", "2025-07-08T17:17:46.02"),
        new("Access to co-workers","/images/cowork.jpg",  "Up to 20% preferred rates", "2025-07-08T17:17:46.02")
    };

    private IEnumerable<BusinessTypeItem> FilteredTypeItems =>
        SortTypeItems(_typeItems.Where(x => string.IsNullOrEmpty(_typeSearch) ||
            x.Name.Contains(_typeSearch, StringComparison.OrdinalIgnoreCase) ||
            x.Promo.Contains(_typeSearch, StringComparison.OrdinalIgnoreCase)))
        .Skip((_typePage - 1) * _typePageSize).Take(_typePageSize);

    private IEnumerable<BusinessTypeItem> SortTypeItems(IEnumerable<BusinessTypeItem> items) =>
        (_typeSortCol, _typeSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Promo", true) => items.OrderBy(x => x.Promo),
            ("Promo", false) => items.OrderByDescending(x => x.Promo),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int TypeTotalPages => (int)Math.Ceiling(_typeItems.Count / (double)_typePageSize);
    private int TypeFrom => (_typePage - 1) * _typePageSize + 1;
    private int TypeTo => Math.Min(_typePage * _typePageSize, _typeItems.Count);

    public record BusinessTypeItem(string Name, string ImageUrl, string Promo, string DateCreated);

