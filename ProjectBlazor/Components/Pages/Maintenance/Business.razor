@page "/maintenance/business"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Business</h3>

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "locations"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "locations" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        Business Locations
    </button>
    <button @onclick='() => _activeTab = "types"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "types" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        Business Types
    </button>
    <button @onclick='() => _activeTab = "hotels"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "hotels" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        Hotels
    </button>
</div>

<div class="grid grid-cols-12 gap-4">

    @* ── Business Locations ── *@
    @if (_activeTab == "locations")
    {
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height:750px;">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-3"
                     style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                    <h4 class="text-sm font-medium text-white">Business Locations</h4>
                </div>
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <select value="@_locPageSize" @onchange="e => { _locPageSize = int.Parse(e.Value.ToString()); _locPage = 1; }" class="border border-gray-300 rounded px-2 py-1 text-xs">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        entries per page
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        Search:
                        <input type="text" @bind="_locSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded px-2 py-1 text-xs w-36" />
                    </div>
                </div>
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddLocation"
                            class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: #C9A84C;">
                        + Add New
                    </button>
                </div>
                <div class="overflow-y-auto" style="max-height:560px;">
                    <table class="text-xs table-fixed" style="width: 100%;">
                        <thead style="position:sticky;top:0;background:white;z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 45%;" @onclick='() => SortLoc("Name")'>
                                    Name <span class="text-gray-400">@LocSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 20%;" @onclick='() => SortLoc("PostalCode")'>
                                    Postal Code <span class="text-gray-400">@LocSortIcon("PostalCode")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 20%;" @onclick='() => SortLoc("Country")'>
                                    Country <span class="text-gray-400">@LocSortIcon("Country")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 15%;" @onclick='() => SortLoc("DateCreated")'>
                                    Date Created <span class="text-gray-400">@LocSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredLocItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="px-2" style="height: 64px; overflow: hidden;">
                                        <div class="relative w-full" style="height: 64px;">
                                            <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 8px;">
                                                @item.Code
                                            </div>
                                            <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 16px;">
                                                @item.Name
                                            </div>
                                            <div class="absolute left-0 flex gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 36px;">
                                                <button @onclick="() => OpenEditLocation(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: #C9A84C;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                    Edit
                                                </button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                    Delete
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-2 text-gray-600" style="height: 64px; vertical-align: middle;">@item.PostalCode</td>
                                    <td class="px-2 text-gray-600" style="height: 64px; vertical-align: middle;">@item.Country</td>
                                    <td class="px-2 text-gray-600" style="height: 64px; vertical-align: middle;">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @LocFrom to @LocTo of @_locItems.Count entries</span>
                    <div class="flex items-center gap-1">@RenderPagination(_locPage, LocTotalPages, (p) => _locPage = p)</div>
                </div>
            </div>
        </div>
    }

    @* ── Business Types ── *@
    @if (_activeTab == "types")
    {
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height:750px;">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-3"
                     style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                    <h4 class="text-sm font-medium text-white">Business Types</h4>
                </div>
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <select value="@_typePageSize" @onchange="e => { _typePageSize = int.Parse(e.Value.ToString()); _typePage = 1; }" class="border border-gray-300 rounded px-2 py-1 text-xs">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        entries per page
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        Search:
                        <input type="text" @bind="_typeSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded px-2 py-1 text-xs w-36" />
                    </div>
                </div>
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddType"
                            class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: #C9A84C;">
                        + Add New
                    </button>
                </div>
                <div class="overflow-y-auto" style="max-height:560px;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky;top:0;background:white;z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 40%;" @onclick='() => SortType("Name")'>
                                    Name <span class="text-gray-400">@TypeSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 40%;" @onclick='() => SortType("Promo")'>
                                    Promo <span class="text-gray-400">@TypeSortIcon("Promo")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" style="width: 20%;" @onclick='() => SortType("DateCreated")'>
                                    Date Created <span class="text-gray-400">@TypeSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredTypeItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2">
                                        <div class="flex items-center gap-2">
                                            <img src="@item.ImageUrl" class="w-10 h-10 rounded object-cover" alt="@item.Name" />
                                            <div class="relative">
                                                <div class="text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 -mb-1">
                                                    @item.Code
                                                </div>
                                                <div class="font-medium text-gray-700 -mt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-2">
                                                    @item.Name
                                                </div>
                                                <div class="flex gap-2 mt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-2">
                                                    <button @onclick="() => OpenEditType(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: #C9A84C;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Edit
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Duplicate
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Delete
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600">@item.Promo</td>
                                    <td class="py-2 px-2 text-gray-600">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @TypeFrom to @TypeTo of @_typeItems.Count entries</span>
                    <div class="flex items-center gap-1">@RenderPagination(_typePage, TypeTotalPages, (p) => _typePage = p)</div>
                </div>
            </div>
        </div>
    }

    @* ── Hotels ── *@
    @if (_activeTab == "hotels")
    {
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height:750px;">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-3"
                     style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                    <h4 class="text-sm font-medium text-white">Hotels</h4>
                </div>
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <select value="@_hotelPageSize" @onchange="e => { _hotelPageSize = int.Parse(e.Value.ToString()); _hotelPage = 1; }" class="border border-gray-300 rounded px-2 py-1 text-xs">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        entries per page
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        Search:
                        <input type="text" @bind="_hotelSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded px-2 py-1 text-xs w-48" />
                    </div>
                </div>
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddHotel"
                            class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: #C9A84C;">
                        + Add New
                    </button>
                </div>
                <div class="overflow-y-auto" style="max-height:560px;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky;top:0;background:white;z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("Name")'>
                                    Name <span class="text-gray-400">@HotelSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("Location")'>
                                    Location <span class="text-gray-400">@HotelSortIcon("Location")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("Address")'>
                                    Address <span class="text-gray-400">@HotelSortIcon("Address")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("ContactNo")'>
                                    Contact No. <span class="text-gray-400">@HotelSortIcon("ContactNo")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("Email")'>
                                    Email <span class="text-gray-400">@HotelSortIcon("Email")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("Url")'>
                                    Url <span class="text-gray-400">@HotelSortIcon("Url")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none" @onclick='() => SortHotel("DateCreated")'>
                                    Date Created <span class="text-gray-400">@HotelSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredHotelItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2">
                                        <div class="flex items-center gap-2">
                                            <img src="@item.ImageUrl" class="w-10 h-10 rounded object-cover" alt="@item.Name" />
                                            <div class="relative">
                                                <div class="text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 -mb-1">
                                                    @item.Code
                                                </div>
                                                <div class="font-medium text-gray-700 -mt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-2">
                                                    @item.Name
                                                </div>
                                                <div class="flex gap-2 mt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-2">
                                                    <button @onclick="() => OpenEditHotel(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: #C9A84C;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Edit
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Delete
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.Location</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Address</td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.ContactNo</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600 max-w-xs truncate">@item.Url</td>
                                    <td class="py-2 px-2 text-gray-600">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @HotelFrom to @HotelTo of @_hotelItems.Count entries</span>
                    <div class="flex items-center gap-1">@RenderPagination(_hotelPage, HotelTotalPages, (p) => _hotelPage = p)</div>
                </div>
            </div>
        </div>
    }

</div>

@* Edit Location Dialog *@
@if (_showEditLocationDialog)
{
    <div class="fixed inset-0 flex items-center justify-center z-[100]" style="background: rgba(0,0,0,0.4);">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md flex flex-col">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">Edit Business Location</span>
                </div>
                <button @onclick="CancelEditLocation"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-4">
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Name</label>
                    <input type="text" @bind="_editName" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Postal Code</label>
                    <input type="text" @bind="_editPostalCode" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Country</label>
                    <input type="text" @bind="_editCountry" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" />
                </div>
                
                <div class="flex justify-end gap-2 pt-2">
                    <button @onclick="CancelEditLocation" class="px-4 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 font-medium">Cancel</button>
                    <button @onclick="SaveEditLocation" class="px-4 py-2 text-xs rounded-lg text-white font-medium" style="background: #C9A84C;">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@* Add Location Dialog *@
@if (_showAddLocationDialog)
{
    <div class="fixed inset-0 flex items-center justify-center z-[100]" style="background: rgba(0,0,0,0.4);">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md flex flex-col">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.AddLocation" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">Add Business Location</span>
                </div>
                <button @onclick="() => _showAddLocationDialog = false"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-4">
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Name</label>
                    <input type="text" @bind="_addName" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" placeholder="Enter location name" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Postal Code</label>
                    <input type="text" @bind="_addPostalCode" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" placeholder="Enter postal code" />
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-2">Country</label>
                    <input type="text" @bind="_addCountry" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-xs focus:outline-none focus:border-[#C9A84C] focus:ring-1 focus:ring-[#C9A84C]" placeholder="Enter country" />
                </div>
                
                <div class="flex justify-end gap-2 pt-2">
                    <button @onclick="() => _showAddLocationDialog = false" class="px-4 py-2 text-xs rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 font-medium">Cancel</button>
                    <button @onclick="AddLocation" class="px-4 py-2 text-xs rounded-lg text-white font-medium" style="background: #C9A84C;">Add Location</button>
                </div>
            </div>
        </div>
    </div>
}

@* Edit Business Type Dialog *@
@if (_showEditTypeDialog)
{
    <div class="fixed inset-0 flex items-start justify-center z-[100]" style="background: rgba(0,0,0,0.4); padding: 70px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md flex flex-col">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">Edit Business Type</span>
                </div>
                <button @onclick="CancelEditType"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
