@page "/maintenance/business"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Business</h3>

<div class="grid grid-cols-12 gap-4">

    @* ── Business Locations (left) ── *@
    <div class="col-span-6">
        <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4" style="height:750px;">

            @* Dark header *@
            <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-3"
                 style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                <h4 class="text-sm font-medium text-white">Business Locations</h4>
            </div>

            @* Controls *@
            <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    <select value="@_locPageSize" @onchange="e => { _locPageSize = int.Parse(e.Value.ToString()); _locPage = 1; }" class="border border-gray-300 rounded px-2 py-1 text-xs">

                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    entries per page
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-600">
                    Search:
                    <input type="text" @bind="_locSearch" @bind:event="oninput"
                           class="border border-gray-300 rounded px-2 py-1 text-xs w-36" />
                </div>
            </div>

            @* Table *@
            <div class="overflow-x-auto" style="min-height:320px;">

                <table class="w-full text-xs">
                    <thead style="position:sticky;top:0;background:white;z-index:1;">

                        @* Row 1: Add New button *@
                        <tr>
                            <td colspan="4" class="pb-2">
                                <button class="flex items-center gap-2 px-3 py-1.5 rounded-full text-white text-xs border-none cursor-pointer"
                                        style="background: #C9A84C;">
                                    + Add New
                                </button>
                            </td>
                        </tr>
                        @* Row 2: Sortable column headers *@
                        <tr class="border-b-2 border-gray-200">
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortLoc("Name")'>
                                Name <span class="text-gray-400">@LocSortIcon("Name")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortLoc("PostalCode")'>
                                Postal Code <span class="text-gray-400">@LocSortIcon("PostalCode")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortLoc("Country")'>
                                Country <span class="text-gray-400">@LocSortIcon("Country")</span>
                            </th>
                            <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                @onclick='() => SortLoc("DateCreated")'>
                                Date Created <span class="text-gray-400">@LocSortIcon("DateCreated")</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredLocItems)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2">
                                    <div class="font-medium text-gray-700">@item.Name</div>
                                    <div class="flex gap-2 mt-1">
                                        <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent"
                                                style="color: #C9A84C;">
                                            ✎ Edit
                                        </button>
                                        <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                            🗑 Delete
                                        </button>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-gray-600">@item.PostalCode</td>
                                <td class="py-2 px-2 text-gray-600">@item.Country</td>
                                <td class="py-2 px-2 text-gray-600">@item.DateCreated</td>
                            </tr>
                        }
                        @for (int i = FilteredLocItems.Count(); i < _locPageSize; i++)
                        {
                            <tr class="border-b border-gray-100">
                                <td class="py-2 px-2">&nbsp;</td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2"></td>
                                <td class="py-2 px-2"></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Footer *@
            <div class="flex items-center justify-between mt-3">
                <span class="text-xs text-gray-500">
                    Showing @LocFrom to @LocTo of @_locItems.Count entries
                </span>
                <div class="flex items-center gap-1">
                    @RenderPagination(_locPage, LocTotalPages, (p) => _locPage = p)
                </div>
            </div>
        </div>
    </div>

