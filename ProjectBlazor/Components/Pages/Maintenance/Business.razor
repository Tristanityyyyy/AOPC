    public record LocationItem(string Code, string Name, string PostalCode, string Country, string DateCreated);

    private void OpenAddLocation() { _addName = ""; _addPostalCode = ""; _addCountry = ""; _showAddLocationDialog = true; }
    private void AddLocation()
    {
        _locItems.Insert(0, new LocationItem($"LOC-{_locItems.Count + 1:D3}", _addName, _addPostalCode, _addCountry, DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")));
        _showAddLocationDialog = false;
    }

    private void OpenEditLocation(LocationItem item) { _editingLocation = item; _editName = item.Name; _editPostalCode = item.PostalCode; _editCountry = item.Country; _showEditLocationDialog = true; }
    private void SaveEditLocation()
    {
        if (_editingLocation != null)
        {
            var i = _locItems.FindIndex(x => x.Code == _editingLocation.Code);
            if (i >= 0) _locItems[i] = new LocationItem(_editingLocation.Code, _editName, _editPostalCode, _editCountry, _editingLocation.DateCreated);
        }
        _showEditLocationDialog = false;
    }
    private void CancelEditLocation() => _showEditLocationDialog = false;

