    private IEnumerable<HotelItem> FilteredHotelItems =>
        SortHotelItems(_hotelItems.Where(x => string.IsNullOrEmpty(_hotelSearch) ||
            x.Name.Contains(_hotelSearch, StringComparison.OrdinalIgnoreCase) ||
            x.Location.Contains(_hotelSearch, StringComparison.OrdinalIgnoreCase) ||
            x.Email.Contains(_hotelSearch, StringComparison.OrdinalIgnoreCase)))
        .Skip((_hotelPage - 1) * _hotelPageSize).Take(_hotelPageSize);

    private IEnumerable<HotelItem> SortHotelItems(IEnumerable<HotelItem> items) =>
        (_hotelSortCol, _hotelSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Location", true) => items.OrderBy(x => x.Location),
            ("Location", false) => items.OrderByDescending(x => x.Location),
            ("Address", true) => items.OrderBy(x => x.Address),
            ("Address", false) => items.OrderByDescending(x => x.Address),
            ("ContactNo", true) => items.OrderBy(x => x.ContactNo),
            ("ContactNo", false) => items.OrderByDescending(x => x.ContactNo),
            ("Email", true) => items.OrderBy(x => x.Email),
            ("Email", false) => items.OrderByDescending(x => x.Email),
            ("Url", true) => items.OrderBy(x => x.Url),
            ("Url", false) => items.OrderByDescending(x => x.Url),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int HotelTotalPages => (int)Math.Ceiling(_hotelItems.Count / (double)_hotelPageSize);
    private int HotelFrom => (_hotelPage - 1) * _hotelPageSize + 1;
    private int HotelTo => Math.Min(_hotelPage * _hotelPageSize, _hotelItems.Count);

    public record HotelItem(string Name, string ImageUrl, string Location, string Address, string ContactNo, string Email, string Url, string DateCreated);
