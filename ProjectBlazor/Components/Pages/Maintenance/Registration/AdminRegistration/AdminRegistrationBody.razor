@namespace ProjectBlazor.Components.Pages.Maintenance.Registration.AdminRegistration
@using ProjectBlazor.Components.Shared

<AdminRegistrationHeader />

<div class="col-span-12">
    <DataTable T="AdminRegistrationItem"
               Title="@AdminRegistrationHeader.Title"
               Items="Items"
               Columns="Columns"
               ButtonColor="@AdminRegistrationHeader.ButtonColor"
               HeaderGradient="@AdminRegistrationHeader.HeaderGradient"
               TableHeight="600px"
               ContainerStyle="height:750px;"
               OnAddClick="OpenAdd" />
</div>

<AdminRegistrationDialogs @ref="Dialogs" OnAdd="HandleAdd" OnEdit="HandleEdit" />

@code {
    [Parameter] public List<AdminRegistrationItem> Items { get; set; } = new();
    [Parameter] public List<TableColumn<AdminRegistrationItem>> Columns { get; set; } = new();

    public AdminRegistrationDialogs Dialogs { get; set; } = null!;
    public AdminRegistrationHeader AdminRegistrationHeader { get; set; } = new();

    [Inject] private AdminRegistrationService? AdminRegistrationService { get; set; }

    public void OpenAdd() => Dialogs.OpenAdd();

    protected override async Task OnInitializedAsync()
    {
        var admins = await AdminRegistrationService!.GetAdminListAsync();
        Items = admins.Select(a => new AdminRegistrationItem(
            a.Id,
            a.EmployeeID,
            a.Fullname,
            a.Username,
            a.Fname,
            a.Lname,
            a.Email,
            a.Gender,
            a.Position,
            a.Corporatename,
            a.UserTypeId,
            a.UserType,
            DateTime.TryParse(a.DateCreated, out var dc) ? dc : DateTime.Now,
            a.CorporateID,
            a.MembershipID,
            a.PositionID,
            a.Status,
            a.FilePath,
            a.IsVIP == "1"
        )).ToList();

        Columns = new List<TableColumn<AdminRegistrationItem>>
        {
            new() {
                Header = "Full Name", Width = "18%", SortField = "Fullname",
                RenderCell = item => __builder =>
                {
                    <div class="relative w-full" style="height:72px;">
                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:4px;">
                            @item.EmployeeID
                        </div>
                        <div class="absolute left-0 flex items-center gap-2 transition-transform duration-200 group-hover:translate-y-3" style="top:8px;">
                            @if (!string.IsNullOrEmpty(item.FilePath))
                            {
                                <img src="@item.FilePath" class="w-7 h-7 rounded-full object-cover flex-shrink-0" alt="@item.Fullname" />
                            }
                            else
                            {
                                <div class="w-7 h-7 rounded-full flex-shrink-0 flex items-center justify-center bg-gray-200">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="@($"font-size:14px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                </div>
                            }
                            <span class="font-medium text-gray-800 text-xs overflow-hidden text-ellipsis whitespace-nowrap" style="max-width: 85%;" title="@item.Fullname">@item.Fullname</span>
                        </div>
                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 group-hover:translate-y-3" style="top:40px;">
                            <button @onclick="() => Dialogs.OpenEdit(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:13px;" Color="Color.Inherit" /> Edit
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:13px;" Color="Color.Inherit" /> Delete
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" /> Send Email
                            </button>
                        </div>
                    </div>
                    ;
                }
            },
            new() {
                Header = "Username", SortField = "Username",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Username</span>; }
            },
            new() {
                Header = "Email", SortField = "Email",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Email</span>; }
            },
            new() {
                Header = "Gender", SortField = "Gender",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Gender</span>; }
            },
            new() {
                Header = "Company Name", SortField = "Corporatename",
                RenderCell = item => __builder => { <span class="text-gray-600">@item.Corporatename</span>; }
            },
            new() {
                Header = "Position", SortField = "Position",
                RenderCell = item => __builder => { <span class="text-gray-600 overflow-hidden text-ellipsis whitespace-nowrap block" title="@item.Position">@item.Position</span>; }
            },
            new() {
                Header = "Status", SortField = "Status",
                RenderCell = item => __builder => { <span class="@(item.Status == "REGISTERED" ? "text-green-600 font-medium" : "text-red-500")">@item.Status</span>; }
            },
            new() {
                Header = "Date Created", SortField = "DateCreated",
                RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateCreated.ToString("M/d/yyyy")</span>; }
            }
        };
    }

    private async Task HandleAdd(AdminRegistrationItem item)
    {
        Items.Add(item);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleEdit(AdminRegistrationItem item)
    {
        var index = Items.FindIndex(i => i.Id == item.Id);
        if (index >= 0) Items[index] = item;
        await InvokeAsync(StateHasChanged);
    }
}
