@page "/maintenance/vendor"
@rendermode InteractiveServer
@using ProjectBlazor.Components

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Vendor Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <MaintenanceCard Title="Vendor Maintenance">
            <ToolbarLeft>
                <div class="flex flex-col gap-2 w-full">
                    <!-- Row 1: entries per page (left) | View Inactive + Import + Search (right) -->
                    <div class="flex items-center gap-2 w-full">
                        <!-- LEFT -->
                        <div class="flex items-center gap-2 text-xs text-gray-600">
                            <select value="@_vendorPageSize" @onchange="e => { _vendorPageSize = int.Parse(e.Value.ToString()); _vendorPage = 1; }"
                                    class="border border-gray-300 rounded px-2 py-1 text-xs">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                            <span>entries per page</span>
                        </div>

                        <!-- RIGHT -->
                        <div class="flex items-center gap-2 ml-auto">
                            <button @onclick="ToggleViewMode"
                                    class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-700 hover:bg-gray-50 transition font-medium">
                                @(_showInactive ? "View Active Vendor" : "View Inactive Vendor")
                                <span>›</span>
                            </button>
                            <div class="w-px h-4 bg-gray-300 mx-1"></div>
                            <span class="text-xs text-gray-600 font-medium">Import Excel File:</span>
                            <InputFile id="vendorFileInput" OnChange="HandleFileUpload" accept=".xlsx,.xls" class="hidden" />
                            <label for="vendorFileInput"
                                   class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-300 bg-white text-xs text-gray-600 cursor-pointer hover:bg-gray-50 transition">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Style="font-size:13px;" />
                                @(_uploadedFileName ?? "Choose File")
                            </label>
                            <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium transition"
                                    style="background:@ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" />
                                Upload
                            </button>
                            <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-600 hover:bg-gray-50 transition">
                                <MudIcon Icon="@Icons.Material.Filled.Download" Style="font-size:13px;" />
                                Download Template
                            </button>
                            <div class="w-px h-4 bg-gray-300 mx-1"></div>
                            <span class="text-xs text-gray-600 font-medium">Search:</span>
                            <input type="text" @bind="_vendorSearch" @bind:event="oninput"
                                   class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                                   placeholder="Type to search..." />
                        </div>
                    </div>

                    <!-- Row 2: Add New (left) | Filter By Business Type (right) -->
                    <div class="flex items-center w-full">
                        <!-- LEFT -->
                        <button @onclick="OpenAddVendor" class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                                style="background: @ThemeConfig.Colors.Primary;">
                            + Add New
                        </button>

                        <!-- RIGHT -->
                        <div class="relative ml-auto">
                            <button @onclick="ToggleFilter"
                                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-700 hover:bg-gray-50 transition">
                                <MudIcon Icon="@Icons.Material.Filled.FilterList" Style="font-size:13px;" />
                                Filter By Business Type
                            </button>
                            @if (_showFilter)
                            {
                                <div class="absolute right-0 top-8 z-50 bg-white border border-gray-200 rounded-lg shadow-lg p-4 w-72">
                                    <div class="flex flex-col gap-2 mb-3">
                                        @foreach (var bt in _businessTypes)
                                        {
                                            <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                                <input type="checkbox"
                                                       checked="@_selectedBusinessTypes.Contains(bt)"
                                                       @onchange="e => ToggleBusinessType(bt, (bool)e.Value)" />
                                                @bt
                                            </label>
                                        }
                                    </div>
                                    <div class="flex justify-end gap-2 pt-2 border-t border-gray-100">
                                        <button @onclick="ClearFilter"
                                                class="px-3 py-1 text-xs text-gray-600 cursor-pointer border-none bg-transparent hover:text-gray-900">
                                            Clear
                                        </button>
                                        <button @onclick="ToggleFilter"
                                                class="px-3 py-1 text-xs text-white rounded cursor-pointer border-none"
                                                style="background:@ThemeConfig.Colors.Primary;">
                                            Close
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </ToolbarLeft>

            <!-- ToolbarRight must be empty -->
            <ToolbarRight>
                <div></div>
            </ToolbarRight>
            <Body>
                <div>
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap" style="width: 5%;"></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 18%;"
                                    @onclick='() => SortVendor("Name")'>
                                    Name <span class="text-gray-400">@VendorSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 20%;"
                                    @onclick='() => SortVendor("Email")'>
                                    Email <span class="text-gray-400">@VendorSortIcon("Email")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 35%;"
                                    @onclick='() => SortVendor("BusinessAddress")'>
                                    Business Address <span class="text-gray-400">@VendorSortIcon("BusinessAddress")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 8%;"
                                    @onclick='() => SortVendor("Status")'>
                                    Status <span class="text-gray-400">@VendorSortIcon("Status")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none whitespace-nowrap" style="width: 14%;"
                                    @onclick='() => SortVendor("DateCreated")'>
                                    Date Created <span class="text-gray-400">@VendorSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredVendorItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2" style="width: 5%;">
                                        <div class="w-10 h-10 rounded overflow-hidden flex-shrink-0 flex items-center justify-center pointer-events-none"
                                             style="background:@ThemeConfig.Colors.Background.Alt;">
                                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                            {
                                                <img src="@item.ThumbnailUrl" alt="@item.Name" class="w-full h-full object-cover" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Store" Style="@($"font-size:16px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                            }
                                        </div>
                                    </td>
                                    <td class="py-2 px-2" style="height: 64px; width: 18%;">
                                        <div class="relative w-full" style="height: 64px;">
                                            <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 8px;">
                                                @item.Code
                                            </div>
                                            <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 16px;">
                                                @item.Name
                                            </div>
                                            <div class="absolute left-0 flex gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-2" style="top: 36px;">
                                                <button @onclick="() => OpenEditVendor(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                    Edit
                                                </button>
                                                @if (_showInactive)
                                                {
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Activate
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.Block" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Deactivate
                                                    </button>
                                                }
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                                    <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="font-size: 14px;" Color="Color.Inherit" />
                                                    Duplicate
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600" style="width: 20%;">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600" style="width: 35%;">@item.BusinessAddress</td>
                                    <td class="py-2 px-2" style="width: 8%;">
                                        <span class="@(item.Status == "ACTIVE" ? "text-green-600 font-medium" : "text-gray-500")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap" style="width: 14%;">@item.DateCreated.ToString("M/d/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Body>
            <Footer>
                <span class="text-xs text-gray-500">
                    Showing @VendorFrom to @VendorTo of @_totalVendorCount entries
                </span>
                <div class="flex items-center gap-1">
                    <Pagination CurrentPage="_vendorPage" TotalPages="VendorTotalPages" SetPageAction="p => _vendorPage = p" />
                </div>
            </Footer>
        </MaintenanceCard>
    </div>
</div>

@* ── Add/Edit Vendor Dialog ── *@
@if (_showAddVendorDialog || _showEditVendorDialog)
{
    var isEdit = _showEditVendorDialog;
    <div class="fixed inset-0 flex items-start justify-center z-[100]"
         style="background:rgba(0,0,0,0.45); padding:60px 20px 20px;">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl flex flex-col"
             style="max-height:calc(100vh - 80px);">

            @* ── Header ── *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="@ThemeConfig.Styles.HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Store" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@(isEdit ? "Edit Vendor" : "Add Vendor")</span>
                </div>
                <button @onclick="CloseVendorDialog"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* ── Body ── *@
            <div class="overflow-y-auto flex flex-col" style="padding:0;">

                @* ── SECTION: Media Assets ── *@
                <div class="px-6 py-5 flex flex-col gap-4"
                     style="border-bottom:0.5px solid @ThemeConfig.Colors.Border.Subtle;">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-semibold tracking-widest uppercase"
                              style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">
                            Media Assets
                        </span>
                        <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
                    </div>

                    @* Featured + Logo side by side *@
                    <div class="grid grid-cols-2 gap-3">

                        @* Featured Image *@
                        <label class="cursor-pointer group">
                            <div class="border-2 border-dashed rounded-xl p-4 flex flex-col items-center gap-3
                                            transition-all hover:border-amber-400"
                                 style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle; min-height:120px;
                                            justify-content:center; position:relative;">
                                <div class="absolute top-2 right-2 text-xs font-semibold px-2 py-0.5 rounded"
                                     style="background:rgba(201,168,76,0.12); color:@ThemeConfig.Colors.Primary;
                                                font-size:9px; letter-spacing:0.5px;">
                                    FEATURED
                                </div>
                                @if (!string.IsNullOrEmpty(_vendorFeaturedImageUrl))
                                {
                                    <img src="@_vendorFeaturedImageUrl"
                                         class="w-14 h-14 rounded-full object-cover"
                                         style="border:2px solid rgba(201,168,76,0.3);" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center"
                                         style="background:rgba(201,168,76,0.1);
                                                        border:1.5px solid rgba(201,168,76,0.2);">
                                        <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate"
                                                 Style="@($"font-size:18px; color:{ThemeConfig.Colors.Primary};")" />
                                    </div>
                                }
                                <div class="text-center">
                                    <div class="text-xs font-medium text-gray-600">Upload Featured Image</div>
                                    <div class="text-gray-400 mt-0.5" style="font-size:9px;">
                                        JPEG · PNG · WEBP
                                    </div>
                                </div>
                            </div>
                            <InputFile OnChange="OnVendorFeaturedImageSelected"
                                       accept="image/*" class="hidden" />
                        </label>

                        @* Logo *@
                        <label class="cursor-pointer group">
                            <div class="border-2 border-dashed rounded-xl p-4 flex flex-col items-center gap-3
                                            transition-all hover:border-amber-400"
                                 style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle; min-height:120px;
                                            justify-content:center; position:relative;">
                                <div class="absolute top-2 right-2 text-xs font-semibold px-2 py-0.5 rounded"
                                     style="background:rgba(13,27,42,0.07); color:@ThemeConfig.Colors.Text.Primary;
                                                font-size:9px; letter-spacing:0.5px;">
                                    LOGO
                                </div>
                                @if (!string.IsNullOrEmpty(_vendorLogoUrl))
                                {
                                    <img src="@_vendorLogoUrl"
                                         class="w-14 h-14 rounded-lg object-cover"
                                         style="border:2px solid rgba(201,168,76,0.3);" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                                         style="background:rgba(13,27,42,0.05);
                                                        border:1.5px solid rgba(13,27,42,0.12);">
                                        <MudIcon Icon="@Icons.Material.Filled.Image"
                                                 Style="@($"font-size:18px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                    </div>
                                }
                                <div class="text-center">
                                    <div class="text-xs font-medium text-gray-600">Upload Logo</div>
                                    <div class="text-gray-400 mt-0.5" style="font-size:9px;">
                                        JPEG · PNG · WEBP
                                    </div>
                                </div>
                            </div>
                            <InputFile OnChange="OnVendorLogoSelected"
                                       accept="image/*" class="hidden" />
                        </label>
                    </div>

                    @* Gallery filmstrip *@
                    <div class="flex flex-col gap-2">
                        <div class="text-xs font-semibold text-gray-500" style="font-size:10px;">
                            Gallery Images
                        </div>
                        <div class="flex items-center gap-2 overflow-x-auto pb-1">
                            @foreach (var (img, idx) in _vendorGalleryImages.Select((x, i) => (x, i)))
                            {
                                <div class="relative flex-shrink-0">
                                    <img src="@img"
                                         class="w-14 h-14 rounded-lg object-cover"
                                         style="border:1px solid @ThemeConfig.Colors.Border.Light;" />
                                    <button @onclick="() => RemoveGalleryImage(idx)"
                                            class="absolute flex items-center justify-center
                                                           text-white border-none cursor-pointer"
                                            style="top:-5px; right:-5px; width:16px; height:16px;
                                                           border-radius:50%; background:@ThemeConfig.Colors.Primary; font-size:9px;">
                                        ✕
                                    </button>
                                </div>
                            }
                        @* Add tile *@
                        <label class="flex-shrink-0 cursor-pointer">
                            <div class="w-14 h-14 rounded-lg border-2 border-dashed flex flex-col
                                            items-center justify-center gap-0.5 transition-all
                                            hover:border-amber-400"
                                 style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle;">
                                <span class="text-gray-400 font-light" style="font-size:20px; line-height:1;">+</span>
                                <span class="text-gray-400" style="font-size:8px;">Add</span>
                            </div>
                            <InputFile OnChange="OnVendorGallerySelected"
                                       accept="image/*" multiple class="hidden" />
                        </label>
                    </div>
                </div>
            </div>

            @* ── SECTION: Basic Info ── *@
            <div class="px-6 py-5 flex flex-col gap-4"
                 style="border-bottom:0.5px solid @ThemeConfig.Colors.Border.Subtle;">
                <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold tracking-widest uppercase"
                          style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">Basic Info</span>
                    <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
                </div>

                @* Vendor Name + Contact *@
                <div class="grid grid-cols-2 gap-3">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">
                            Vendor Name <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                        </label>
                        <input type="text" @bind="_vendorName"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">
                            Contact Number <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                        </label>
                        <input type="text" @bind="_vendorContactNumber"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400"
                               placeholder="+1 234 567 8900" />
                    </div>
                </div>

                @* Description *@
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">
                        Description <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                    </label>
                    <textarea @bind="_vendorDescription" rows="4"
                              class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                         resize-y focus:outline-none focus:border-amber-400"></textarea>
                </div>

                @* Address *@
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">
                        Address <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-amber-500"
                              style="font-size:12px;">📍</span>
                        <input type="text" @bind="_vendorAddress"
                               class="w-full border rounded-lg pl-8 pr-3 py-2 text-xs
                                          focus:outline-none"
                               style="border-color:@ThemeConfig.Colors.Background.WarningBorder; background:@ThemeConfig.Colors.Background.WarningLight;" />
                    </div>
                </div>
            </div>

            @* ── SECTION: Contact & Web ── *@
            <div class="px-6 py-5 flex flex-col gap-4"
                 style="border-bottom:0.5px solid @ThemeConfig.Colors.Border.Subtle;">
                <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold tracking-widest uppercase"
                          style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">
                        Contact & Web
                    </span>
                    <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
                </div>

                @* Services + Website *@
                <div class="grid grid-cols-2 gap-3">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">Services</label>
                        <input type="text" @bind="_vendorServices"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">
                            Website URL <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                        </label>
                        <input type="text" @bind="_vendorWebsiteUrl"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400"
                               placeholder="https://" />
                    </div>
                </div>

                @* Email + Map *@
                <div class="grid grid-cols-2 gap-3">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">Email</label>
                        <input type="email" @bind="_vendorEmail"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400"
                               placeholder="vendor@example.com" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">Map Embed</label>
                        <input type="text" @bind="_vendorMap"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400"
                               placeholder="&lt;iframe src=&quot;https://maps.google.com/...&quot;" />
                    </div>
                </div>
            </div>

            @* ── SECTION: Business Details ── *@
            <div class="px-6 py-5 flex flex-col gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold tracking-widest uppercase"
                          style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">
                        Business Details
                    </span>
                    <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    @* Business Type multi-select *@
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-600">
                            Business Type <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                        </label>
                        <div class="relative">
                            <button type="button" @onclick="ToggleVendorBizTypeDropdown"
                                    class="w-full border border-gray-300 rounded-lg px-3 py-2
                                               text-xs text-left bg-white flex items-center
                                               justify-between focus:outline-none hover:border-amber-400">
                                <span class="text-gray-400 truncate">
                                    @(_vendorSelectedBusinessTypes.Any()
                                                                        ? $"{_vendorSelectedBusinessTypes.Count} type(s) selected"
                                                                        : "-Select Business Type-")
                                </span>
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
                                    <polyline points="6,9 12,15 18,9" stroke="@ThemeConfig.Colors.Text.Muted"
                                              stroke-width="2" stroke-linecap="round" />
                                </svg>
                            </button>
                            @* Selected tags *@
                            @if (_vendorSelectedBusinessTypes.Any())
                                {
                                    <div class="flex flex-wrap gap-1 mt-1.5">
                                        @foreach (var bt in _vendorSelectedBusinessTypes.ToList())
                                        {
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs"
                                                  style="background:rgba(201,168,76,0.12);
                                                                     border:1px solid rgba(201,168,76,0.25);
                                                                     color:@ThemeConfig.Colors.Text.LabelAccent; font-size:10px;">
                                                @bt
                                                <button @onclick="() => ToggleVendorBizType(bt, false)"
                                                        class="bg-transparent border-none cursor-pointer
                                                                           leading-none"
                                                        style="color:@ThemeConfig.Colors.Text.LabelAccent; font-size:11px;">
                                                    ×
                                                </button>
                                            </span>
                                        }
                                    </div>
                                }
                                @if (_showVendorBizTypeDropdown)
                                {
                                    <div class="absolute left-0 top-full mt-1 z-50 bg-white border
                                                        border-gray-200 rounded-lg shadow-lg w-full"
                                         style="max-height:160px; overflow-y:auto;">
                                        @foreach (var bt in _businessTypes)
                                        {
                                            <label class="flex items-center gap-2 text-xs text-gray-700
                                                                      cursor-pointer py-1.5 px-3 hover:bg-gray-50">
                                                <input type="checkbox"
                                                       checked="@_vendorSelectedBusinessTypes.Contains(bt)"
                                                       @onchange="e => ToggleVendorBizType(bt, (bool)e.Value)"
                                                       style="accent-color:@ThemeConfig.Colors.Primary;" />
                                                @bt
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        @* Hotel Business Address *@
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-600">
                                Hotel Business Address <span style="color:@ThemeConfig.Colors.Primary;">*</span>
                            </label>
                            <select @bind="_vendorHotelBusinessAddress"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                               focus:outline-none focus:border-amber-400 bg-white">
                                <option value="">-Select Location-</option>
                                <option value="Doha">Doha</option>
                                <option value="Istanbul">Istanbul</option>
                                <option value="Muscat">Muscat</option>
                                <option value="Westbay - STR">Westbay - STR</option>
                                <option value="The Pearl Island - STR MAI">The Pearl Island - STR MAI</option>
                                <option value="The Pearl Island - MMK">The Pearl Island - MMK</option>
                            </select>
                        </div>
                    </div>
                </div>

            </div>

            @* ── Footer ── *@
            <div class="flex items-center justify-end gap-3 px-6 py-4 flex-shrink-0"
                 style="border-top:0.5px solid @ThemeConfig.Colors.Border.Subtle; background:@ThemeConfig.Colors.Background.Subtle; border-radius:0 0 1rem 1rem;">
                <button @onclick="CloseVendorDialog"
                        class="text-xs cursor-pointer bg-transparent border-none
                                   hover:text-gray-700 underline"
                        style="color:@ThemeConfig.Colors.Primary;">
                    Cancel
                </button>
                <button @onclick="SaveVendorDialog"
                        class="px-6 py-2 text-xs rounded-lg text-white font-medium
                                   border-none cursor-pointer"
                        style="@ThemeConfig.Styles.ButtonPrimary">
                    @(isEdit ? "Save Changes" : "Register Vendor")
                </button>
            </div>

        </div>
    </div>
}
@code {
    private string? _uploadedFileName;
    private bool _showInactive = false;

    private void ToggleViewMode()
    {
        _showInactive = !_showInactive;
        _vendorPage = 1;
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _uploadedFileName = e.File.Name;
        await Task.CompletedTask;
    }

    private string _vendorSearch = "";
    private int _vendorPage = 1;
    private int _vendorPageSize = 10;
    private string _vendorSortCol = "DateCreated";
    private bool _vendorSortAsc = false;
    private int _totalVendorCount = 0;

    private void SortVendor(string col)
    {
        if (_vendorSortCol == col) _vendorSortAsc = !_vendorSortAsc;
        else { _vendorSortCol = col; _vendorSortAsc = true; }
        _vendorPage = 1;
    }
    private string VendorSortIcon(string col) => _vendorSortCol == col ? (_vendorSortAsc ? "↑" : "↓") : "⇅";

    private List<VendorItem> _vendorItems = new()
{
    new("Vendor-001", null, "Kahve Lounge",                                 "",                                      "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,9,3)),
    new("Vendor-001",null, "Toro Latin Gastro Bar",                        "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "SAX Türkiye",                                  "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "Scalini Istanbul",                             "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "1860 Lounge",                                  "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "Kocatas Patisserie",                           "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "Chef Erdal Kocatas Mansions",                  "restaurant-istanbul@sixsenses.com",     "Istanbul",                   "Food & Beverages", "ACTIVE",   new DateTime(2025,8,5)),
    new("Vendor-001",null, "The St. Regis Doha",                           "Reservations.Doha@stregis.com",         "Westbay - STR",              "Rooms & Suites",   "ACTIVE",   new DateTime(2025,6,15)),
    new("Vendor-001",null, "The St. Regis Marsa Arabia Island, The Pearl", "Reservations.Doha@stregis.com",         "The Pearl Island - STR MAI", "Rooms & Suites",   "ACTIVE",   new DateTime(2025,6,15)),
    new("Vendor-001",null, "Marsa Malaz Kempinski, The Pearl - Doha",      "reservations.marsamalaz@kempinski.com", "The Pearl Island - MMK",     "Rooms & Suites",   "ACTIVE",   new DateTime(2025,6,15)),
    new("Vendor-001",null, "Test",                                         "",                                      "Muscat",                     "Wellness",         "INACTIVE", new DateTime(2025,5,20)),
    new("Vendor-001",null, "Huqqa",                                        "dining.reservations@stregis.com",       "Westbay - STR",              "Food & Beverages", "INACTIVE", new DateTime(2025,2,16)),
    new("Vendor-001",null, "The Lounge",                                   "",                                      "Muscat",                     "Food & Beverages", "INACTIVE", new DateTime(2025,2,16)),
    new("Vendor-001",null, "Murano Lobby Lounge",                          "",                                      "The Pearl Island - MMK",     "Food & Beverages", "INACTIVE", new DateTime(2024,9,22)),
    new("Vendor-001",null, "Hakkasan Doha",                                "",                                      "Westbay - STR",              "Food & Beverages", "INACTIVE", new DateTime(2024,9,19)),
    new("Vendor-001",null, "Oyster Bay Restaurant",                        "dining.reservations@stregis.com",        "Westbay - STR",              "Food & Beverages", "INACTIVE", new DateTime(2024,4,3)),
    new("Vendor-001",null, "AMNM",                                         "",                                      "Westbay - STR",              "Shops",            "INACTIVE", new DateTime(2024,2,27)),
    new("Vendor-001",null, "El Faro",                                      "restaurants.marsamalaz@kempinski.com",  "Muscat",                     "Food & Beverages", "INACTIVE", new DateTime(2024,2,21)),
    new("Vendor-001",null, "Guerlain Spa, Alfardan",                       "spa@alfardan.com.qa",                   "The Pearl Island - MMK",     "Wellness",         "INACTIVE", new DateTime(2024,2,21)),
};

    private IEnumerable<VendorItem> FilteredVendorItems
    {
        get
        {
            var statusFilter = _showInactive ? "INACTIVE" : "ACTIVE";
            var filtered = _vendorItems.Where(x =>
                x.Status == statusFilter &&
                (_selectedBusinessTypes.Count == 0 || _selectedBusinessTypes.Contains(x.BusinessType)) &&  
                (string.IsNullOrEmpty(_vendorSearch) ||
                 x.Name.Contains(_vendorSearch, StringComparison.OrdinalIgnoreCase) ||
                 x.Email.Contains(_vendorSearch, StringComparison.OrdinalIgnoreCase) ||
                 x.BusinessAddress.Contains(_vendorSearch, StringComparison.OrdinalIgnoreCase)));

            var sorted = SortVendorItems(filtered);
            _totalVendorCount = sorted.Count();
            return sorted.Skip((_vendorPage - 1) * _vendorPageSize).Take(_vendorPageSize);
        }
    }

    private IEnumerable<VendorItem> SortVendorItems(IEnumerable<VendorItem> items) =>
        (_vendorSortCol, _vendorSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Email", true) => items.OrderBy(x => x.Email),
            ("Email", false) => items.OrderByDescending(x => x.Email),
            ("BusinessAddress", true) => items.OrderBy(x => x.BusinessAddress),
            ("BusinessAddress", false) => items.OrderByDescending(x => x.BusinessAddress),
            ("Status", true) => items.OrderBy(x => x.Status),
            ("Status", false) => items.OrderByDescending(x => x.Status),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int VendorTotalPages => (int)Math.Ceiling(_totalVendorCount / (double)_vendorPageSize);
    private int VendorFrom => _totalVendorCount == 0 ? 0 : (_vendorPage - 1) * _vendorPageSize + 1;
    private int VendorTo => Math.Min(_vendorPage * _vendorPageSize, _totalVendorCount);

    public record VendorItem(
        string Code,
        string? ThumbnailUrl,
        string Name,
        string Email,
        string BusinessAddress,
        string BusinessType,  
        string Status,
        DateTime DateCreated);


    private bool _showFilter = false;
    private void ToggleFilter() => _showFilter = !_showFilter;

    private List<string> _businessTypes = new()
    {
        "Rooms & Suites Oman", "Food & Beverages Oman", "Wellness Oman",
        "International Privileges Oman", "Alfardan Jewellery Oman",
        "International Privileges", "Alfardan Jewellery", "Rooms & Suites",
        "Shops", "Wellness", "Access to co-working spaces", "Food & Beverages", "Health"
    };

    private HashSet<string> _selectedBusinessTypes = new();

    private void ToggleBusinessType(string bt, bool selected)
    {
        if (selected) _selectedBusinessTypes.Add(bt);
        else _selectedBusinessTypes.Remove(bt);
        _vendorPage = 1;
    }

    private void ClearFilter()
    {
        _selectedBusinessTypes.Clear();
        _vendorPage = 1;
    }

    // ── VENDOR DIALOG STATE ──
    private bool _showAddVendorDialog = false;
    private bool _showEditVendorDialog = false;
    private VendorItem? _editingVendor;
    private bool _showVendorBizTypeDropdown = false;

    // Vendor form fields
    private string _vendorFeaturedImageUrl = "";
    private string _vendorLogoUrl = "";
    private List<string> _vendorGalleryImages = new();
    private string _vendorName = "";
    private string _vendorContactNumber = "";
    private string _vendorDescription = "";
    private string _vendorAddress = "";
    private string _vendorServices = "";
    private string _vendorWebsiteUrl = "";
    private string _vendorEmail = "";
    private string _vendorMap = "";
    private HashSet<string> _vendorSelectedBusinessTypes = new();
    private string _vendorHotelBusinessAddress = "";

    private void ToggleVendorBizTypeDropdown() => _showVendorBizTypeDropdown = !_showVendorBizTypeDropdown;
    private void ToggleVendorBizType(string bt, bool selected)
    {
        if (selected) _vendorSelectedBusinessTypes.Add(bt);
        else _vendorSelectedBusinessTypes.Remove(bt);
    }

    private void OpenAddVendor()
    {
        _vendorFeaturedImageUrl = ""; _vendorLogoUrl = "";
        _vendorGalleryImages = new(); _vendorName = "";
        _vendorContactNumber = ""; _vendorDescription = "";
        _vendorAddress = ""; _vendorServices = "";
        _vendorWebsiteUrl = ""; _vendorEmail = "";
        _vendorMap = ""; _vendorSelectedBusinessTypes = new();
        _vendorHotelBusinessAddress = "";
        _showVendorBizTypeDropdown = false;
        _showAddVendorDialog = true;
    }

    private void OpenEditVendor(VendorItem item)
    {
        _editingVendor = item;
        _vendorFeaturedImageUrl = item.ThumbnailUrl ?? "";
        _vendorLogoUrl = ""; _vendorGalleryImages = new();
        _vendorName = item.Name; _vendorEmail = item.Email;
        _vendorContactNumber = ""; _vendorDescription = "";
        _vendorAddress = item.BusinessAddress;
        _vendorServices = ""; _vendorWebsiteUrl = "";
        _vendorMap = ""; _vendorSelectedBusinessTypes = new() { item.BusinessType };
        _vendorHotelBusinessAddress = item.BusinessAddress;
        _showVendorBizTypeDropdown = false;
        _showEditVendorDialog = true;
    }

    private void CloseVendorDialog()
    {
        _showAddVendorDialog = false;
        _showEditVendorDialog = false;
        _editingVendor = null;
        _showVendorBizTypeDropdown = false;
    }

    private void SaveVendorDialog()
    {
        if (_showEditVendorDialog && _editingVendor != null)
        {
            var index = _vendorItems.IndexOf(_editingVendor);
            if (index >= 0)
            {
                _vendorItems[index] = _editingVendor with
                {
                    ThumbnailUrl = string.IsNullOrEmpty(_vendorFeaturedImageUrl) ? null : _vendorFeaturedImageUrl,
                    Name = _vendorName,
                    Email = _vendorEmail,
                    BusinessAddress = _vendorAddress,
                    BusinessType = _vendorSelectedBusinessTypes.FirstOrDefault() ?? _editingVendor.BusinessType
                };
            }
        }
        else
        {
            _vendorItems.Insert(0, new VendorItem(
                $"Vendor-{(_vendorItems.Count + 1):D3}",
                string.IsNullOrEmpty(_vendorFeaturedImageUrl) ? null : _vendorFeaturedImageUrl,
                _vendorName, _vendorEmail, _vendorAddress,
                _vendorSelectedBusinessTypes.FirstOrDefault() ?? "",
                "ACTIVE", DateTime.Now));
        }
        CloseVendorDialog();
    }

    private async Task OnVendorFeaturedImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        _vendorFeaturedImageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task OnVendorLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        _vendorLogoUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task OnVendorGallerySelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
            _vendorGalleryImages.Add($"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}");
        }
    }

    private void RemoveGalleryImage(int index)
    {
        if (index >= 0 && index < _vendorGalleryImages.Count)
            _vendorGalleryImages.RemoveAt(index);
    }
}
