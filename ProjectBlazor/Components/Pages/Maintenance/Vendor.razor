@page "/maintenance/vendor"
@rendermode InteractiveServer
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Vendor Maintenance</h3>

<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12">
        <DataTable T="VendorItem"
                   Title="Vendor Maintenance"
                   Items="_vendorItems"
                   Columns="_vendorColumns"
                   ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                   HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                   ShowImportExport="true"
                   ImportedFileName="@_uploadedFileName"
                   OnAddClick="OpenAddVendor"
                   OnImport="HandleFileUpload"
                   OnImportButtonClick="HandleImportClick"
                   OnExportTemplateClick="HandleExportTemplate"
                   ExternalFilter="GetVendorFilter()">
            <ToolbarButtons>
                <button @onclick="ToggleViewMode"
                        class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-700 hover:bg-gray-50 transition font-medium">
                    @(_showInactive ? "View Active Vendor" : "View Inactive Vendor")
                    <span>›</span>
                </button>
                <button @onclick="ToggleFilter"
                        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-700 hover:bg-gray-50 transition">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Style="font-size:13px;" />
                    Filter By Business Type
                </button>
                @if (_showFilter)
                {
                    <div class="absolute right-0 top-8 z-50 bg-white border border-gray-200 rounded-lg shadow-lg p-4 w-72 mt-8">
                        <div class="flex flex-col gap-2 mb-3">
                            @foreach (var bt in _businessTypes)
                            {
                                <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer">
                                    <input type="checkbox"
                                           checked="@_selectedBusinessTypes.Contains(bt)"
                                           @onchange="e => ToggleBusinessType(bt, (bool)e.Value)" />
                                    @bt
                                </label>
                            }
                        </div>
                        <div class="flex justify-end gap-2 pt-2 border-t border-gray-100">
                            <button @onclick="ClearFilter"
                                    class="px-3 py-1 text-xs text-gray-600 cursor-pointer border-none bg-transparent hover:text-gray-900">
                                Clear
                            </button>
                            <button @onclick="ToggleFilter"
                                    class="px-3 py-1 text-xs text-white rounded cursor-pointer border-none"
                                    style="background:@ThemeConfig.Colors.Primary;">
                                Close
                            </button>
                        </div>
                    </div>
                }
            </ToolbarButtons>
        </DataTable>
    </div>
</div>

@* ── Add/Edit Vendor Dialog ── *@
@if (_showAddVendorDialog || _showEditVendorDialog)
{
    var isEdit = _showEditVendorDialog;
    <DialogModal IsVisible="_showAddVendorDialog || _showEditVendorDialog"
                 Title="@(isEdit ? "Edit Vendor" : "Add Vendor")"
                 Icon="@Icons.Material.Filled.Store"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 MaxWidth="2xl"
                 OnClose="CloseVendorDialog">
        <ChildContent>
            <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-semibold tracking-widest uppercase"
                      style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">
                    Media Assets
                </span>
                <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <label class="cursor-pointer group">
                    <div class="border-2 border-dashed rounded-xl p-4 flex flex-col items-center gap-3 transition-all hover:border-amber-400"
                         style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle; min-height:120px; justify-content:center; position:relative;">
                        <div class="absolute top-2 right-2 text-xs font-semibold px-2 py-0.5 rounded"
                             style="background:rgba(201,168,76,0.12); color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:0.5px;">
                            FEATURED
                        </div>
                        @if (!string.IsNullOrEmpty(_vendorFeaturedImageUrl))
                        {
                            <img src="@_vendorFeaturedImageUrl" class="w-14 h-14 rounded-full object-cover" style="border:2px solid rgba(201,168,76,0.3);" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-full flex items-center justify-center"
                                 style="background:rgba(201,168,76,0.1); border:1.5px solid rgba(201,168,76,0.2);">
                                <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" Style="@($"font-size:18px; color:{ThemeConfig.Colors.Primary};")" />
                            </div>
                        }
                        <div class="text-center">
                            <div class="text-xs font-medium text-gray-600">Upload Featured Image</div>
                            <div class="text-gray-400 mt-0.5" style="font-size:9px;">JPEG · PNG · WEBP</div>
                        </div>
                    </div>
                    <InputFile OnChange="OnVendorFeaturedImageSelected" accept="image/*" class="hidden" />
                </label>

                <label class="cursor-pointer group">
                    <div class="border-2 border-dashed rounded-xl p-4 flex flex-col items-center gap-3 transition-all hover:border-amber-400"
                         style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle; min-height:120px; justify-content:center; position:relative;">
                        <div class="absolute top-2 right-2 text-xs font-semibold px-2 py-0.5 rounded"
                             style="background:rgba(13,27,42,0.07); color:@ThemeConfig.Colors.Text.Primary; font-size:9px; letter-spacing:0.5px;">
                            LOGO
                        </div>
                        @if (!string.IsNullOrEmpty(_vendorLogoUrl))
                        {
                            <img src="@_vendorLogoUrl" class="w-14 h-14 rounded-lg object-cover" style="border:2px solid rgba(201,168,76,0.3);" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                                 style="background:rgba(13,27,42,0.05); border:1.5px solid rgba(13,27,42,0.12);">
                                <MudIcon Icon="@Icons.Material.Filled.Image" Style="@($"font-size:18px; color:{ThemeConfig.Colors.Text.Muted};")" />
                            </div>
                        }
                        <div class="text-center">
                            <div class="text-xs font-medium text-gray-600">Upload Logo</div>
                            <div class="text-gray-400 mt-0.5" style="font-size:9px;">JPEG · PNG · WEBP</div>
                        </div>
                    </div>
                    <InputFile OnChange="OnVendorLogoSelected" accept="image/*" class="hidden" />
                </label>
            </div>

            <div class="flex flex-col gap-2">
                <div class="text-xs font-semibold text-gray-500" style="font-size:10px;">Gallery Images</div>
                <div class="flex items-center gap-2 overflow-x-auto pb-1">
                    @foreach (var (img, idx) in _vendorGalleryImages.Select((x, i) => (x, i)))
                    {
                        <div class="relative flex-shrink-0">
                            <img src="@img" class="w-14 h-14 rounded-lg object-cover" style="border:1px solid @ThemeConfig.Colors.Border.Light;" />
                            <button @onclick="() => RemoveGalleryImage(idx)"
                                    class="absolute flex items-center justify-center text-white border-none cursor-pointer"
                                    style="top:-5px; right:-5px; width:16px; height:16px; border-radius:50%; background:@ThemeConfig.Colors.Primary; font-size:9px;">
                                ✕
                            </button>
                        </div>
                    }
                    <label class="flex-shrink-0 cursor-pointer">
                        <div class="w-14 h-14 rounded-lg border-2 border-dashed flex flex-col items-center justify-center gap-0.5 transition-all hover:border-amber-400"
                             style="border-color:@ThemeConfig.Colors.Border.Light; background:@ThemeConfig.Colors.Background.Subtle;">
                            <span class="text-gray-400 font-light" style="font-size:20px; line-height:1;">+</span>
                            <span class="text-gray-400" style="font-size:8px;">Add</span>
                        </div>
                        <InputFile OnChange="OnVendorGallerySelected" accept="image/*" multiple class="hidden" />
                    </label>
                </div>
            </div>

            <div class="flex items-center gap-2 mt-4">
                <span class="text-xs font-semibold tracking-widest uppercase" style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">Basic Info</span>
                <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Vendor Name <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                    <input type="text" @bind="_vendorName" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Contact Number <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                    <input type="text" @bind="_vendorContactNumber" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" placeholder="+1 234 567 8900" />
                </div>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-600">Description <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                <textarea @bind="_vendorDescription" rows="4" class="border border-gray-300 rounded-lg px-3 py-2 text-xs resize-y focus:outline-none focus:border-amber-400"></textarea>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-600">Address <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-amber-500" style="font-size:12px;">📍</span>
                    <input type="text" @bind="_vendorAddress" class="w-full border rounded-lg pl-8 pr-3 py-2 text-xs focus:outline-none"
                           style="border-color:@ThemeConfig.Colors.Background.WarningBorder; background:@ThemeConfig.Colors.Background.WarningLight;" />
                </div>
            </div>

            <div class="flex items-center gap-2 mt-4">
                <span class="text-xs font-semibold tracking-widest uppercase" style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">Contact & Web</span>
                <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Services</label>
                    <input type="text" @bind="_vendorServices" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Website URL <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                    <input type="text" @bind="_vendorWebsiteUrl" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" placeholder="https://" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Email</label>
                    <input type="email" @bind="_vendorEmail" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" placeholder="vendor@example.com" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Map Embed</label>
                    <input type="text" @bind="_vendorMap" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400" placeholder="&lt;iframe src=&quot;https://maps.google.com/...&quot;" />
                </div>
            </div>

            <div class="flex items-center gap-2 mt-4">
                <span class="text-xs font-semibold tracking-widest uppercase" style="color:@ThemeConfig.Colors.Primary; font-size:9px; letter-spacing:1.5px;">Business Details</span>
                <div class="flex-1 border-t" style="border-color:rgba(201,168,76,0.2);"></div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Business Type <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                    <div class="relative">
                        <button type="button" @onclick="ToggleVendorBizTypeDropdown"
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs text-left bg-white flex items-center justify-between focus:outline-none hover:border-amber-400">
                            <span class="text-gray-400 truncate">
                                @(_vendorSelectedBusinessTypes.Any() ? $"{_vendorSelectedBusinessTypes.Count} type(s) selected" : "-Select Business Type-")
                            </span>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
                                <polyline points="6,9 12,15 18,9" stroke="@ThemeConfig.Colors.Text.Muted" stroke-width="2" stroke-linecap="round" />
                            </svg>
                        </button>
                        @if (_vendorSelectedBusinessTypes.Any())
                        {
                            <div class="flex flex-wrap gap-1 mt-1.5">
                                @foreach (var bt in _vendorSelectedBusinessTypes.ToList())
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs"
                                          style="background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.25); color:@ThemeConfig.Colors.Text.LabelAccent; font-size:10px;">
                                        @bt
                                        <button @onclick="() => ToggleVendorBizType(bt, false)" class="bg-transparent border-none cursor-pointer leading-none"
                                                style="color:@ThemeConfig.Colors.Text.LabelAccent; font-size:11px;">×</button>
                                    </span>
                                }
                            </div>
                        }
                        @if (_showVendorBizTypeDropdown)
                        {
                            <div class="absolute left-0 top-full mt-1 z-50 bg-white border border-gray-200 rounded-lg shadow-lg w-full" style="max-height:160px; overflow-y:auto;">
                                @foreach (var bt in _businessTypes)
                                {
                                    <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer py-1.5 px-3 hover:bg-gray-50">
                                        <input type="checkbox" checked="@_vendorSelectedBusinessTypes.Contains(bt)"
                                               @onchange="e => ToggleVendorBizType(bt, (bool)e.Value)" style="accent-color:@ThemeConfig.Colors.Primary;" />
                                        @bt
                                    </label>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-600">Hotel Business Address <span style="color:@ThemeConfig.Colors.Primary;">*</span></label>
                    <select @bind="_vendorHotelBusinessAddress" class="border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-amber-400 bg-white">
                        <option value="">-Select Location-</option>
                        <option value="Doha">Doha</option>
                        <option value="Istanbul">Istanbul</option>
                        <option value="Muscat">Muscat</option>
                        <option value="Westbay - STR">Westbay - STR</option>
                        <option value="The Pearl Island - STR MAI">The Pearl Island - STR MAI</option>
                        <option value="The Pearl Island - MMK">The Pearl Island - MMK</option>
                    </select>
                </div>
            </div>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="@(isEdit ? "Save Changes" : "Register Vendor")"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CloseVendorDialog"
                          OnConfirm="SaveVendorDialog" />
        </FooterContent>
    </DialogModal>
}
@code {
    private List<TableColumn<VendorItem>> _vendorColumns = new();

    protected override void OnInitialized()
    {
        _vendorColumns = new List<TableColumn<VendorItem>>
    {
        new() {
            Header = "", Width = "5%",
            RenderCell = item => __builder => {
                <div class="w-10 h-10 rounded overflow-hidden flex-shrink-0 flex items-center justify-center pointer-events-none"
                     style="background:@ThemeConfig.Colors.Background.Alt;">
                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                        {
                    <img src="@item.ThumbnailUrl" alt="@item.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                    <MudIcon Icon="@Icons.Material.Filled.Store" Style="@($"font-size:16px; color:{ThemeConfig.Colors.Text.Muted};")" />
                        }
                </div>
                ;
            }
        },                                          // ← comma here
        new() {
            Header = "Name", Width = "18%", SortField = "Name",
            RenderCell = item => __builder => {
            <div class="relative w-full" style="height:72px;">

                @* Code: fades in at top on hover *@
                <div class="absolute left-0 text-gray-400 text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                     style="top:4px;">
                    @item.Code
                </div>

                @* Name: starts at top, slides down on hover *@
                <div class="absolute left-0 font-medium mt-2 text-gray-700 transition-transform duration-200 group-hover:translate-y-3"
                     style="top:8px;">
                    @item.Name
                </div>

                @* Buttons: always visible, slide down together with name on hover *@
                <div class="absolute left-0 flex gap-2 my-2 transition-transform duration-200 group-hover:translate-y-3"
                     style="top:28px;">
                    <button @onclick="() => OpenEditVendor(item)"
                            class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent"
                            style="color:@ThemeConfig.Colors.Primary;">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:14px;" Color="Color.Inherit" /> Edit
                    </button>
                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-500">
                        <MudIcon Icon="@Icons.Material.Filled.Block" Style="font-size:14px;" Color="Color.Inherit" /> Deactivate
                    </button>
                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent"
                            style="color:@ThemeConfig.Colors.Primary;">
                        <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="font-size:14px;" Color="Color.Inherit" /> Duplicate
                    </button>
                </div>

            </div>
                            ;
                        }
                    },                                          // ← comma here, then add remaining columns below
                    new() {
                        Header = "Email", Width = "20%", SortField = "Email",
                        RenderCell = item => __builder => {

            <span class="text-gray-600">@item.Email</span>
            ; }
                    },
                    new() {
                        Header = "Business Address", Width = "35%", SortField = "BusinessAddress",
                        RenderCell = item => __builder => {

            <span class="text-gray-600">@item.BusinessAddress</span>
            ; }
                    },
                    new() {
                        Header = "Status", Width = "8%", SortField = "Status",
                        RenderCell = item => __builder => {
            <span class="@(item.Status == "ACTIVE" ? "text-green-600 font-medium" : "text-gray-500")">@item.Status</span>
            ;
                        }
                    },
                    new() {
                        Header = "Date Created", Width = "14%", SortField = "DateCreated",
                        RenderCell = item => __builder => {

            <span class="text-gray-600 whitespace-nowrap">@item.DateCreated.ToString("M/d/yyyy")</span>
            ; }
                    }
                };                                              // ← closes _vendorColumns = new List<>
    }                                                   // ← closes OnInitialized()

    private string? _uploadedFileName;

    private async Task HandleFileUpload(string fileName)
    {
        _uploadedFileName = fileName;
        await Task.CompletedTask;
    }

    private Task HandleImportClick()
    {
        return Task.CompletedTask;
    }

    private Task HandleExportTemplate()
    {
        return Task.CompletedTask;
    }

    private bool _showInactive = false;

    private Func<VendorItem, bool> GetVendorFilter()
    {
        return vendor => vendor.Status == (_showInactive ? "INACTIVE" : "ACTIVE");
    }

    private void ToggleViewMode()
    {
        _showInactive = !_showInactive;
        _vendorPage = 1;
    }

    private string _vendorSearch = "";
    private int _vendorPage = 1;
    private int _vendorPageSize = 10;
    private string _vendorSortCol = "DateCreated";
    private bool _vendorSortAsc = false;
    private int _totalVendorCount = 0;

    private void SortVendor(string col)
    {
        if (_vendorSortCol == col) _vendorSortAsc = !_vendorSortAsc;
        else { _vendorSortCol = col; _vendorSortAsc = true; }
        _vendorPage = 1;
    }
    private string VendorSortIcon(string col) => _vendorSortCol == col ? (_vendorSortAsc ? "↑" : "↓") : "⇅";

