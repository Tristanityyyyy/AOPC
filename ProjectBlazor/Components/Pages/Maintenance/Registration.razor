                                                <button @onclick="() => OpenEditReg(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:13px;" Color="Color.Inherit" /> Edit</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500"><MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:13px;" Color="Color.Inherit" /> Delete</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" /> Send Email</button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 align-middle" style="height: 72px;">@item.Username</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Gender</td>
                                    <td class="py-2 px-2 text-gray-600">@item.CompanyName</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Position</td>
