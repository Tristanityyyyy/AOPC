    {
        if (_selectedBulkUsers.Contains(name)) _selectedBulkUsers.Remove(name);
        else _selectedBulkUsers.Add(name);
    }

    private void ToggleSelectAll()
    {
        if (_selectedBulkUsers.Count == BulkEmailUsers.Count())
            _selectedBulkUsers.Clear();
        else
