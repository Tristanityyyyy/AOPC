@page "/maintenance/registration"
@rendermode InteractiveServer
@using ProjectBlazor.Components

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Registration</h3>

@* ── FILTER POPUP ── *@
@if (_showFilter)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center" style="background: rgba(0,0,0,0.3);">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md">
            <div class="flex items-center justify-between mb-5">
                <span class="font-semibold text-base" style="color:@ThemeConfig.Colors.Primary;">Filter</span>
                <button @onclick="() => _showFilter = false"
                        class="w-6 h-6 flex items-center justify-center rounded text-white text-xs font-bold border-none cursor-pointer"
                        style="background:#222;">
                    ✕
                </button>
            </div>

            @* Company Name *@
            <div class="flex items-center gap-4 mb-4">
                <span class="text-xs font-semibold text-gray-700 w-28">Company name:</span>
                <select class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-xs" @bind="_filterCompany">
                    <option value="">-Select Corporate-</option>
                    @foreach (var c in AllCompanies)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>

            @* Gender *@
            <div class="flex items-center gap-4 mb-4">
                <span class="text-xs font-semibold text-gray-700 w-28">Gender:</span>
                <div class="flex items-center gap-4 flex-1">
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="radio" name="gender" value="Male" checked="@(_filterGender == "Male")"
                               @onchange='() => _filterGender = "Male"' /> Male
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="radio" name="gender" value="Female" checked="@(_filterGender == "Female")"
                               @onchange='() => _filterGender = "Female"' /> Female
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_filterGender == "")"
                               @onchange='() => _filterGender = ""' /> Show all
                    </label>
                </div>
            </div>

            @* Position *@
            <div class="flex items-center gap-4 mb-4">
                <span class="text-xs font-semibold text-gray-700 w-28">Position:</span>
                <div class="flex items-center gap-3 flex-1">
                    <select class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-xs" @bind="_filterPosition">
                        <option value="">-Select Option-</option>
                        @foreach (var p in AllPositions)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                    <label class="flex items-center gap-1 text-xs cursor-pointer whitespace-nowrap">
                        <input type="checkbox" checked="@(_filterPosition == "")"
                               @onchange='() => _filterPosition = ""' /> Show all
                    </label>
                </div>
            </div>

            @* VIP *@
            <div class="flex items-center gap-4 mb-4">
                <span class="text-xs font-semibold text-gray-700 w-28" style="color:@ThemeConfig.Colors.Primary; font-weight:700;">VIP:</span>
                <div class="flex items-center gap-4 flex-1">
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_filterVip == "Yes")"
                               @onchange='() => _filterVip = _filterVip == "Yes" ? "" : "Yes"'  /> Yes
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_filterVip == "No")"
                               @onchange='() => _filterVip = _filterVip == "No" ? "" : "No"'  /> No
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_filterVip == "")"
                               @onchange='() => _filterVip = ""' /> Show all
                    </label>
                </div>
            </div>

            @* Status *@
            <div class="flex items-center gap-4 mb-6">
                <span class="text-xs font-semibold text-gray-700 w-28">Status:</span>
                <div class="flex items-center gap-4 flex-1">
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="radio" name="status" value="Active" checked="@(_filterStatus == "Active")"
                               @onchange='() => _filterStatus = "Active"' /> Registered
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="radio" name="status" value="Inactive" checked="@(_filterStatus == "Inactive")"
                               @onchange='() => _filterStatus = "Inactive"' /> Unregistered
                    </label>
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_filterStatus == "")"
                               @onchange='() => _filterStatus = ""' /> Show all
                    </label>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3">
                <button @onclick="ClearFilter"
                        class="px-5 py-2 text-xs rounded-lg border border-gray-300 bg-white text-gray-600 cursor-pointer hover:bg-gray-50 transition underline">
                    Clear
                </button>
                <button @onclick="ApplyFilter"
                        class="px-6 py-2 text-xs rounded-lg text-white font-medium border-none cursor-pointer"
                        style="background:@ThemeConfig.Colors.Primary;">
                    Apply
                </button>
            </div>
        </div>
    </div>
}

@* ── BULK EMAIL POPUP ── *@
@if (_showBulkEmail)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center" style="background: rgba(0,0,0,0.3);">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl" style="max-height: 80vh; display: flex; flex-direction: column;">
            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl" style="@ThemeConfig.Styles.HeaderGradient">
                <span class="font-semibold text-base" style="color:@ThemeConfig.Colors.OnWhite;">Select Unregister users</span>
                <div class="flex items-center gap-2">
                    <select class="border border-gray-300 rounded-lg px-3 py-1.5 text-xs" @bind="_bulkEmailCompany">
                        <option value="">-Select Corporate-</option>
                        @foreach (var c in AllCompanies)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                    <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium"
                            style="background:@ThemeConfig.Colors.Primary;">
                        <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:13px;" Color="Color.Inherit" />
                    </button>
                    <button @onclick="() => _showBulkEmail = false"
                            class="flex items-center justify-center px-3 py-1.5 rounded-lg text-white text-xs font-bold border-none cursor-pointer"
                            style="background:@ThemeConfig.Colors.Primary;">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" />
                        Bulk Email
                    </button>
                    <button @onclick="ClosePositionDialog"
                            class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                            style="background: rgba(255,255,255,0.15);">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                    </button>
                </div>
            </div>

            @* User list *@
            <div class="overflow-y-auto px-6 py-4 flex-1">
                <div class="grid grid-cols-3 gap-x-4 gap-y-3">
                    @foreach (var item in BulkEmailUsers)
                    {
                        <label class="flex items-center gap-2 text-xs cursor-pointer">
                            <input type="checkbox"
                                   checked="@_selectedBulkUsers.Contains(item.FullName)"
                                   @onchange="() => ToggleBulkUser(item.FullName)" />
                            @item.FullName
                        </label>
                    }
                </div>
            </div>

            @* Footer *@
            <div class="flex items-center justify-between px-6 py-3 border-t border-gray-100">
                <span class="text-xs font-semibold" style="color:@ThemeConfig.Colors.Primary;">
                    User Count: @_selectedBulkUsers.Count
                </span>
                <div class="flex items-center gap-3">
                    <label class="flex items-center gap-1 text-xs cursor-pointer">
                        <input type="checkbox" checked="@(_selectedBulkUsers.Count == BulkEmailUsers.Count())"
                               @onchange="ToggleSelectAll" /> Send to all
                    </label>
                    <button class="px-5 py-1.5 text-xs rounded-lg text-white font-medium border-none cursor-pointer"
                            style="background:@ThemeConfig.Colors.Primary;">
                        Send
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "user"'
            class="flex items-center gap-1 px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "user" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        <MudIcon Icon="@Icons.Material.Filled.Group" Style="font-size: 14px;" Color="Color.Inherit" />
        User Registration
    </button>
    <button @onclick='() => _activeTab = "oyster"'
            class="flex items-center gap-1 px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "oyster" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Style="font-size: 14px;" Color="Color.Inherit" />
        Oyster Admin Registration
    </button>
    <button @onclick='() => _activeTab = "corporate"'
            class="flex items-center gap-1 px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "corporate" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size: 14px;" Color="Color.Inherit" />
        Corporate Admin Registration
    </button>
</div>

@* ── USER REGISTRATION ── *@
@if (_activeTab == "user")
{
    <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="@ThemeConfig.Styles.HeaderGradient">
                    <h4 class="text-sm font-medium text-white">User Registration</h4>
                </div>
                @if (_activeTab == "user")
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: true)
                }
                else if (_activeTab == "oyster")
                {
                    @ControlsRow1(showFilter: false, showBulkEmail: false)
                }
                else
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: false)
                }
                @ControlsRow2("_userSearch", "_userPageSize", "_userPage")
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddReg" class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background:@ThemeConfig.Colors.Primary;">
                        + Add New
                    </button>
                </div>
                <div class="overflow-y-auto" style="max-height:600px;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" style="width: 18%;" @onclick='() => SortUser("FullName")'>Full Name <span class="text-gray-400">@SortIconUser("FullName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Username")'>Username <span class="text-gray-400">@SortIconUser("Username")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Email")'>Email <span class="text-gray-400">@SortIconUser("Email")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Gender")'>Gender <span class="text-gray-400">@SortIconUser("Gender")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("CompanyName")'>Company Name <span class="text-gray-400">@SortIconUser("CompanyName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Position")'>Position <span class="text-gray-400">@SortIconUser("Position")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Status")'>Status <span class="text-gray-400">@SortIconUser("Status")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Vip")'>VIP <span class="text-gray-400">@SortIconUser("Vip")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("DateCreated")'>Date Created <span class="text-gray-400">@SortIconUser("DateCreated")</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredUserItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2" style="height: 72px;">
                                        <div class="relative w-full" style="height: 72px;">
                                            <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 4px;">@item.Code</div>
                                            <div class="absolute left-0 flex items-center gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 14px;">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" class="w-8 h-8 rounded-full object-cover" alt="@item.FullName" />
                                                }
                                                else
                                                {
                                                    <div class="w-8 h-8 rounded-full overflow-hidden flex items-center justify-center bg-gray-200">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="@($"font-size:16px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                                    </div>
                                                }
                                                <div class="font-medium text-gray-800 text-xs">@item.FullName</div>
                                            </div>
                                            <div class="absolute left-0 flex gap-2 pt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 50px;">
                                                <button @onclick="() => OpenEditReg(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:13px;" Color="Color.Inherit" /> Edit</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500"><MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:13px;" Color="Color.Inherit" /> Delete</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" /> Send Email</button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 align-middle" style="height: 72px;">@item.Username</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Gender</td>
                                    <td class="py-2 px-2 text-gray-600">@item.CompanyName</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Position</td>
                                    <td class="py-2 px-2"><span class="@(item.Status == "Active" ? "text-green-600 font-medium" : "text-red-500")">@item.Status</span></td>
                                    <td class="py-2 px-2"><span class="@(item.Vip == "Yes" ? "text-amber-600 font-medium" : "text-gray-400")">@item.Vip</span></td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @UserFrom to @UserTo of @_userTotalCount entries</span>
                    <div class="flex items-center gap-1">
                        <Pagination CurrentPage="_userPage" TotalPages="UserTotalPages" SetPageAction="p => _userPage = p" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── OYSTER ADMIN REGISTRATION ── *@
@if (_activeTab == "oyster")
{
    <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="@ThemeConfig.Styles.HeaderGradient">
                    <h4 class="text-sm font-medium text-white">Oyster Admin Registration</h4>
                </div>
                @if (_activeTab == "user")
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: true)
                }
                else if (_activeTab == "oyster")
                {
                    @ControlsRow1(showFilter: false, showBulkEmail: false)
                }
                else
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: false)
                }
                @ControlsRow2("_oysterSearch", "_oysterPageSize", "_oysterPage")
