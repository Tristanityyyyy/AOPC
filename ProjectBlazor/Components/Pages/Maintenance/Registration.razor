        new("USR-005", "/images/user5.jpg", "Layla Hassan",      "layla.hassan",      "layla.hassan@ooredoo.com.qa",   "Female", "Ooredoo",                    "Marketing Director",      "Active",   "No",  "09/28/2025"),
