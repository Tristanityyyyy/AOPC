    // ── Filtered + sorted + paged ──────────────────────────────
    private IEnumerable<RegistrationItem> FilteredUserItems => GetFiltered(_userItems, _userSearch, _userSortCol, _userSortAsc, _userPage, _userPageSize, out _userTotalCount);
    private IEnumerable<RegistrationItem> FilteredOysterItems => GetFiltered(_oysterItems, _oysterSearch, _oysterSortCol, _oysterSortAsc, _oysterPage, _oysterPageSize, out _oysterTotalCount);
    private IEnumerable<RegistrationItem> FilteredCorpItems => GetFiltered(_corpItems, _corpSearch, _corpSortCol, _corpSortAsc, _corpPage, _corpPageSize, out _corpTotalCount);

    private IEnumerable<RegistrationItem> GetFiltered(List<RegistrationItem> src, string search, string sortCol, bool sortAsc, int page, int pageSize, out int total)
    {
        var q = src.Where(x => string.IsNullOrEmpty(search) ||
            x.FullName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Username.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Email.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.CompanyName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Position.Contains(search, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrEmpty(_filterCompany))
            q = q.Where(x => x.CompanyName == _filterCompany);
        if (!string.IsNullOrEmpty(_filterGender))
            q = q.Where(x => x.Gender == _filterGender);
        if (!string.IsNullOrEmpty(_filterPosition))
            q = q.Where(x => x.Position == _filterPosition);
        if (!string.IsNullOrEmpty(_filterVip))
            q = q.Where(x => x.Vip == _filterVip);
        if (!string.IsNullOrEmpty(_filterStatus))
            q = q.Where(x => x.Status == _filterStatus);

        q = (sortCol, sortAsc) switch
        {
            ("Username", true) => q.OrderBy(x => x.Username),
            ("Username", false) => q.OrderByDescending(x => x.Username),
            ("Email", true) => q.OrderBy(x => x.Email),
            ("Email", false) => q.OrderByDescending(x => x.Email),
            ("Gender", true) => q.OrderBy(x => x.Gender),
            ("Gender", false) => q.OrderByDescending(x => x.Gender),
            ("CompanyName", true) => q.OrderBy(x => x.CompanyName),
            ("CompanyName", false) => q.OrderByDescending(x => x.CompanyName),
            ("Position", true) => q.OrderBy(x => x.Position),
            ("Position", false) => q.OrderByDescending(x => x.Position),
            ("Status", true) => q.OrderBy(x => x.Status),
            ("Status", false) => q.OrderByDescending(x => x.Status),
            ("Vip", true) => q.OrderBy(x => x.Vip),
            ("Vip", false) => q.OrderByDescending(x => x.Vip),
            ("DateCreated", true) => q.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => q.OrderByDescending(x => x.DateCreated),
            _ => q.OrderBy(x => x.FullName)
        };

        total = q.Count();
        return q.Skip((page - 1) * pageSize).Take(pageSize);
    }

    // ── Pagination ─────────────────────────────────────────────
    private int UserTotalPages => (int)Math.Ceiling(_userTotalCount / (double)_userPageSize);
    private int OysterTotalPages => (int)Math.Ceiling(_oysterTotalCount / (double)_oysterPageSize);
    private int CorpTotalPages => (int)Math.Ceiling(_corpTotalCount / (double)_corpPageSize);
    private int UserFrom => _userTotalCount == 0 ? 0 : (_userPage - 1) * _userPageSize + 1;
    private int OysterFrom => _oysterTotalCount == 0 ? 0 : (_oysterPage - 1) * _oysterPageSize + 1;
    private int CorpFrom => _corpTotalCount == 0 ? 0 : (_corpPage - 1) * _corpPageSize + 1;
    private int UserTo => Math.Min(_userPage * _userPageSize, _userTotalCount);
    private int OysterTo => Math.Min(_oysterPage * _oysterPageSize, _oysterTotalCount);
    private int CorpTo => Math.Min(_corpPage * _corpPageSize, _corpTotalCount);

    public record RegistrationItem(
        string Code, string ImageUrl, string FullName, string Username, string Email, string Gender,
        string CompanyName, string Position, string Status, string Vip, string DateCreated);

        // ── REGISTRATION DIALOG STATE ──
private bool _showAddRegDialog = false;
private bool _showEditRegDialog = false;
private RegistrationItem? _editingReg;

private string _regImageUrl = "";
private string _regEmployeeId = "";
private string _regEmail = "";
private string _regFirstName = "";
private string _regLastName = "";
private string _regUsername = "";
private string _regPassword = "";
private string _regPosition = "";
private string _regVip = "No";
private string _regGender = "";
private string _regCompany = "";
private string _regMembershipTier = "";

private void OpenAddReg()
{
    _regImageUrl = ""; _regEmployeeId = ""; _regEmail = "";
    _regFirstName = ""; _regLastName = ""; _regUsername = "";
    _regPassword = ""; _regPosition = ""; _regVip = "No";
    _regGender = ""; _regCompany = ""; _regMembershipTier = "";
    _editingReg = null;
    _showAddRegDialog = true;
}

private void OpenEditReg(RegistrationItem item)
{
    _editingReg = item;
    _regImageUrl = item.ImageUrl ?? "";
    _regEmail = item.Email;
    _regUsername = item.Username;
    _regPosition = item.Position;
    _regVip = item.Vip;
    _regGender = item.Gender;
    _regCompany = item.CompanyName;
    var parts = item.FullName.Split(' ', 2);
    _regFirstName = parts.Length > 0 ? parts[0] : "";
    _regLastName = parts.Length > 1 ? parts[1] : "";
    _regEmployeeId = item.Code;
    _regPassword = "";
    _regMembershipTier = "";
    _showEditRegDialog = true;
}

private void CloseRegDialog()
{
    _showAddRegDialog = false;
    _showEditRegDialog = false;
    _editingReg = null;
}

private void SaveRegDialog()
{
    var fullName = $"{_regFirstName} {_regLastName}".Trim();
    var list = _activeTab == "oyster" ? _oysterItems
             : _activeTab == "corporate" ? _corpItems
             : _userItems;

    if (_showEditRegDialog && _editingReg != null)
    {
        var index = list.IndexOf(_editingReg);
        if (index >= 0)
        {
            list[index] = _editingReg with
            {
                ImageUrl = _regImageUrl,
                FullName = fullName,
                Username = _regUsername,
                Email = _regEmail,
                Gender = _regGender,
                CompanyName = _regCompany,
                Position = _regPosition,
                Vip = _regVip
            };
        }
    }
    else
    {
        var prefix = _activeTab == "oyster" ? "OYS"
                   : _activeTab == "corporate" ? "CRP" : "USR";
        list.Insert(0, new RegistrationItem(
            $"{prefix}-{(list.Count + 1):D3}",
            string.IsNullOrEmpty(_regImageUrl) ? "" : _regImageUrl,
            fullName, _regUsername, _regEmail, _regGender,
            _regCompany, _regPosition, "Active", _regVip,
            DateTime.Now.ToString("MM/dd/yyyy")
        ));
    }
    CloseRegDialog();
}

private async Task OnRegImageSelected(InputFileChangeEventArgs e)
{
    var file = e.File;
    var buffer = new byte[file.Size];
    await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
    _regImageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
}
