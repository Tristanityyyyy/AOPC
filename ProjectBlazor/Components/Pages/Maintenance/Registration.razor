    // ── Filtered + sorted + paged ──────────────────────────────
    private IEnumerable<RegistrationItem> FilteredUserItems => GetFiltered(_userItems, _userSearch, _userSortCol, _userSortAsc, _userPage, _userPageSize, out _userTotalCount);
    private IEnumerable<RegistrationItem> FilteredOysterItems => GetFiltered(_oysterItems, _oysterSearch, _oysterSortCol, _oysterSortAsc, _oysterPage, _oysterPageSize, out _oysterTotalCount);
    private IEnumerable<RegistrationItem> FilteredCorpItems => GetFiltered(_corpItems, _corpSearch, _corpSortCol, _corpSortAsc, _corpPage, _corpPageSize, out _corpTotalCount);

    private IEnumerable<RegistrationItem> GetFiltered(List<RegistrationItem> src, string search, string sortCol, bool sortAsc, int page, int pageSize, out int total)
    {
        var q = src.Where(x => string.IsNullOrEmpty(search) ||
            x.FullName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Username.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Email.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.CompanyName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
            x.Position.Contains(search, StringComparison.OrdinalIgnoreCase));

        q = (sortCol, sortAsc) switch
        {
            ("Username", true) => q.OrderBy(x => x.Username),
            ("Username", false) => q.OrderByDescending(x => x.Username),
            ("Email", true) => q.OrderBy(x => x.Email),
            ("Email", false) => q.OrderByDescending(x => x.Email),
            ("Gender", true) => q.OrderBy(x => x.Gender),
            ("Gender", false) => q.OrderByDescending(x => x.Gender),
            ("CompanyName", true) => q.OrderBy(x => x.CompanyName),
            ("CompanyName", false) => q.OrderByDescending(x => x.CompanyName),
            ("Position", true) => q.OrderBy(x => x.Position),
            ("Position", false) => q.OrderByDescending(x => x.Position),
            ("Status", true) => q.OrderBy(x => x.Status),
            ("Status", false) => q.OrderByDescending(x => x.Status),
            ("Vip", true) => q.OrderBy(x => x.Vip),
            ("Vip", false) => q.OrderByDescending(x => x.Vip),
            ("DateCreated", true) => q.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => q.OrderByDescending(x => x.DateCreated),
            _ => q.OrderBy(x => x.FullName)
        };

        total = q.Count();
        return q.Skip((page - 1) * pageSize).Take(pageSize);
    }

    // ── Pagination ─────────────────────────────────────────────
    private int UserTotalPages => (int)Math.Ceiling(_userTotalCount / (double)_userPageSize);
    private int OysterTotalPages => (int)Math.Ceiling(_oysterTotalCount / (double)_oysterPageSize);
    private int CorpTotalPages => (int)Math.Ceiling(_corpTotalCount / (double)_corpPageSize);
    private int UserFrom => _userTotalCount == 0 ? 0 : (_userPage - 1) * _userPageSize + 1;
    private int OysterFrom => _oysterTotalCount == 0 ? 0 : (_oysterPage - 1) * _oysterPageSize + 1;
    private int CorpFrom => _corpTotalCount == 0 ? 0 : (_corpPage - 1) * _corpPageSize + 1;
    private int UserTo => Math.Min(_userPage * _userPageSize, _userTotalCount);
    private int OysterTo => Math.Min(_oysterPage * _oysterPageSize, _oysterTotalCount);
    private int CorpTo => Math.Min(_corpPage * _corpPageSize, _corpTotalCount);

    public record RegistrationItem(
        string Code, string FullName, string Username, string Email, string Gender,
        string CompanyName, string Position, string Status, string Vip, string DateCreated);
