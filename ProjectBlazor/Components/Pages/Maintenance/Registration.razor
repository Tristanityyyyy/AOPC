@page "/maintenance/registration"
@rendermode InteractiveServer

<h3 class="text-2xl font-medium mb-4" style="color: #0D1B2A;">Registration</h3>

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "user"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "user" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        👥 User Registration
    </button>
    <button @onclick='() => _activeTab = "oyster"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "oyster" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        👥 Oyster Admin Registration
    </button>
    <button @onclick='() => _activeTab = "corporate"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "corporate" ? "border-color:#C9A84C; color:#C9A84C;" : "border-color:transparent; color:#6b7280;")">
        🏢 Corporate Admin Registration
    </button>
</div>

@* ── USER REGISTRATION ── *@
@if (_activeTab == "user")
{
    <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="background: linear-gradient(135deg, #0D1B2A 0%, #134E4A 90%, #0F766E 100%);">
                    <h4 class="text-sm font-medium text-white">User Registration</h4>
                </div>
                @ControlsRow1()
                @ControlsRow2("_userSearch", "_userPageSize", "_userPage")
                <div class="mb-3 px-1">
                    <button class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background:#C9A84C;">
                        + Add New
                    </button>
                </div>
                <div class="overflow-y-auto" style="max-height:600px;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" style="width: 18%;" @onclick='() => SortUser("FullName")'>Full Name <span class="text-gray-400">@SortIconUser("FullName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Username")'>Username <span class="text-gray-400">@SortIconUser("Username")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Email")'>Email <span class="text-gray-400">@SortIconUser("Email")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Gender")'>Gender <span class="text-gray-400">@SortIconUser("Gender")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("CompanyName")'>Company Name <span class="text-gray-400">@SortIconUser("CompanyName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Position")'>Position <span class="text-gray-400">@SortIconUser("Position")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Status")'>Status <span class="text-gray-400">@SortIconUser("Status")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("Vip")'>VIP <span class="text-gray-400">@SortIconUser("Vip")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortUser("DateCreated")'>Date Created <span class="text-gray-400">@SortIconUser("DateCreated")</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredUserItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2" style="height: 72px;">
                                        <div class="relative w-full" style="height: 72px;">
                                            <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 4px;">
                                                @item.Code
                                            </div>
                                            <div class="absolute left-0 flex items-center gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 14px;">
                                                <div class="w-8 h-8 rounded-full overflow-hidden flex items-center justify-center bg-gray-200">
                                                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:16px; color:#9ca3af;" />
                                                </div>
                                                <div class="font-medium text-gray-800 text-xs">@item.FullName</div>
                                            </div>
                                            <div class="absolute left-0 flex gap-2 pt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 42px;">
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:#C9A84C;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:13px;" Color="Color.Inherit" /> Edit
                                                </button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:13px;" Color="Color.Inherit" /> Delete
                                                </button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:#C9A84C;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" /> Send Email
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 align-middle" style="height: 72px;">@item.Username</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Gender</td>
                                    <td class="py-2 px-2 text-gray-600">@item.CompanyName</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Position</td>
                                    <td class="py-2 px-2">
                                        <span class="@(item.Status == "Active" ? "text-green-600 font-medium" : "text-red-500")">@item.Status</span>
                                    </td>
                                    <td class="py-2 px-2">
                                        <span class="@(item.Vip == "Yes" ? "text-amber-600 font-medium" : "text-gray-400")">@item.Vip</span>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @UserFrom to @UserTo of @_userTotalCount entries</span>
                    <Pagination CurrentPage="_userPage" TotalPages="UserTotalPages" SetPageAction="p => _userPage = p" />
                </div>
            </div>
        </div>
    </div>
}

