@code {
    private string _activeTab = "user";
    private string? _uploadedFileName;

    // ── Per-tab state ──────────────────────────────────────────
    private string _userSearch = ""; private int _userPageSize = 10; private int _userPage = 1; private int _userTotalCount = 0; private string _userSortCol = "FullName"; private bool _userSortAsc = true;
    private string _oysterSearch = ""; private int _oysterPageSize = 10; private int _oysterPage = 1; private int _oysterTotalCount = 0; private string _oysterSortCol = "FullName"; private bool _oysterSortAsc = true;
    private string _corpSearch = ""; private int _corpPageSize = 10; private int _corpPage = 1; private int _corpTotalCount = 0; private string _corpSortCol = "FullName"; private bool _corpSortAsc = true;

    private async Task HandleFileUpload(InputFileChangeEventArgs e) { _uploadedFileName = e.File.Name; await Task.CompletedTask; }

    // ── Shared render fragments ────────────────────────────────
    private RenderFragment ControlsRow1() =>
    @<div class="flex items-center justify-between mb-3 px-1">
        <div class="flex items-center gap-2">
            <button class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium" style="background:#C9A84C;">☰ Filter</button>
            <button class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium" style="background:#C9A84C;">✉ Bulk Email</button>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-xs text-gray-600 font-medium">Import Excel File:</span>
            <InputFile id="regFileInput" OnChange="HandleFileUpload" accept=".xlsx,.xls" class="hidden" />
            <label for="regFileInput" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-300 bg-white text-xs text-gray-600 cursor-pointer hover:bg-gray-50 transition">
                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Style="font-size:13px;" />
                @(_uploadedFileName ?? "Choose File")
            </label>
            <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-xs border-none cursor-pointer font-medium" style="background:#C9A84C;">
                <MudIcon Icon="@Icons.Material.Filled.Upload" Style="font-size:13px;" /> Upload
            </button>
            <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs border border-gray-300 cursor-pointer bg-white text-gray-600 hover:bg-gray-50 transition">
                <MudIcon Icon="@Icons.Material.Filled.Download" Style="font-size:13px;" /> Download Template
            </button>
        </div>
    </div>;

    private RenderFragment ControlsRow2(string searchField, string pageSizeField, string pageField) =>
    @<div class="flex items-center justify-between mb-3 px-1">
        <div class="flex items-center gap-2 text-xs text-gray-600">
            <select class="border border-gray-300 rounded px-2 py-1 text-xs"
                    value="@GetPageSize(pageSizeField)"
                    @onchange="e => SetPageSize(pageSizeField, int.Parse(e.Value!.ToString()!))">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <span>entries per page</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-600">
            <span class="font-medium">Search:</span>
            <input type="text" value="@GetSearch(searchField)"
                   @oninput="e => SetSearch(searchField, e.Value!.ToString()!)"
                   class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                   placeholder="Type to search..." />
        </div>
    </div>;

    // ── Search/PageSize helpers ────────────────────────────────
    private string GetSearch(string f) => f == "_userSearch" ? _userSearch : f == "_oysterSearch" ? _oysterSearch : _corpSearch;
    private void SetSearch(string f, string v) { if (f == "_userSearch") { _userSearch = v; _userPage = 1; } else if (f == "_oysterSearch") { _oysterSearch = v; _oysterPage = 1; } else { _corpSearch = v; _corpPage = 1; } }
    private int GetPageSize(string f) => f == "_userPageSize" ? _userPageSize : f == "_oysterPageSize" ? _oysterPageSize : _corpPageSize;
    private void SetPageSize(string f, int v) { if (f == "_userPageSize") { _userPageSize = v; _userPage = 1; } else if (f == "_oysterPageSize") { _oysterPageSize = v; _oysterPage = 1; } else { _corpPageSize = v; _corpPage = 1; } }

    // ── Sort helpers ───────────────────────────────────────────
    private void SortUser(string col) { if (_userSortCol == col) _userSortAsc = !_userSortAsc; else { _userSortCol = col; _userSortAsc = true; } _userPage = 1; }
    private void SortOyster(string col) { if (_oysterSortCol == col) _oysterSortAsc = !_oysterSortAsc; else { _oysterSortCol = col; _oysterSortAsc = true; } _oysterPage = 1; }
    private void SortCorp(string col) { if (_corpSortCol == col) _corpSortAsc = !_corpSortAsc; else { _corpSortCol = col; _corpSortAsc = true; } _corpPage = 1; }
    private string SortIconUser(string col) => _userSortCol == col ? (_userSortAsc ? "↑" : "↓") : "⇅";
    private string SortIconOyster(string col) => _oysterSortCol == col ? (_oysterSortAsc ? "↑" : "↓") : "⇅";
    private string SortIconCorp(string col) => _corpSortCol == col ? (_corpSortAsc ? "↑" : "↓") : "⇅";

