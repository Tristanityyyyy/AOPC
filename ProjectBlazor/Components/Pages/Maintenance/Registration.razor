                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @OysterFrom to @OysterTo of @_oysterTotalCount entries</span>
                    <div class="flex items-center gap-1">
                        <Pagination CurrentPage="_oysterPage" TotalPages="OysterTotalPages" SetPageAction="p => _oysterPage = p" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── CORPORATE ADMIN REGISTRATION ── *@
@if (_activeTab == "corporate")
{
    <div class="grid grid-cols-12 gap-4">
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="@ThemeConfig.Styles.HeaderGradient">
                    <h4 class="text-sm font-medium text-white">Corporate Admin Registration</h4>
                </div>
                @if (_activeTab == "user")
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: true)
                }
                else if (_activeTab == "oyster")
                {
                    @ControlsRow1(showFilter: false, showBulkEmail: false)
                }
                else
                {
                    @ControlsRow1(showFilter: true, showBulkEmail: false)
                }
                @ControlsRow2("_corpSearch", "_corpPageSize", "_corpPage")
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddReg" class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium" style="background:@ThemeConfig.Colors.Primary;">+ Add New</button>
                </div>
                <div class="overflow-y-auto" style="max-height:600px;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" style="width: 18%;" @onclick='() => SortCorp("FullName")'>Full Name <span class="text-gray-400">@SortIconCorp("FullName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Username")'>Username <span class="text-gray-400">@SortIconCorp("Username")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Email")'>Email <span class="text-gray-400">@SortIconCorp("Email")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Gender")'>Gender <span class="text-gray-400">@SortIconCorp("Gender")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("CompanyName")'>Company Name <span class="text-gray-400">@SortIconCorp("CompanyName")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Position")'>Position <span class="text-gray-400">@SortIconCorp("Position")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Status")'>Status <span class="text-gray-400">@SortIconCorp("Status")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("Vip")'>VIP <span class="text-gray-400">@SortIconCorp("Vip")</span></th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 whitespace-nowrap cursor-pointer select-none" @onclick='() => SortCorp("DateCreated")'>Date Created <span class="text-gray-400">@SortIconCorp("DateCreated")</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, index) in FilteredCorpItems.Select((x, i) => (x, i)))
                            {
                                <tr class="border-b border-gray-100 hover:bg-amber-50 group @(index % 2 == 0 ? "bg-white" : "bg-gray-50")">
                                    <td class="py-2 px-2" style="height: 72px;">
                                        <div class="relative w-full" style="height: 72px;">
                                            <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top: 4px;">@item.Code</div>
                                            <div class="absolute left-0 flex items-center gap-2 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 14px;">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" class="w-8 h-8 rounded-full object-cover" alt="@item.FullName" />
                                                }
                                                else
                                                {
                                                    <div class="w-8 h-8 rounded-full overflow-hidden flex items-center justify-center bg-gray-200">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="@($"font-size:16px; color:{ThemeConfig.Colors.Text.Muted};")" />
                                                    </div>
                                                }
                                                <div class="font-medium text-gray-800 text-xs">@item.FullName</div>
                                            </div>
                                            <div class="absolute left-0 flex gap-2 pt-1 transition-transform duration-200 translate-y-0 group-hover:translate-y-3" style="top: 50px;">
                                                <button @onclick="() => OpenEditReg(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:13px;" Color="Color.Inherit" /> Edit</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500"><MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size:13px;" Color="Color.Inherit" /> Delete</button>
                                                <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color:@ThemeConfig.Colors.Primary;"><MudIcon Icon="@Icons.Material.Filled.Email" Style="font-size:13px;" Color="Color.Inherit" /> Send Email</button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 align-middle" style="height: 72px;">@item.Username</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Email</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Gender</td>
                                    <td class="py-2 px-2 text-gray-600">@item.CompanyName</td>
                                    <td class="py-2 px-2 text-gray-600">@item.Position</td>
                                    <td class="py-2 px-2"><span class="@(item.Status == "Active" ? "text-green-600 font-medium" : "text-red-500")">@item.Status</span></td>
                                    <td class="py-2 px-2"><span class="@(item.Vip == "Yes" ? "text-amber-600 font-medium" : "text-gray-400")">@item.Vip</span></td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">Showing @CorpFrom to @CorpTo of @_corpTotalCount entries</span>
                    <div class="flex items-center gap-1">
                        <Pagination CurrentPage="_corpPage" TotalPages="CorpTotalPages" SetPageAction="p => _corpPage = p" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@* ── Add/Edit Registration Dialog ── *@
@if (_showAddRegDialog || _showEditRegDialog)
{
    var isEdit = _showEditRegDialog;
    var isOyster = _activeTab == "oyster";
    var isCorporate = _activeTab == "corporate";
    var isUser = _activeTab == "user";

    var dialogTitle = isEdit
        ? (isOyster ? "Edit Oyster Admin" : isCorporate ? "Edit Corporate Admin" : "Edit User")
        : (isOyster ? "Oyster Admin Registration Form" : isCorporate ? "Corporate Admin Registration Form" : "User Registration Form");

    <div class="fixed inset-0 flex items-start justify-center z-[100]"
         style="background: rgba(0,0,0,0.4); padding: 60px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl flex flex-col"
             style="max-height: calc(100vh - 80px);">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="@ThemeConfig.Styles.HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@dialogTitle</span>
                </div>
                <button @onclick="CloseRegDialog"
                        class="w-7 h-7 flex items-center justify-center rounded text-white text-xs
                               font-bold cursor-pointer border-none"
                       style="@($"background:{ThemeConfig.Colors.Primary}")">
                    ✕
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-4">

                @* Profile Image Upload *@
                <div class="flex items-center gap-6 mb-2">
                    <div class="w-24 h-24 rounded-full border-2 border-gray-200 overflow-hidden
                                flex-shrink-0 flex items-center justify-center bg-gray-100">
                        @if (!string.IsNullOrEmpty(_regImageUrl))
                        {
                            <img src="@_regImageUrl" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person"Style="@($"font-size:40px; color:{ThemeConfig.Colors.Text.LightGray};")" />
                        }
                    </div>
                    <label class="flex items-center gap-2 px-6 py-2 rounded-lg text-white text-xs
                                  font-medium cursor-pointer"
                           style="background:@ThemeConfig.Colors.Primary;">
                        <MudIcon Icon="@Icons.Material.Filled.Upload"
                                 Style="font-size:14px;" Color="Color.Inherit" />
                        Upload Image
                        <InputFile OnChange="OnRegImageSelected" accept="image/*" class="hidden" />
                    </label>
                </div>

                @* Employee ID + Email *@
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-700">Employee ID</label>
                        <input type="text" @bind="_regEmployeeId"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                      focus:outline-none focus:border-amber-400" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-700">Email</label>
                        <input type="email" @bind="_regEmail"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                      focus:outline-none focus:border-amber-400" />
                    </div>
                </div>

                @* First Name + Last Name *@
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-700">First Name</label>
                        <input type="text" @bind="_regFirstName"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                      focus:outline-none focus:border-amber-400" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-700">Last Name</label>
                        <input type="text" @bind="_regLastName"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                      focus:outline-none focus:border-amber-400" />
                    </div>
                </div>

                @* Username + Password (Oyster) OR Username + Position (User/Corporate) *@
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-700">Username</label>
                        <input type="text" @bind="_regUsername"
                               class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                      focus:outline-none focus:border-amber-400" />
                    </div>
                    @if (isOyster)
                    {
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">Admin Password</label>
                            <input type="password" @bind="_regPassword"
                                   class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                          focus:outline-none focus:border-amber-400" />
                        </div>
                    }
                    else
                    {
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">Position</label>
                            <select @bind="_regPosition"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                           focus:outline-none focus:border-amber-400 bg-white">
                                <option value="">-Select Position-</option>
                                @foreach (var p in AllPositions)
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                        </div>
                    }
                </div>

                @* User/Corporate only: VIP Status + Gender *@
                @if (!isOyster)
                {
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">VIP Status</label>
                            <select @bind="_regVip"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                           focus:outline-none focus:border-amber-400 bg-white">
                                <option value="No">No</option>
                                <option value="Yes">Yes</option>
                            </select>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">Gender</label>
                            <select @bind="_regGender"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                           focus:outline-none focus:border-amber-400 bg-white">
                                <option value="">-Select Gender-</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                    </div>

                    @* Corporate Name + Membership Tier *@
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">Corporate Name</label>
                            <select @bind="_regCompany"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                           focus:outline-none focus:border-amber-400 bg-white">
                                <option value="">-Select Corporate-</option>
                                @foreach (var c in AllCompanies)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-gray-700">Membership Tier</label>
                            <select @bind="_regMembershipTier"
                                    class="border border-gray-300 rounded-lg px-3 py-2 text-xs
                                           focus:outline-none focus:border-amber-400 bg-white">
                                <option value="">-Select Tier-</option>
                                <option value="EXCLUSIVE - VIP">EXCLUSIVE - VIP</option>
                                <option value="PLATINUM">PLATINUM</option>
                                <option value="EXCLUSIVE">EXCLUSIVE</option>
                                <option value="EXCLUSIVE OMAN">EXCLUSIVE OMAN</option>
                                <option value="BRONZE">BRONZE</option>
                            </select>
                        </div>
                    </div>
                }

            </div>

            @* Footer *@
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-100 flex-shrink-0">
                <button @onclick="CloseRegDialog"
                        class="text-xs cursor-pointer bg-transparent border-none underline
                               hover:text-gray-700"
                        style="color:@ThemeConfig.Colors.Primary;">
                    Cancel
                </button>
                <button @onclick="SaveRegDialog"
                        class="px-6 py-2 text-xs rounded-lg text-white font-medium border-none cursor-pointer"
                        style="@ThemeConfig.Styles.ButtonPrimary">
                    Submit
                </button>
            </div>

        </div>
    </div>
}
@code {
