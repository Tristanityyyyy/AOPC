        (_tierSortCol, _tierSortAsc) switch
        {
            ("Name", true) => items.OrderBy(x => x.Name),
            ("Name", false) => items.OrderByDescending(x => x.Name),
            ("Description", true) => items.OrderBy(x => x.Description),
            ("Description", false) => items.OrderByDescending(x => x.Description),
            ("DateStarted", true) => items.OrderBy(x => x.DateStarted),
            ("DateStarted", false) => items.OrderByDescending(x => x.DateStarted),
            ("DateEnded", true) => items.OrderBy(x => x.DateEnded),
            ("DateEnded", false) => items.OrderByDescending(x => x.DateEnded),
            ("UserCount", true) => items.OrderBy(x => x.UserCount),
            ("UserCount", false) => items.OrderByDescending(x => x.UserCount),
            ("VipCount", true) => items.OrderBy(x => x.VipCount),
            ("VipCount", false) => items.OrderByDescending(x => x.VipCount),
            ("DateCreated", true) => items.OrderBy(x => x.DateCreated),
            ("DateCreated", false) => items.OrderByDescending(x => x.DateCreated),
            _ => items
        };

    private int TierTotalPages => (int)Math.Ceiling(_tierItems.Count / (double)_tierPageSize);
    private int TierFrom => (_tierPage - 1) * _tierPageSize + 1;
    private int TierTo => Math.Min(_tierPage * _tierPageSize, _tierItems.Count);

    private string _addPrivImageUrl = "";
    private string _editPrivImageUrl = "";

    private async Task OnAddImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        _addPrivImageUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private async Task OnEditImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        _editPrivImageUrl = $"data:{file.ContentType};base64,{base64}";
    }
    public record MembershipTierItem(string Name, string Description, string DateStarted, string DateEnded, int UserCount, int VipCount, string DateCreated);

    // ── TIER DIALOG STATE ──
    private bool _showAddTierDialog = false;
    private bool _showEditTierDialog = false;
    private MembershipTierItem? _editingTier;

    // Tier form fields
    private string _tierName = "";
    private string _tierDescription = "";
    private DateTime _tierDateStarted = DateTime.Today;
    private DateTime _tierDateEnded = DateTime.Today;
    private int _tierUserCount = 0;
    private int _tierVipCount = 0;
    private string _tierCountry = "";
    private string _tierTextCardColor = "#000000";
    private string _tierMembershipCardUrl = "";
    private string _tierVipCardUrl = "";
    private string _tierQrFrameUrl = "";
    private string _tierVipBadgeUrl = "";

    private void OpenAddTier()
    {
        _tierName = ""; _tierDescription = ""; _tierCountry = "";
        _tierTextCardColor = "#000000";
        _tierDateStarted = DateTime.Today; _tierDateEnded = DateTime.Today;
        _tierUserCount = 0; _tierVipCount = 0;
        _tierMembershipCardUrl = ""; _tierVipCardUrl = "";
        _tierQrFrameUrl = ""; _tierVipBadgeUrl = "";
        _showAddTierDialog = true;
    }

    private void OpenEditTier(MembershipTierItem item)
    {
        _editingTier = item;
        _tierName = item.Name;
        _tierDescription = item.Description;
        DateTime.TryParse(item.DateStarted, out var ds);
        DateTime.TryParse(item.DateEnded, out var de);
        _tierDateStarted = ds == default ? DateTime.Today : ds;
        _tierDateEnded = de == default ? DateTime.Today : de;
        _tierUserCount = item.UserCount;
        _tierVipCount = item.VipCount;
        _tierCountry = ""; _tierTextCardColor = "#000000";
        _tierMembershipCardUrl = ""; _tierVipCardUrl = "";
        _tierQrFrameUrl = ""; _tierVipBadgeUrl = "";
        _showEditTierDialog = true;
    }

    private void CloseTierDialog()
    {
        _showAddTierDialog = false;
        _showEditTierDialog = false;
        _editingTier = null;
    }

    private void SaveTierDialog()
    {
        if (_showEditTierDialog && _editingTier != null)
        {
            var index = _tierItems.IndexOf(_editingTier);
            if (index >= 0)
            {
                _tierItems[index] = _editingTier with
                {
                    Name = _tierName,
                    Description = _tierDescription,
                    DateStarted = _tierDateStarted.ToString("MM/dd/yyyy"),
                    DateEnded = _tierDateEnded.ToString("MM/dd/yyyy"),
                    UserCount = _tierUserCount,
                    VipCount = _tierVipCount
                };
            }
        }
        else
        {
            _tierItems.Insert(0, new MembershipTierItem(
                _tierName, _tierDescription,
                _tierDateStarted.ToString("MM/dd/yyyy"),
                _tierDateEnded.ToString("MM/dd/yyyy"),
                _tierUserCount, _tierVipCount,
                DateTime.Now.ToString("MM/dd/yyyy")));
        }
        CloseTierDialog();
    }

    private async Task OnTierImageSelected(InputFileChangeEventArgs e, int slot)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        switch (slot)
        {
            case 0: _tierMembershipCardUrl = base64; break;
            case 1: _tierVipCardUrl = base64; break;
            case 2: _tierQrFrameUrl = base64; break;
            case 3: _tierVipBadgeUrl = base64; break;
        }
    }


