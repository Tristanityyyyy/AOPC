@page "/maintenance/membershipprivilege"
@rendermode InteractiveServer
@inject IJSRuntime JS
@using ProjectBlazor.Components

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Membership & Privilege</h3>

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "privileges"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "privileges" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        Privileges Maintenance
    </button>
    <button @onclick='() => _activeTab = "tier"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "tier" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        Membership Tier Maintenance
    </button>
</div>

<div class="grid grid-cols-12 gap-4">

    @if (_activeTab == "privileges")
    {
        @* ── Privileges Maintenance ── *@
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">

                @* Dark header *@
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="@ThemeConfig.Styles.HeaderGradient">
                    <h4 class="text-sm font-medium text-white">Privileges Maintenance</h4>
                </div>

                @* Controls Row *@
                <div class="flex items-center justify-between mb-4 px-1">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <select value="@_privPageSize" @onchange="e => { _privPageSize = int.Parse(e.Value.ToString()); _privPage = 1; }"
                                class="border border-gray-300 rounded px-2 py-1 text-xs">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <span>entries per page</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <span class="font-medium">Search:</span>
                        <input type="text" @bind="_privSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                               placeholder="Type to search..." />
                    </div>
                </div>

                @* Add New *@
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddPrivilege"
                            class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: @ThemeConfig.Colors.Primary;">
                        + Add New
                    </button>
                </div>

                @* Table *@
                <div style="height:480px; overflow-y:auto;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 w-48 cursor-pointer select-none"
                                    @onclick='() => SortPriv("Name")'>
                                    Name <span class="text-gray-400">@PrivSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortPriv("Description")'>
                                    Description <span class="text-gray-400">@PrivSortIcon("Description")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortPriv("Validity")'>
                                    Validity <span class="text-gray-400">@PrivSortIcon("Validity")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortPriv("NoExpiry")'>
                                    No Expiry <span class="text-gray-400">@PrivSortIcon("NoExpiry")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortPriv("BusinessTypeName")'>
                                    Business Type Name <span class="text-gray-400">@PrivSortIcon("BusinessTypeName")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortPriv("DateCreated")'>
                                    Date Created <span class="text-gray-400">@PrivSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FilteredPrivItems)
                            {
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-2 px-2">
                                        <div class="flex items-center gap-2">
                                            <img src="@item.ImageUrl" class="w-10 h-10 rounded object-cover bg-gray-100" alt="@item.Name" />
                                            <div>
                                                <div class="font-medium text-gray-800">@item.Name</div>
                                                <div class="flex gap-2 mt-1">
                                                    <button @onclick="() => OpenEditPrivilege(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Edit
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                                        <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Duplicate
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Delete
                                                    </button>
                                                    <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Text.Primary;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 14px;" Color="Color.Inherit" />
                                                        Select Vendor
                                                    </button>

                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 max-w-sm">
                                        <div class="line-clamp-3">@item.Description</div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.Validity</td>
                                    <td class="py-2 px-2 text-gray-600">@item.NoExpiry</td>
                                    <td class="py-2 px-2 text-gray-600">@item.BusinessTypeName</td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Footer *@
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">
                        Showing @PrivFrom to @PrivTo of @_privItems.Count entries
                    </span>
                    <div class="flex items-center gap-1">
                        @RenderPagination(_privPage, PrivTotalPages, (p) => _privPage = p)
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* ── Membership Tier Maintenance ── *@
        <div class="col-span-12">
            <div class="bg-white rounded-lg border border-gray-200 shadow-md flex flex-col p-4">

                @* Dark header *@
                <div class="flex items-center justify-between -mx-4 -mt-4 px-4 py-3 rounded-t-lg mb-4"
                     style="@ThemeConfig.Styles.HeaderGradient">
                    <h4 class="text-sm font-medium text-white">Membership Tier Maintenance</h4>
                </div>

                @* Controls Row *@
                <div class="flex items-center justify-between mb-4 px-1">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <select value="@_tierPageSize" @onchange="e => { _tierPageSize = int.Parse(e.Value.ToString()); _tierPage = 1; }"
                                class="border border-gray-300 rounded px-2 py-1 text-xs">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <span>entries per page</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                        <span class="font-medium">Search:</span>
                        <input type="text" @bind="_tierSearch" @bind:event="oninput"
                               class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-44"
                               placeholder="Type to search..." />
                    </div>
                </div>

                @* Add New *@
                <div class="mb-3 px-1">
                    <button @onclick="OpenAddTier" class="flex items-center gap-1 px-4 py-1.5 rounded-full text-white text-xs border-none cursor-pointer font-medium"
                            style="background: @ThemeConfig.Colors.Primary;">
                        + Add New
                    </button>
                </div>

                @* Table *@
                <div style="height:480px; overflow-y:auto;">
                    <table class="w-full text-xs">
                        <thead style="position:sticky; top:0; background:white; z-index:1;">
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("Name")'>
                                    Name <span class="text-gray-400">@TierSortIcon("Name")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("Description")'>
                                    Description <span class="text-gray-400">@TierSortIcon("Description")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("DateStarted")'>
                                    Date Started <span class="text-gray-400">@TierSortIcon("DateStarted")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("DateEnded")'>
                                    Date Ended <span class="text-gray-400">@TierSortIcon("DateEnded")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("UserCount")'>
                                    User Count <span class="text-gray-400">@TierSortIcon("UserCount")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("VipCount")'>
                                    VIP Count <span class="text-gray-400">@TierSortIcon("VipCount")</span>
                                </th>
                                <th class="text-left py-2 px-2 font-semibold text-gray-700 cursor-pointer select-none"
                                    @onclick='() => SortTier("DateCreated")'>
                                    Date Created <span class="text-gray-400">@TierSortIcon("DateCreated")</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FilteredTierItems)
                            {
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-2 px-2">
                                        <div class="font-medium text-gray-800">@item.Name</div>
                                        <div class="flex gap-2 mt-1">
                                            <button @onclick="() => OpenEditTier(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Edit
                                            </button>
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" />
                                                Delete
                                            </button>
                                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 14px;" Color="Color.Inherit" />
                                                View
                                            </button>
                                        </div>
                                    </td>
                                    <td class="py-2 px-2 text-gray-600">@item.Description</td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateStarted</td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateEnded</td>
                                    <td class="py-2 px-2 text-gray-600">@item.UserCount</td>
                                    <td class="py-2 px-2 text-gray-600">@item.VipCount</td>
                                    <td class="py-2 px-2 text-gray-600 whitespace-nowrap">@item.DateCreated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Footer *@
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                    <span class="text-xs text-gray-500">
                        Showing @TierFrom to @TierTo of @_tierItems.Count entries
                    </span>
                    <div class="flex items-center gap-1">
                        @RenderPagination(_tierPage, TierTotalPages, (p) => _tierPage = p)
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@* ── Add/Edit Privilege Dialog ── *@
@if (_showAddPrivilegeDialog || _showEditPrivilegeDialog)
{
    var isEdit = _showEditPrivilegeDialog;
    <div class="fixed inset-0 flex items-start justify-center z-[100]" style="background: rgba(0,0,0,0.4); padding: 70px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl flex flex-col" style="max-height: calc(100vh - 90px);">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="@ThemeConfig.Styles.HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@(isEdit ? "Edit Privilege" : "Add Privilege")</span>
                </div>
                <button @onclick="ClosePrivilegeDialog"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-5">

                @* Image Upload *@
                <div class="flex items-center gap-6 mb-2">
                    <img src="@(string.IsNullOrEmpty(_privImageUrl) ? "/images/default.jpg" : _privImageUrl)"
                         class="w-24 h-24 rounded-full object-cover border-2 border-gray-200 bg-gray-100" />
                    <label class="flex items-center gap-2 px-5 py-2 rounded-lg text-white text-xs font-medium cursor-pointer"
                           style="background:@ThemeConfig.Colors.Primary;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <rect x="3" y="3" width="18" height="18" rx="2" stroke="white" stroke-width="2" fill="none" />
                            <circle cx="8.5" cy="8.5" r="1.5" fill="white" />
                            <polyline points="21,15 16,10 5,21" stroke="white" stroke-width="2" stroke-linejoin="round" />
                        </svg>
                        Upload Image
                        <InputFile OnChange="OnPrivImageSelected" accept="image/*" class="hidden" />
                    </label>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
                    <input type="text" @bind="_privName"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Description</label>
                    <textarea @bind="_privDescription" rows="4"
                              class="w-full border border-gray-300 rounded px-3 py-2 text-xs resize-y focus:outline-none"></textarea>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Validity</label>
                    <input type="date" @bind="_privValidityDate"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Business Type Name <span class="text-red-500">*</span></label>
                    <select @bind="_privBusinessTypeName"
                            class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                        <option value="">-Select Business Type-</option>
                        <option value="Health">Health</option>
                        <option value="Rooms & Suites">Rooms & Suites</option>
                        <option value="Food & Beverages">Food & Beverages</option>
                        <option value="Access to co-working spaces">Access to co-working spaces</option>
                    </select>
                </div>

                @* Terms and Conditions *@
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Terms and Conditions <span class="text-red-500">*</span></label>
                    <div class="border border-gray-300 rounded-lg overflow-hidden focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-100">
                        <div id="privTermsToolbar" class="flex items-center gap-0.5 px-2 py-1.5 bg-gray-50 border-b border-gray-200 flex-wrap">
                            @RichToolbarButtons()
                        </div>
                        <div id="privTermsEditor"
                             class="min-h-[100px] max-h-[200px] overflow-y-auto px-3 py-2 text-xs text-gray-700 outline-none leading-relaxed"
                             contenteditable="true">
                        </div>
                    </div>
                </div>

                @* Mechanics *@
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Mechanics <span class="text-red-500">*</span></label>
                    <div class="border border-gray-300 rounded-lg overflow-hidden focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-100">
                        <div id="privMechToolbar" class="flex items-center gap-0.5 px-2 py-1.5 bg-gray-50 border-b border-gray-200 flex-wrap">
                            @RichToolbarButtons()
                        </div>
                        <div id="privMechEditor"
                             class="min-h-[140px] max-h-[240px] overflow-y-auto px-3 py-2 text-xs text-gray-700 outline-none leading-relaxed"
                             contenteditable="true">
                        </div>
                    </div>
                </div>

            </div>

            @* Footer *@
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-100">
                <button @onclick="ClosePrivilegeDialog"
                        class="text-xs text-gray-500 underline cursor-pointer bg-transparent border-none hover:text-gray-700">
                    Cancel
                </button>
                <button @onclick="SavePrivilegeDialog"
                        class="px-6 py-2 text-xs rounded-lg text-white font-medium border-none cursor-pointer"
                        style="@ThemeConfig.Styles.ButtonPrimary">
                    Submit
                </button>
            </div>

        </div>
    </div>
}
@* ── Add/Edit Membership Tier Dialog ── *@
@if (_showAddTierDialog || _showEditTierDialog)
{
    var isEdit = _showEditTierDialog;
    <div class="fixed inset-0 flex items-start justify-center z-[100]" style="background: rgba(0,0,0,0.4); padding: 70px 20px 20px 20px;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-3xl flex flex-col" style="max-height: calc(100vh - 90px);">

            @* Header *@
            <div class="flex items-center justify-between px-6 py-4 rounded-t-xl"
                 style="@ThemeConfig.Styles.HeaderGradient">
                <div class="flex items-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Style="font-size:18px; color:white;" />
                    <span class="text-sm font-semibold text-white">@(isEdit ? "Edit Membership Tier" : "Add Membership Tier")</span>
                </div>
                <button @onclick="CloseTierDialog"
                        class="flex items-center justify-center w-7 h-7 rounded-full border-none cursor-pointer text-white hover:opacity-80"
                        style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" Color="Color.Inherit" />
                </button>
            </div>

            @* Body *@
            <div class="overflow-y-auto px-6 py-5 flex flex-col gap-5">

                @* 4 Upload Areas *@
                <div class="grid grid-cols-4 gap-4">
                    @* Membership Card *@
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-xs text-gray-600 text-center">Upload Membership Card Here</span>
                        <label class="w-full cursor-pointer">
                            <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden"
                                 style="height:100px;">
                                @if (!string.IsNullOrEmpty(_tierMembershipCardUrl))
                                {
                                    <img src="@_tierMembershipCardUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-gray-300">
                                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                        <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                        <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                    </svg>
                                }
                            </div>
                            <InputFile OnChange="e => OnTierImageSelected(e, 0)" accept="image/*" class="hidden" />
                        </label>
                    </div>

                    @* VIP Card *@
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-xs text-gray-600 text-center">Upload VIP Card Here</span>
                        <label class="w-full cursor-pointer">
                            <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden"
                                 style="height:100px;">
                                @if (!string.IsNullOrEmpty(_tierVipCardUrl))
                                {
                                    <img src="@_tierVipCardUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                        <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                        <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                    </svg>
                                }
                            </div>
                            <InputFile OnChange="e => OnTierImageSelected(e, 1)" accept="image/*" class="hidden" />
                        </label>
                    </div>

                    @* QR Code Frame *@
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-xs text-gray-600 text-center">Upload QR Code Frame Here</span>
                        <label class="w-full cursor-pointer">
                            <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden"
                                 style="height:100px;">
                                @if (!string.IsNullOrEmpty(_tierQrFrameUrl))
                                {
                                    <img src="@_tierQrFrameUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                        <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
