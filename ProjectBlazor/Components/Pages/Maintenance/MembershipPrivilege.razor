@page "/maintenance/membershipprivilege"
@rendermode InteractiveServer
@inject IJSRuntime JS
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Shared

<h3 class="text-2xl font-medium mb-4" style="@ThemeConfig.Styles.TextPrimary">Membership & Privilege</h3>

@* Tab bar *@
<div class="flex border-b border-gray-200 mb-4">
    <button @onclick='() => _activeTab = "privileges"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "privileges" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        Privileges Maintenance
    </button>
    <button @onclick='() => _activeTab = "tier"'
            class="px-5 py-2 text-xs font-medium border-b-2 transition"
            style="@(_activeTab == "tier" ? "border-color:@ThemeConfig.Colors.Primary; color:@ThemeConfig.Colors.Primary;" : "border-color:transparent; color:@ThemeConfig.Colors.Text.Secondary;")">
        Membership Tier Maintenance
    </button>
</div>

<div class="grid grid-cols-12 gap-4">

    @if (_activeTab == "privileges")
    {
        <div class="col-span-12">
            <DataTable T="PrivilegeItem"
                       Title="Privileges Maintenance"
                       Items="_privItems"
                       Columns="_privColumns"
                       ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                       HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                       OnAddClick="OpenAddPrivilege" />
        </div>
    }
    else
    {
        <div class="col-span-12">
            <DataTable T="MembershipTierItem"
                       Title="Membership Tier Maintenance"
                       Items="_tierItems"
                       Columns="_tierColumns"
                       ButtonColor="@ProjectBlazor.Components.ThemeConfig.Colors.Primary"
                       HeaderGradient="@ProjectBlazor.Components.ThemeConfig.Styles.HeaderGradient"
                       OnAddClick="OpenAddTier" />
        </div>
    }

</div>

@* ── Add/Edit Privilege Dialog ── *@
@if (_showAddPrivilegeDialog || _showEditPrivilegeDialog)
{
    var isEdit = _showEditPrivilegeDialog;
    <DialogModal IsVisible="_showAddPrivilegeDialog || _showEditPrivilegeDialog"
                 Title="@(isEdit ? "Edit Privilege" : "Add Privilege")"
                 Icon="@Icons.Material.Filled.CardGiftcard"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="ClosePrivilegeDialog">
        <ChildContent>
            <div class="flex items-center gap-6 mb-2">
                <img src="@(string.IsNullOrEmpty(_privImageUrl) ? "/images/default.jpg" : _privImageUrl)"
                     class="w-24 h-24 rounded-full object-cover border-2 border-gray-200 bg-gray-100" />
                <label class="flex items-center gap-2 px-5 py-2 rounded-lg text-white text-xs font-medium cursor-pointer"
                       style="background:@ThemeConfig.Colors.Primary;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="white" stroke-width="2" fill="none" />
                        <circle cx="8.5" cy="8.5" r="1.5" fill="white" />
                        <polyline points="21,15 16,10 5,21" stroke="white" stroke-width="2" stroke-linejoin="round" />
                    </svg>
                    Upload Image
                    <InputFile OnChange="OnPrivImageSelected" accept="image/*" class="hidden" />
                </label>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
                <input type="text" @bind="_privName"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Description</label>
                <textarea @bind="_privDescription" rows="4"
                          class="w-full border border-gray-300 rounded px-3 py-2 text-xs resize-y focus:outline-none"></textarea>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Validity</label>
                <input type="date" @bind="_privValidityDate"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Business Type Name <span class="text-red-500">*</span></label>
                <select @bind="_privBusinessTypeName"
                        class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                    <option value="">-Select Business Type-</option>
                    <option value="Health">Health</option>
                    <option value="Rooms & Suites">Rooms & Suites</option>
                    <option value="Food & Beverages">Food & Beverages</option>
                    <option value="Access to co-working spaces">Access to co-working spaces</option>
                </select>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Terms and Conditions <span class="text-red-500">*</span></label>
                <div class="border border-gray-300 rounded-lg overflow-hidden focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-100">
                    <div id="privTermsToolbar" class="flex items-center gap-0.5 px-2 py-1.5 bg-gray-50 border-b border-gray-200 flex-wrap">
                        @RichToolbarButtons()
                    </div>
                    <div id="privTermsEditor"
                         class="min-h-[100px] max-h-[200px] overflow-y-auto px-3 py-2 text-xs text-gray-700 outline-none leading-relaxed"
                         contenteditable="true">
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Mechanics <span class="text-red-500">*</span></label>
                <div class="border border-gray-300 rounded-lg overflow-hidden focus-within:border-amber-500 focus-within:ring-2 focus-within:ring-amber-100">
                    <div id="privMechToolbar" class="flex items-center gap-0.5 px-2 py-1.5 bg-gray-50 border-b border-gray-200 flex-wrap">
                        @RichToolbarButtons()
                    </div>
                    <div id="privMechEditor"
                         class="min-h-[140px] max-h-[240px] overflow-y-auto px-3 py-2 text-xs text-gray-700 outline-none leading-relaxed"
                         contenteditable="true">
                    </div>
                </div>
            </div>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Submit"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="ClosePrivilegeDialog"
                          OnConfirm="SavePrivilegeDialog" />
        </FooterContent>
    </DialogModal>
}
@* ── Add/Edit Membership Tier Dialog ── *@
@if (_showAddTierDialog || _showEditTierDialog)
{
    var isEdit = _showEditTierDialog;
    <DialogModal IsVisible="_showAddTierDialog || _showEditTierDialog"
                 Title="@(isEdit ? "Edit Membership Tier" : "Add Membership Tier")"
                 Icon="@Icons.Material.Filled.Star"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="CloseTierDialog">
        <ChildContent>
            <div class="grid grid-cols-4 gap-4">
                <div class="flex flex-col items-center gap-1">
                    <span class="text-xs text-gray-600 text-center">Upload Membership Card Here</span>
                    <label class="w-full cursor-pointer">
                        <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden" style="height:100px;">
                            @if (!string.IsNullOrEmpty(_tierMembershipCardUrl))
                            {
                                <img src="@_tierMembershipCardUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-gray-300">
                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                </svg>
                            }
                        </div>
                        <InputFile OnChange="e => OnTierImageSelected(e, 0)" accept="image/*" class="hidden" />
                    </label>
                </div>

                <div class="flex flex-col items-center gap-1">
                    <span class="text-xs text-gray-600 text-center">Upload VIP Card Here</span>
                    <label class="w-full cursor-pointer">
                        <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden" style="height:100px;">
                            @if (!string.IsNullOrEmpty(_tierVipCardUrl))
                            {
                                <img src="@_tierVipCardUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                </svg>
                            }
                        </div>
                        <InputFile OnChange="e => OnTierImageSelected(e, 1)" accept="image/*" class="hidden" />
                    </label>
                </div>

                <div class="flex flex-col items-center gap-1">
                    <span class="text-xs text-gray-600 text-center">Upload QR Code Frame Here</span>
                    <label class="w-full cursor-pointer">
                        <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden" style="height:100px;">
                            @if (!string.IsNullOrEmpty(_tierQrFrameUrl))
                            {
                                <img src="@_tierQrFrameUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                </svg>
                            }
                        </div>
                        <InputFile OnChange="e => OnTierImageSelected(e, 2)" accept="image/*" class="hidden" />
                    </label>
                </div>

                <div class="flex flex-col items-center gap-1">
                    <span class="text-xs text-gray-600 text-center">Upload VIP Badge Here</span>
                    <label class="w-full cursor-pointer">
                        <div class="border border-gray-300 rounded bg-gray-50 flex items-center justify-center overflow-hidden" style="height:100px;">
                            @if (!string.IsNullOrEmpty(_tierVipBadgeUrl))
                            {
                                <img src="@_tierVipBadgeUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <polyline points="3,17 8,12 12,16 16,11 21,17" stroke="@ThemeConfig.Colors.Text.LightGray" stroke-width="1.5" fill="none" />
                                    <circle cx="8" cy="8" r="1.5" fill="@ThemeConfig.Colors.Text.LightGray" />
                                </svg>
                            }
                        </div>
                        <InputFile OnChange="e => OnTierImageSelected(e, 3)" accept="image/*" class="hidden" />
                    </label>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 items-start">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Text Card Color:</label>
                    <div class="flex items-center gap-2">
                        <input type="color" @bind="_tierTextCardColor"
                               class="w-12 h-10 rounded border border-gray-300 cursor-pointer p-0.5" />
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Membership Country</label>
                    <select @bind="_tierCountry"
                            class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none">
                        <option value="">-Select Country-</option>
                        <option value="Qatar">Qatar</option>
                        <option value="Oman">Oman</option>
                        <option value="UAE">UAE</option>
                        <option value="Saudi Arabia">Saudi Arabia</option>
                        <option value="Kuwait">Kuwait</option>
                        <option value="Bahrain">Bahrain</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Membership Name <span class="text-red-500">*</span></label>
                    <input type="text" @bind="_tierName"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Description</label>
                    <input type="text" @bind="_tierDescription"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Date Used</label>
                    <input type="date" @bind="_tierDateStarted"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Date Ended</label>
                    <input type="date" @bind="_tierDateEnded"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">User Count</label>
                    <input type="number" @bind="_tierUserCount"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">VIP Count</label>
                    <input type="number" @bind="_tierVipCount"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-xs focus:outline-none" />
                </div>
            </div>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Submit"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CloseTierDialog"
                          OnConfirm="SaveTierDialog" />
        </FooterContent>
    </DialogModal>
}
@code {

    private string _activeTab = "privileges";

    // ── Column Definitions ──
    private List<TableColumn<PrivilegeItem>> _privColumns = new();
    private List<TableColumn<MembershipTierItem>> _tierColumns = new();

    protected override void OnInitialized()
    {
        _privColumns = new List<TableColumn<PrivilegeItem>>
{
    new() {
        Header = "Name", Width = "20%", SortField = "Name",
        RenderCell = item => __builder => {
<div class="relative w-full flex items-center gap-2 group" style="height:80px;">
    <img src="@item.ImageUrl" class="w-10 h-10 rounded object-cover flex-shrink-0" alt="@item.Name" />
    <div class="relative flex-1" style="height:64px;">
        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:0px;">@item.Code</div>
        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 group-hover:translate-y-2" style="top:12px;">@item.Name</div>
        <div class="absolute left-0 flex gap-1 transition-transform duration-200 group-hover:translate-y-2" style="top:36px;">
            <button @onclick="() => OpenEditPrivilege(item)"
                    class="flex items-center gap-0.5 text-xs cursor-pointer border-none bg-transparent"
                    style="color: @ThemeConfig.Colors.Primary;">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 12px;" Color="Color.Inherit" /> Edit
            </button>
            <button class="flex items-center gap-0.5 text-xs cursor-pointer border-none bg-transparent text-red-500">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 12px;" Color="Color.Inherit" /> Delete
            </button>
            <button class="flex items-center gap-0.5 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 12px;" Color="Color.Inherit" /> View
            </button>
        </div>
    </div>
</div>
        ;
        }
    },
    new() { Header = "Description", Width = "25%", SortField = "Description", RenderCell = item => __builder => {

<span class="text-gray-600">@item.Description</span>
; } },
    new() { Header = "Validity",      Width = "10%", SortField = "Validity",      RenderCell = item => __builder => {

<span class="text-gray-600 whitespace-nowrap">@item.Validity</span>
; } },
    new() { Header = "No Expiry",     Width = "10%", SortField = "NoExpiry",      RenderCell = item => __builder => {

<span class="text-gray-600">@item.NoExpiry</span>
; } },
    new() { Header = "Business Type", Width = "15%", SortField = "BusinessTypeName", RenderCell = item => __builder => {

<span class="text-gray-600">@item.BusinessTypeName</span>
; } },
    new() { Header = "Date Created",  Width = "12%", SortField = "DateCreated",   RenderCell = item => __builder => {

<span class="text-gray-600 whitespace-nowrap">@item.DateCreated</span>
; } }
};

        _tierColumns = new List<TableColumn<MembershipTierItem>>
        {
            new() {
                Header = "Name", Width = "15%", SortField = "Name",
                RenderCell = item => __builder => {
                    <div class="relative w-full" style="height:80px;">
                        <div class="absolute left-0 text-gray-400 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200" style="top:4px;">@item.Code</div>
                        <div class="absolute left-0 font-medium text-gray-700 transition-transform duration-200 group-hover:translate-y-2" style="top:12px;">@item.Name</div>
                        <div class="absolute left-0 flex gap-2 transition-transform duration-200 group-hover:translate-y-2" style="top:36px;">
                            <button @onclick="() => OpenEditTier(item)" class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent" style="color: @ThemeConfig.Colors.Primary;">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size: 14px;" Color="Color.Inherit" /> Edit
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-red-500">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Style="font-size: 14px;" Color="Color.Inherit" /> Delete
                            </button>
                            <button class="flex items-center gap-1 text-xs cursor-pointer border-none bg-transparent text-gray-600">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 14px;" Color="Color.Inherit" /> View
                            </button>
                        </div>
                    </div>
                    ;
                }
            },
            new() { Header = "Description", SortField = "Description", RenderCell = item => __builder => { <span class="text-gray-600">@item.Description</span>; } },
            new() { Header = "Date Started", SortField = "DateStarted", RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateStarted</span>; } },
            new() { Header = "Date Ended", SortField = "DateEnded", RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateEnded</span>; } },
            new() { Header = "User Count", SortField = "UserCount", RenderCell = item => __builder => { <span class="text-gray-600">@item.UserCount</span>; } },
            new() { Header = "VIP Count", SortField = "VipCount", RenderCell = item => __builder => { <span class="text-gray-600">@item.VipCount</span>; } },
            new() { Header = "Date Created", SortField = "DateCreated", RenderCell = item => __builder => { <span class="text-gray-600 whitespace-nowrap">@item.DateCreated</span>; } }
        };
    }

    // ── RICH TOOLBAR BUTTONS (shared across all 4 editors) ──
    private RenderFragment RichToolbarButtons() => __builder =>
    {
        <button type="button" data-cmd="bold"
                class="w-7 h-7 flex items-center justify-center rounded text-xs font-bold text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer">
            <b>B</b>
        </button>
        <button type="button" data-cmd="italic"
                class="w-7 h-7 flex items-center justify-center rounded text-xs italic text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer">
            <i>I</i>
        </button>
        <div class="w-px h-4 bg-gray-300 mx-1"></div>
        <button type="button" data-cmd="insertUnorderedList"
                class="w-7 h-7 flex items-center justify-center rounded text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer"
                title="Bullet List">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <circle cx="4" cy="7" r="2" fill="currentColor" />
                <circle cx="4" cy="12" r="2" fill="currentColor" />
                <circle cx="4" cy="17" r="2" fill="currentColor" />
                <line x1="9" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="9" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="9" y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
        </button>
        <button type="button" data-cmd="insertOrderedList"
                class="w-7 h-7 flex items-center justify-center rounded text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer"
                title="Numbered List">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <line x1="10" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="10" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="10" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <rect x="3" y="4" width="4" height="4" rx="0.5" stroke="currentColor" stroke-width="1.5" fill="none" />
                <rect x="3" y="10" width="4" height="4" rx="0.5" stroke="currentColor" stroke-width="1.5" fill="none" />
                <rect x="3" y="16" width="4" height="4" rx="0.5" stroke="currentColor" stroke-width="1.5" fill="none" />
            </svg>
        </button>
        <div class="w-px h-4 bg-gray-300 mx-1"></div>
        <button type="button" data-cmd="indent"
                class="w-7 h-7 flex items-center justify-center rounded text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer"
                title="Indent">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="9" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <line x1="9" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <polyline points="3,9 6,12 3,15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
        </button>
        <button type="button" data-cmd="outdent"
                class="w-7 h-7 flex items-center justify-center rounded text-gray-600 hover:bg-gray-200 border-none bg-transparent cursor-pointer"
                title="Outdent">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
