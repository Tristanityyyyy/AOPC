    private async Task SavePrivilegeDialog()
    {
        _privTermsHtml = await JS.InvokeAsync<string>("richEditor.getHtml", "privTermsEditor");
        _privMechanicsHtml = await JS.InvokeAsync<string>("richEditor.getHtml", "privMechEditor");

        if (_showEditPrivilegeDialog && _editingPrivilege != null)
        {
            var index = _privItems.IndexOf(_editingPrivilege);
            if (index >= 0)
            {
                _privItems[index] = _editingPrivilege with
                {
                    ImageUrl = _privImageUrl,
                    Name = _privName,
                    Description = _privDescription,
                    Validity = _privValidityDate.ToString("yyyy-MM-ddTHH:mm:ss"),
                    BusinessTypeName = _privBusinessTypeName,
                    TermsHtml = _privTermsHtml,
                    MechanicsHtml = _privMechanicsHtml
                };
            }
        }
        else
        {
            _privItems.Insert(0, new PrivilegeItem(
                _privName,
                string.IsNullOrEmpty(_privImageUrl) ? "/images/default.jpg" : _privImageUrl,
                _privDescription,
                _privValidityDate.ToString("yyyy-MM-ddTHH:mm:ss"),
                "NO", _privBusinessTypeName,
                DateTime.Now.ToString("MMM d yyyy h:mmtt"),
                _privTermsHtml, _privMechanicsHtml
            ));
        }
        ClosePrivilegeDialog();
    }

