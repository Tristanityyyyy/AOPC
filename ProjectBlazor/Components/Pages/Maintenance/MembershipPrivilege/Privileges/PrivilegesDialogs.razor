@namespace ProjectBlazor.Components.Pages.Maintenance.MembershipPrivilege.Privileges
@using ProjectBlazor.Components.Shared
@using ProjectBlazor.Components.Shared.Form
@using ProjectBlazor.Components
@using ProjectBlazor.Components.Pages.Maintenance.Business.Types

<DialogModal IsVisible="IsVisible"
             Title="Add Privilege"
             Icon="@Icons.Material.Filled.CardGiftcard"
             HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
             OnClose="() => OnClose.InvokeAsync()">
    <ChildContent>
        <FormGrid Columns="2">
            <FormField Label="Title" Required>
                <TextInput @bind-Value="_addTitle" Placeholder="Enter privilege title" />
            </FormField>
            <FormField Label="Business Type">
                <SelectInput @bind-Value="_addBusinessTypeID">
                    <option value="">Select Business Type</option>
                    @foreach (var type in BusinessTypes)
                    {
                        <option value="@type.BusinessTypeID">@type.BusinessTypeName</option>
                    }
                </SelectInput>
            </FormField>
            <FormField Label="Validity">
                <TextInput @bind-Value="_addValidity" Placeholder="e.g. Valid until Dec 31, 2024" />
            </FormField>
            <FormField Label="No Expiry">
                <SelectInput @bind-Value="_addNoExpiry">
                    <option value="0">NO</option>
                    <option value="1">YES</option>
                </SelectInput>
            </FormField>
        </FormGrid>

        <FormField Label="Description">
            <TextAreaInput @bind-Value="_addDescription" Rows="2" Placeholder="Enter privilege description" />
        </FormField>

        <FormField Label="Terms & Conditions">
            <TextAreaInput @bind-Value="_addTmc" Rows="3" Placeholder="Enter terms and conditions" />
        </FormField>

        <FormField Label="Mechanics">
            <TextAreaInput @bind-Value="_addMechanics" Rows="3" Placeholder="Enter mechanics" />
        </FormField>

        <FormField Label="Image">
            <ImageUpload @bind-Value="_addImgUrl" PlaceholderIcon="@Icons.Material.Filled.CardGiftcard" />
        </FormField>
    </ChildContent>
    <FooterContent>
        <DialogFooter ConfirmText="Add Privilege"
                      ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                      OnCancel="() => OnClose.InvokeAsync()"
                      OnConfirm="AddPrivilege" />
    </FooterContent>
</DialogModal>

@if (_showEditDialog)
{
    <DialogModal IsVisible="true"
                 Title="Edit Privilege"
                 Icon="@Icons.Material.Filled.CardGiftcard"
                 HeaderGradient="@ThemeConfig.Styles.HeaderGradient"
                 OnClose="CancelEdit">
        <ChildContent>
            <FormGrid Columns="2">
                <FormField Label="Title" Required>
                    <TextInput @bind-Value="_editTitle" />
                </FormField>
                <FormField Label="Business Type">
                    <SelectInput @bind-Value="_editBusinessTypeID">
                        @foreach (var type in BusinessTypes)
                        {
                            <option value="@type.BusinessTypeID">@type.BusinessTypeName</option>
                        }
                    </SelectInput>
                </FormField>
                <FormField Label="Validity">
                    <TextInput @bind-Value="_editValidity" />
                </FormField>
                <FormField Label="No Expiry">
                    <SelectInput @bind-Value="_editNoExpiry">
                        <option value="0">NO</option>
                        <option value="1">YES</option>
                    </SelectInput>
                </FormField>
            </FormGrid>

            <FormField Label="Description">
                <TextAreaInput @bind-Value="_editDescription" Rows="2" />
            </FormField>

            <FormField Label="Terms & Conditions">
                <TextAreaInput @bind-Value="_editTmc" Rows="3" />
            </FormField>

            <FormField Label="Mechanics">
                <TextAreaInput @bind-Value="_editMechanics" Rows="3" />
            </FormField>

            <FormField Label="Image">
                <ImageUpload @bind-Value="_editImgUrl" PlaceholderIcon="@Icons.Material.Filled.CardGiftcard" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Save Changes"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CancelEdit"
                          OnConfirm="SaveEdit" />
        </FooterContent>
    </DialogModal>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<PrivilegeItem> OnAdd { get; set; }
    [Parameter] public EventCallback<PrivilegeItem> OnEdit { get; set; }
    [Parameter] public List<BusinessTypeDto> BusinessTypes { get; set; } = new();

    private bool _showEditDialog;
    private PrivilegeItem? _editingItem;

    private string _addTitle = "";
    private string _addDescription = "";
    private string _addValidity = "";
    private string _addNoExpiry = "0";
    private string _addBusinessTypeID = "";
    private string _addImgUrl = "";
    private string _addTmc = "";
    private string _addMechanics = "";

    private string _editTitle = "";
    private string _editDescription = "";
    private string _editValidity = "";
    private string _editNoExpiry = "0";
    private string _editBusinessTypeID = "";
    private string _editImgUrl = "";
    private string _editTmc = "";
    private string _editMechanics = "";

    public void OpenAdd()
    {
        _addTitle = "";
        _addDescription = "";
        _addValidity = "";
        _addNoExpiry = "0";
        _addBusinessTypeID = "";
        _addImgUrl = "";
        _addTmc = "";
        _addMechanics = "";
    }

    public void OpenEdit(PrivilegeItem item)
    {
        _editingItem = item;
        _editTitle = item.Name;
        _editDescription = item.Description;
        _editValidity = item.Validity;
        _editNoExpiry = item.NoExpiry == "YES" ? "1" : "0";
        _editBusinessTypeID = "";
        _editImgUrl = item.ImageUrl;
        _editTmc = item.TermsHtml;
        _editMechanics = item.MechanicsHtml;
        _showEditDialog = true;
    }

    private void CancelEdit()
    {
        _showEditDialog = false;
        _editingItem = null;
    }

    private async Task AddPrivilege()
    {
        var businessTypeName = BusinessTypes.FirstOrDefault(t => t.BusinessTypeID == _addBusinessTypeID)?.BusinessTypeName ?? "";
        var newItem = new PrivilegeItem(
            $"PRV-{DateTime.Now:yyyyMMddHHmmss}",
            _addTitle,
            _addImgUrl,
            _addDescription,
            _addValidity,
            _addNoExpiry == "1" ? "YES" : "NO",
            businessTypeName,
            DateTime.Now.ToString("MM/dd/yyyy"),
            _addTmc,
            _addMechanics
        );
        await OnAdd.InvokeAsync(newItem);
        await OnClose.InvokeAsync();
    }

    private async Task SaveEdit()
    {
        if (_editingItem != null)
        {
            var businessTypeName = BusinessTypes.FirstOrDefault(t => t.BusinessTypeID == _editBusinessTypeID)?.BusinessTypeName ?? _editingItem.BusinessTypeName;
            var updatedItem = new PrivilegeItem(
                _editingItem.Code,
                _editTitle,
                _editImgUrl,
                _editDescription,
                _editValidity,
                _editNoExpiry == "1" ? "YES" : "NO",
                businessTypeName,
                _editingItem.DateCreated,
                _editTmc,
                _editMechanics
            );
            await OnEdit.InvokeAsync(updatedItem);
        }
        _showEditDialog = false;
        _editingItem = null;
    }
}
