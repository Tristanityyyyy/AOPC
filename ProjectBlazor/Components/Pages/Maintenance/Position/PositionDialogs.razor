@namespace ProjectBlazor.Components.Pages.Maintenance.Position
@using ProjectBlazor.Components.Shared
@using ProjectBlazor.Components.Shared.Form
@using ProjectBlazor.Components.Shared.Table
@using ProjectBlazor.Components
@using MudBlazor

@if (ShowAddDialog)
{
    <DialogModal IsVisible="true"
                 Title="Add Position"
                 Icon="@Icons.Material.Filled.Work"
                 HeaderGradient="@PositionBodyRef.PositionHeader.HeaderGradient"
                 OnClose="() => ShowAddDialog = false">
        <ChildContent>
            <FormField Label="Position Name" Required>
                <TextInput @bind-Value="_addName" Placeholder="Enter position name" />
            </FormField>
            <FormField Label="Position Description">
                <TextAreaInput @bind-Value="_addDescription" Rows="3" Placeholder="Enter position description" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Add Position"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="() => ShowAddDialog = false"
                          OnConfirm="AddPosition" />
        </FooterContent>
    </DialogModal>
}

@if (ShowEditDialog)
{
    <DialogModal IsVisible="true"
                 Title="Edit Position"
                 Icon="@Icons.Material.Filled.Work"
                 HeaderGradient="@PositionBodyRef.PositionHeader.HeaderGradient"
                 OnClose="CancelEdit">
        <ChildContent>
            <FormField Label="Position Name" Required>
                <TextInput @bind-Value="_editName" />
            </FormField>
            <FormField Label="Position Description">
                <TextAreaInput @bind-Value="_editDescription" Rows="3" />
            </FormField>
        </ChildContent>
        <FooterContent>
            <DialogFooter ConfirmText="Save Changes"
                          ButtonStyle="@ThemeConfig.Styles.ButtonPrimary"
                          OnCancel="CancelEdit"
                          OnConfirm="SaveEdit" />
        </FooterContent>
    </DialogModal>
}

@code {
    [Parameter] public PositionBody? PositionBodyRef { get; set; }
    [Inject] private PositionService? PositionService { get; set; }

    private PositionBody? PositionBody => PositionBodyRef;

    public bool ShowAddDialog { get; set; }
    public bool ShowEditDialog { get; set; }
    private PositionItem? _editingItem;
    private bool _isProcessing;

    private string _addName = "";
    private string _addDescription = "";

    private string _editName = "";
    private string _editDescription = "";

    public void OpenAdd()
    {
        _addName = ""; _addDescription = "";
        ShowAddDialog = true;
    }

    public void OpenEdit(PositionItem item)
    {
        _editingItem = item;
        _editName = item.Name;
        _editDescription = item.Description;
        ShowEditDialog = true;
    }

    private void CancelEdit()
    {
        ShowEditDialog = false;
        _editingItem = null;
    }

    private async Task AddPosition()
    {
        if (_isProcessing) return;
        _isProcessing = true;
        try
        {
            var positionID = $"POS-{DateTime.Now.Ticks}";
            var success = await PositionService!.SavePositionAsync(
                0,
                _addName,
                _addDescription,
                positionID,
                DateTime.Now
            );

            if (success)
            {
                PositionBody?.Items.Insert(0, new PositionItem(
                    0,
                    positionID,
                    _addName,
                    _addDescription,
                    DateTime.Now,
                    5
                ));
                ShowAddDialog = false;
            }
        }
        catch
        {
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SaveEdit()
    {
        if (_editingItem == null || _isProcessing) return;
        _isProcessing = true;
        try
        {
            var beforeData = new PositionDto
            {
                Id = _editingItem.Id,
                PositionID = _editingItem.PositionID,
                Name = _editingItem.Name,
                Description = _editingItem.Description,
                DateCreated = _editingItem.DateCreated.ToString("o")
            };

            var success = await PositionService!.SavePositionAsync(
                _editingItem.Id,
                _editName,
                _editDescription,
                _editingItem.PositionID,
                _editingItem.DateCreated,
                beforeData
            );

            if (success)
            {
                if (PositionBody != null)
                {
                    var i = PositionBody.Items.FindIndex(x => x.Id == _editingItem.Id);
                    if (i >= 0)
                    {
                        PositionBody.Items[i] = new PositionItem(
                            _editingItem.Id,
                            _editingItem.PositionID,
                            _editName,
                            _editDescription,
                            _editingItem.DateCreated,
                            _editingItem.Status
                        );
                    }
                }
                ShowEditDialog = false;
                _editingItem = null;
            }
        }
        catch
        {
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
